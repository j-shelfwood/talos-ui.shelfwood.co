---
import "@shelfwood/talos-ui/all.css";
import Meta from "../components/Meta.astro";
import { docsNav, slugToHref } from "../docs-nav";

interface Props {
  title: string;
  description?: string;
  /** Collection id of the current page, e.g. "docs/tokens", for active state. */
  slug: string;
}
const { title, description, slug } = Astro.props;
const pageTitle = `${title} — Talos UI`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <Meta title={pageTitle} description={description} />
  </head>
  <body>
    <div class="ambient-overlay"></div>

    <header class="docs-topbar">
      <a class="docs-brand" href="/">
        <span class="dot"></span>
        <span class="eyebrow">SYS://TALOS-UI</span>
      </a>
      <nav class="row" style="gap:1.25rem">
        <a class="docs-toplink eyebrow" href="/manifesto/">Manifesto</a>
        <a class="docs-toplink eyebrow" href="/showcase/">Showcase</a>
        <a class="docs-toplink eyebrow" href="/mosaic/">Mosaic</a>
        <a class="docs-toplink eyebrow" href="https://github.com/shelfwood">Source</a>
      </nav>
    </header>

    <div class="docs-frame">
      <aside class="talos-sidebar docs-sidebar">
        {
          docsNav.map((group) => (
            <div class="talos-nav-group">
              <span class="talos-nav-group__label">{group.label}</span>
              {group.items.map((item) => (
                <a
                  class:list={[
                    "talos-nav-item",
                    item.slug === slug && "talos-nav-item--active",
                  ]}
                  href={slugToHref(item.slug)}
                  aria-current={item.slug === slug ? "page" : undefined}
                >
                  <span class="talos-nav-item__label">{item.label}</span>
                </a>
              ))}
            </div>
          ))
        }
      </aside>

      <main class="docs-main">
        <div class="docs-head stack">
          <span class="eyebrow">// {title}</span>
          <h1 class="docs-title">{title}</h1>
          {description && <p class="muted docs-lede">{description}</p>}
        </div>
        <article class="docs-prose">
          <slot />
        </article>
      </main>
    </div>

    <script>
      // WC registration + ambient grid cursor tracking (shared).
      import { initAmbient } from "../lib/ambient";
      initAmbient();
    </script>

    <style is:global>
      :root { color-scheme: dark; }
      html { background: var(--talos-background); }
      body {
        margin: 0;
        min-height: 100vh;
        color: var(--talos-foreground);
        font-family: var(--talos-font-display);
        font-weight: 300;
        letter-spacing: 0.01em;
        -webkit-font-smoothing: antialiased;
      }
      .eyebrow {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: var(--talos-tracking-hud);
        color: var(--talos-muted-foreground);
      }
      .stack { display: flex; flex-direction: column; gap: 1rem; }
      .row { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
      .muted { color: var(--talos-muted-foreground); }
      .dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: var(--talos-accent);
        box-shadow: 0 0 8px var(--talos-accent);
      }

      /* --- Top bar -------------------------------------------------------- */
      .docs-topbar {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--talos-edge-subtle);
        background: hsl(var(--talos-background-hsl) / 0.7);
        backdrop-filter: blur(8px);
      }
      .docs-brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
      .docs-toplink { text-decoration: none; transition: color var(--talos-dur-fast) ease; }
      .docs-toplink:hover { color: var(--talos-text-primary); }

      /* --- Two-column frame ---------------------------------------------- */
      .docs-frame {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 15rem minmax(0, 1fr);
        max-width: 1180px;
        margin: 0 auto;
        align-items: start;
      }
      .docs-sidebar {
        position: sticky;
        top: 0;
        align-self: start;
        max-height: 100vh;
        overflow-y: auto;
        background: transparent;
      }
      .docs-main {
        min-width: 0;
        padding: 3.5rem 2.5rem 6rem;
      }
      .docs-head { margin-bottom: 2.5rem; }
      .docs-title {
        font-weight: 300;
        text-transform: uppercase;
        letter-spacing: var(--talos-tracking-hud);
        margin: 0;
        font-size: clamp(1.8rem, 3.5vw, 2.6rem);
        line-height: 1.05;
      }
      .docs-lede { max-width: 60ch; font-size: 1.02rem; }

      @media (max-width: 820px) {
        .docs-frame { grid-template-columns: 1fr; }
        .docs-sidebar {
          position: static;
          max-height: none;
          flex-direction: row;
          flex-wrap: wrap;
          border-right: 0;
          border-bottom: 1px solid var(--talos-edge-subtle);
        }
        .docs-main { padding: 2rem 1.25rem 4rem; }
      }

      /* --- Markdown prose, Talos-styled ---------------------------------- */
      .docs-prose { max-width: 70ch; }
      .docs-prose > * + * { margin-top: 1.15rem; }
      .docs-prose p,
      .docs-prose li {
        font-family: var(--talos-font-body, var(--talos-font-display));
        font-size: 0.98rem;
        line-height: 1.7;
        color: hsl(var(--talos-foreground-hsl) / 0.86);
      }
      .docs-prose h2,
      .docs-prose h3 {
        font-weight: 300;
        text-transform: uppercase;
        letter-spacing: var(--talos-tracking-hud-tight);
        color: var(--talos-text-primary);
        margin-top: 2.75rem;
      }
      .docs-prose h2 {
        font-size: 1.15rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--talos-edge-subtle);
      }
      .docs-prose h3 { font-size: 1rem; }
      .docs-prose a {
        color: var(--talos-accent);
        text-decoration: none;
        border-bottom: 1px solid hsl(var(--talos-accent-hsl) / 0.35);
      }
      .docs-prose a:hover { border-bottom-color: var(--talos-accent); }
      .docs-prose strong { color: var(--talos-text-primary); font-weight: 400; }

      /* Inline code */
      .docs-prose :not(pre) > code {
        font-family: var(--talos-font-mono, ui-monospace, monospace);
        font-size: 0.85em;
        padding: 0.12em 0.4em;
        background: var(--talos-surface-2);
        border: 1px solid var(--talos-edge-subtle);
        border-radius: var(--talos-radius-sm);
        color: var(--talos-text-primary);
      }

      /* Shiki css-variables theme → Talos palette. Restrained monochrome with
         green accent for strings/values; comments dim; keywords/punctuation in
         foreground tones. Background is transparent so the chamfer fill shows. */
      .docs-prose {
        /* shiki sets the pre's inline background from --astro-code-background;
           that inline style wins over our stylesheet, so we point it AT the
           edge colour — it becomes the chamfer hairline layer, with the
           ::before fill covering the interior 1px in. */
        --astro-code-background: var(--talos-edge-default);
        --astro-code-foreground: hsl(var(--talos-foreground-hsl) / 0.9);
        --astro-code-token-comment: var(--talos-text-tertiary);
        --astro-code-token-keyword: hsl(var(--talos-foreground-hsl) / 0.6);
        --astro-code-token-string: var(--talos-accent);
        --astro-code-token-string-expression: var(--talos-accent);
        --astro-code-token-constant: hsl(var(--talos-accent-hsl) / 0.85);
        --astro-code-token-function: var(--talos-text-primary);
      }

      /* Prose opt-out boundary. Live demos (<Demo>) render inside .docs-prose
         and carry .not-content; without this the prose rules above (stray
         top-margin on the first child, link underlines, body font on slotted
         <p>/<a>) leak into demo content. This replaces the dead Starlight
         class that used to supply the opt-out before the Starlight removal. */
      .docs-prose .not-content { margin-top: 0; }
      .docs-prose .not-content :where(p, li) {
        font-family: var(--talos-font-display);
        font-size: inherit;
        line-height: inherit;
        color: inherit;
      }
      .docs-prose .not-content :where(a) {
        color: inherit;
        border-bottom: 0;
      }
      .docs-prose .not-content > * + * { margin-top: 0; }

      /* Fenced code blocks — chamfered HUD frame echoing .talos-code.
         Two-layer chamfer: the host carries the edge colour + clip-path, a
         1px-inset ::before carries the fill. A plain `border` would be sliced
         off the diagonal by clip-path (the chopped-corner defect) — this keeps
         the hairline on the bottom-right cut. */
      .docs-prose pre {
        position: relative;
        isolation: isolate;
        font-family: var(--talos-font-mono, ui-monospace, monospace);
        font-size: 0.85rem;
        line-height: 1.6;
        padding: 1.1rem 1.25rem;
        background: var(--talos-edge-default); /* edge colour shows as the hairline */
        border-radius: 0;
        overflow-x: auto;
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%);
      }
      .docs-prose pre::before {
        content: "";
        position: absolute;
        inset: 1px;
        z-index: -1;
        background: var(--talos-surface-1);
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 9px), calc(100% - 9px) 100%, 0 100%);
      }
      .docs-prose pre > code {
        position: relative;
        z-index: 0;
        background: none;
        border: 0;
        padding: 0;
        font-size: inherit;
        color: inherit;
      }

      /* Tables — zebra hairline, HUD header */
      .docs-prose table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      .docs-prose th {
        text-align: left;
        font-family: var(--talos-font-display);
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: var(--talos-tracking-hud-tight);
        font-size: 0.72rem;
        color: var(--talos-text-tertiary);
        padding: 0.6rem 0.9rem;
        border-bottom: 1px solid var(--talos-edge-strong);
      }
      .docs-prose td {
        padding: 0.6rem 0.9rem;
        border-bottom: 1px solid var(--talos-edge-subtle);
        color: hsl(var(--talos-foreground-hsl) / 0.86);
      }
      .docs-prose tbody tr:nth-child(even) { background: hsl(var(--talos-foreground-hsl) / 0.02); }
      .docs-prose td code { white-space: nowrap; }

      .docs-prose ul { padding-left: 1.25rem; }
      .docs-prose li { margin-top: 0.35rem; }
      .docs-prose li::marker { color: var(--talos-accent); }
    </style>
  </body>
</html>
