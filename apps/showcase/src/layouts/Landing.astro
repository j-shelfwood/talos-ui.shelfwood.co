---
// Landing — simple centered page (showcase, gallery, 404). A thin wrapper over
// BaseLayout; the shell (head, ambient, nav, scripts, global CSS) lives there.
import BaseLayout from "./BaseLayout.astro";
interface Props {
  title?: string;
  navActive?: string;
}
const { title = "Talos UI", navActive } = Astro.props;
---

<BaseLayout title={title} navActive={navActive} frame="main">
  <slot />
</BaseLayout>
