---
// Homepage = a 3D scroll-JOURNEY (ref: Hyper Scroll). A fixed HUD viewport with
// real perspective; scenes are arranged in Z-space and you fly through them as
// you scroll. Honest motion: the camera tracks YOUR scroll (real input), and
// each scene binds to live/real state. Each scene shows a different part of the
// library doing what it is best at.
import "@j_shelfwood/talos-ui/all.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Talos UI — interfaces that visualise a running system</title>
    <meta name="description" content="A component system for building functional instruments — gauges, trends, meters, flows — where colour and motion are bound to live domain state. Scroll to fly through it." />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      html, body { margin: 0; background: var(--talos-background); color: var(--talos-foreground); font-family: var(--talos-font-display); }
      .lenis.lenis-smooth { scroll-behavior: auto !important; }

      /* Fixed window with real perspective — we fly through it. The perspective
         is a CSS var so the camera loop can WARP it with scroll velocity
         (fast scroll → tighter FOV → "hyperspace" pull). Default = at-rest. */
      .viewport { position: fixed; inset: 0; overflow: hidden; z-index: 1;
        perspective: var(--cam-fov, 1100px); perspective-origin: 50% 50%; }
      /* The world carries the velocity dive-tilt + mouse parallax lean. It sits
         at 50%/50% so its rotations pivot about the viewport centre. */
      .world { position: absolute; left: 50%; top: 50%; width: 0; height: 0;
        transform-style: preserve-3d; will-change: transform; }

      /* Real particle starfield: each .star is a div placed in Z-space and
         stretched along Z under velocity → warp-streaks. (Replaces the old flat
         CSS-texture div, which couldn't elongate.) */
      .starfield { position: absolute; left: 0; top: 0; transform-style: preserve-3d; }
      .star { position: absolute; left: 0; top: 0; width: 2px; height: 2px;
        background: hsl(0 0% 100% / 0.55); border-radius: 50%;
        will-change: transform, opacity; backface-visibility: hidden; }

      /* Scenes live at increasing -Z; perspective scales them as they approach. */
      .scene { position: absolute; left: 50%; top: 50%; width: min(1100px, 92vw);
        transform: translate(-50%, -50%); transform-style: preserve-3d;
        will-change: transform, opacity; }
      .scene[data-hidden="1"] { visibility: hidden; }
      /* Accent ghost on fast scroll — a faint accent-tinted drop-shadow offset,
         our monochrome restyle of the reference's red/cyan RGB-split. Magnitude
         is driven by --ghost (px, set by the camera loop from velocity); at rest
         --ghost is 0 and the filter is a no-op. drop-shadow (not box-shadow) so
         it traces the scene's actual instrument silhouettes, not a bounding box. */
      .scene { filter: drop-shadow(var(--ghost, 0px) 0 0 hsl(var(--talos-accent-hsl) / .4)); }

      /* scroll proxy gives the page height — one viewport per scene */
      .scroll-proxy { position: relative; z-index: 0; }

      /* ---- HUD overlay ---- */
      .hud { position: fixed; inset: 0; z-index: 3; pointer-events: none; }
      .hud a, .hud button { pointer-events: auto; }
      .hud-line { position: absolute; background: var(--talos-edge-subtle); }
      .hud-line--top { top: 56px; left: 24px; right: 24px; height: 1px; }
      .hud-line--bottom { bottom: 56px; left: 24px; right: 24px; height: 1px; }
      .hud-top, .hud-bottom { position: absolute; left: 24px; right: 24px; display: flex; align-items: center; justify-content: space-between; font-size: .7rem; text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); color: var(--talos-muted-foreground); }
      .hud-top { top: 20px; } .hud-bottom { bottom: 20px; }
      .hud-top nav a, .hud-bottom a { color: var(--talos-muted-foreground); text-decoration: none; margin-left: 1.25rem; transition: color .18s; }
      .hud-top nav a:hover { color: var(--talos-foreground); }
      .brand { display: inline-flex; align-items: center; gap: .5rem; color: var(--talos-foreground); text-decoration:none; }
      .brand .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--talos-accent); box-shadow: 0 0 8px var(--talos-accent); }
      .hud-progress { position: absolute; right: 22px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 9px; }
      .hud-progress span { width: 8px; height: 1px; background: var(--talos-edge-default); transition: width .25s, background .25s; cursor: pointer; pointer-events: auto; }
      .hud-progress span.active { width: 22px; background: var(--talos-accent); }
      .scroll-cue { position: absolute; left: 50%; bottom: 64px; transform: translateX(-50%); font-size: .62rem; letter-spacing: var(--talos-tracking-hud); color: var(--talos-muted-foreground); text-transform: uppercase; animation: cue 2.4s ease-in-out infinite; }
      @keyframes cue { 0%,100%{opacity:.3;transform:translate(-50%,0)} 50%{opacity:1;transform:translate(-50%,5px)} }

      .scanlines { position: fixed; inset: 0; z-index: 2; pointer-events: none; background: repeating-linear-gradient(to bottom, transparent 0 2px, rgba(0,0,0,.16) 2px 3px); mix-blend-mode: multiply; opacity: .5; }
      .vignette { position: fixed; inset: 0; z-index: 2; pointer-events: none; background: radial-gradient(120% 100% at 50% 50%, transparent 52%, rgba(0,0,0,.6) 100%); }

      /* ---- live HUD garnish: brackets, rulers, scroll-bound readouts ---- */
      /* Corner viewfinder brackets. */
      .bracket { position: absolute; width: 18px; height: 18px; border: 1px solid var(--talos-edge-default); }
      .bracket--tl { top: 48px; left: 16px; border-right: 0; border-bottom: 0; }
      .bracket--tr { top: 48px; right: 16px; border-left: 0; border-bottom: 0; }
      .bracket--bl { bottom: 48px; left: 16px; border-right: 0; border-top: 0; }
      .bracket--br { bottom: 48px; right: 16px; border-left: 0; border-top: 0; }

      /* Left-edge ruler — ticks; a marker rides it at scroll progress. */
      .ruler { position: absolute; left: 16px; top: 96px; bottom: 96px; width: 1px; }
      .ruler__track { position: absolute; inset: 0; }
      .ruler__tick { position: absolute; left: 0; width: 6px; height: 1px; background: var(--talos-edge-subtle); }
      .ruler__tick--major { width: 11px; background: var(--talos-edge-default); }
      .ruler__marker { position: absolute; left: -3px; width: 13px; height: 1px; background: var(--talos-accent); box-shadow: 0 0 6px hsl(var(--talos-accent-hsl)/.7); transition: none; }
      .ruler__pct { position: absolute; left: 16px; transform: translateY(-50%); font-size: .6rem; letter-spacing: .1em; color: var(--talos-accent); font-variant-numeric: tabular-nums; }

      /* Readout cluster, lower-left — live scroll telemetry. */
      .readouts { position: absolute; left: 40px; bottom: 96px; display: flex; flex-direction: column; gap: 6px;
        font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; color: var(--talos-muted-foreground); font-variant-numeric: tabular-nums; }
      .readouts b { color: var(--talos-foreground); font-weight: 400; }
      .readouts .k { color: var(--talos-text-tertiary, var(--talos-muted-foreground)); }

      /* Center-bottom big scroll value. */

      /* Right-edge coordinate ticks that scrub with scroll. */
      .coords { position: absolute; right: 40px; top: 96px; display: flex; flex-direction: column; gap: 6px; align-items: flex-end;
        font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; color: var(--talos-muted-foreground); font-variant-numeric: tabular-nums; }
      .coords b { color: var(--talos-foreground); font-weight: 400; }

      /* typography */
      .eyebrow { font-size: .7rem; text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); color: var(--talos-muted-foreground); }
      .display { font-weight: 300; text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); line-height: 1.02; margin: .5rem 0; font-size: clamp(2.2rem, 5.5vw, 5rem); }
      .lede { max-width: 48ch; color: var(--talos-muted-foreground); font-size: clamp(1rem,1.3vw,1.18rem); line-height: 1.6; }
      .scene-title { font-size: .72rem; text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); color: var(--talos-text-tertiary, var(--talos-muted-foreground)); }
      .center { text-align: center; }
      .row { display:flex; gap:2.5rem; flex-wrap:wrap; align-items:center; justify-content:center; }
      .cta { display:inline-flex; gap:.9rem; margin-top:1.5rem; flex-wrap:wrap; justify-content:center; }
      .cta a { display:inline-flex; align-items:center; padding:.6rem 1.2rem; font-size:.78rem; text-transform:uppercase; letter-spacing:.06em; text-decoration:none; border:1px solid var(--talos-edge-default); color:var(--talos-foreground); transition:border-color .18s, background .18s; clip-path: polygon(0 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%); }
      .cta a:hover { border-color: var(--talos-edge-strong); background: var(--talos-surface-2); }
      .cta a.primary { border-color: hsl(var(--talos-accent-hsl)/.5); color: var(--talos-accent); }
      .quote { font-weight: 300; text-transform: uppercase; letter-spacing: .04em; line-height: 1.15; font-size: clamp(1.6rem,3.4vw,3rem); max-width: 20ch; margin: 0 auto; }
      .quote .accent { color: var(--talos-accent); }

      /* mini console for the console scene */
      .mini-console { display:grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
      .mini-cell { border:1px solid var(--talos-edge-subtle); background: var(--talos-surface-1); padding: 1rem; display:flex; flex-direction:column; align-items:center; gap:.5rem; }
      .mini-cell .scene-title { align-self:flex-start; }

      /* ---- Scene 06: MISSION CONSOLE — maximal density -------------------
         Not a centered column — a full telemetry wall. ~50 live signals in
         grouped blocks, each row carrying a value + an inline mini-bar + a
         range/delta. A derived stat-strip caps it. Reads like a mission
         console: everything at once, scanned not read. Every glyph is a real
         vital of this tab. -------------------------------------------------- */
      .console-strip {
        display: grid; grid-auto-flow: column; grid-auto-columns: 1fr;
        gap: 0; border: 1px solid var(--talos-edge-subtle);
        margin-top: 1rem; font-variant-numeric: tabular-nums;
      }
      .strip-cell { padding: .5rem .8rem; border-right: 1px solid var(--talos-edge-subtle); }
      .strip-cell:last-child { border-right: 0; }
      .strip-cell .sk { font-size:.5rem; letter-spacing:.16em; text-transform:uppercase;
        color: var(--talos-text-tertiary); display:block; }
      .strip-cell .sv { font-size:1.1rem; font-weight:300; color: var(--talos-foreground); }
      .strip-cell .sv small { font-size:.5rem; color: var(--talos-text-tertiary); }

      .console-wall {
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 0; margin-top: 1rem;
        border: 1px solid var(--talos-edge-subtle);
      }
      .wall-block { border-right: 1px solid var(--talos-edge-subtle);
        border-bottom: 1px solid var(--talos-edge-subtle); padding: .55rem .7rem .65rem; }
      /* close the right/bottom seams */
      .wall-block:nth-child(4n) { border-right: 0; }
      .block-head { display:flex; justify-content:space-between; align-items:baseline;
        margin-bottom:.4rem; padding-bottom:.25rem; border-bottom:1px solid var(--talos-edge-default); }
      .block-head .bt { font-size:.56rem; letter-spacing:.18em; text-transform:uppercase;
        color: var(--talos-foreground); }
      .block-head .bm { font-size:.5rem; letter-spacing:.1em; color: var(--talos-text-tertiary); }
      /* the row primitive: label · value · mini-bar · range */
      .metric { display:grid; grid-template-columns: 4.2rem 1fr; align-items:center;
        column-gap:.5rem; padding:.18rem 0; font-size:.6rem; letter-spacing:.04em; }
      .metric .mk { text-transform:uppercase; color: var(--talos-text-tertiary); }
      .metric .mr { display:flex; align-items:center; gap:.45rem; }
      .metric .mv { min-width:3.1rem; text-align:right; color: var(--talos-foreground);
        font-variant-numeric: tabular-nums; }
      .metric .mv[data-band="warn"] { color: var(--talos-warning); }
      .metric .mv[data-band="crit"] { color: var(--talos-danger); }
      .metric .mbar { flex:1; height:3px; background: var(--talos-surface-2);
        position:relative; overflow:hidden; min-width:2rem; }
      .metric .mbar > i { position:absolute; inset:0 auto 0 0; width:0%;
        background: var(--talos-accent); transition: width .28s var(--talos-ease-out, ease); }
      .metric .mbar[data-band="warn"] > i { background: var(--talos-warning); }
      .metric .mbar[data-band="crit"] > i { background: var(--talos-danger); }
      .metric .mx { min-width:3.4rem; font-size:.5rem; color: var(--talos-text-tertiary);
        font-variant-numeric: tabular-nums; text-align:right; }

      /* ---- DIVERSE VIZ PRIMITIVES (break the mini-bar monoculture) ------- */
      /* Sparkline — inline SVG polyline of a metric's recent history. */
      .spark { display:block; width:100%; height:14px; overflow:visible; }
      .spark polyline { fill:none; stroke: var(--talos-accent); stroke-width:1; vector-effect:non-scaling-stroke; }
      .spark[data-band="warn"] polyline { stroke: var(--talos-warning); }
      .spark[data-band="crit"] polyline { stroke: var(--talos-danger); }
      .spark .sparkfill { fill: var(--talos-accent); opacity:.1; stroke:none; }
      /* Dot-matrix — discrete count as filled/empty LED dots. */
      .dotmx { display:inline-flex; gap:2px; align-items:center; flex-wrap:wrap; max-width:6.5rem; }
      .dotmx i { width:5px; height:5px; background: var(--talos-surface-3); display:block; }
      .dotmx i.on { background: var(--talos-accent); box-shadow:0 0 3px hsl(var(--talos-accent-hsl)/.5); }
      .dotmx[data-band="warn"] i.on { background: var(--talos-warning); box-shadow:none; }
      .dotmx[data-band="crit"] i.on { background: var(--talos-danger); box-shadow:none; }
      /* Radial micro-gauge — conic-gradient arc, 0..100 via --p. */
      .radial { --p:0; width:30px; height:30px; border-radius:50%; flex:none;
        background: conic-gradient(var(--talos-accent) calc(var(--p)*1%), var(--talos-surface-2) 0);
        -webkit-mask: radial-gradient(closest-side, transparent 64%, #000 65%);
                mask: radial-gradient(closest-side, transparent 64%, #000 65%);
        position:relative; transition: --p .3s ease; }
      .radial[data-band="warn"] { background: conic-gradient(var(--talos-warning) calc(var(--p)*1%), var(--talos-surface-2) 0); }
      .radial[data-band="crit"] { background: conic-gradient(var(--talos-danger) calc(var(--p)*1%), var(--talos-surface-2) 0); }
      .radial-wrap { display:flex; flex-direction:column; align-items:center; gap:.25rem; }
      .radial-wrap .rl { font-size:.5rem; letter-spacing:.12em; text-transform:uppercase; color: var(--talos-text-tertiary); }
      .radial-wrap .rv { position:absolute; inset:0; display:grid; place-items:center; font-size:.5rem;
        font-variant-numeric:tabular-nums; color: var(--talos-foreground); }
      /* Delta — direction arrow + change magnitude. */
      .delta { font-size:.5rem; font-variant-numeric:tabular-nums; min-width:2.2rem; text-align:right; }
      .delta--up   { color: var(--talos-success); } .delta--up::before   { content:"▲ "; font-size:.8em; }
      .delta--down { color: var(--talos-danger);  } .delta--down::before { content:"▼ "; font-size:.8em; }
      .delta--flat { color: var(--talos-text-tertiary); } .delta--flat::before { content:"▬ "; font-size:.8em; }
      @property --p { syntax:"<number>"; inherits:false; initial-value:0; }

      /* Scene 01 — CORE CONSOLE. One zoned reactor panel that fills the field:
         header rail · asymmetric body (big primary trend + secondary column) ·
         micro-instrument rail · footer aggregate. Reads as a single instrument
         with a mood, not a row of widgets. */
      .rcon { position:relative; width:100%;
        border:1px solid var(--talos-edge-default);
        background:
          linear-gradient(180deg, hsl(0 0% 100% / 0.022), transparent 40%),
          var(--talos-surface-1);
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 14px), calc(100% - 14px) 100%, 0 100%);
      }
      .rcon-head { display:flex; align-items:center; gap:1rem; padding:.7rem 1.1rem;
        border-bottom:1px solid var(--talos-edge-subtle);
        font-size:.62rem; letter-spacing:.16em; text-transform:uppercase; color: var(--talos-text-tertiary); }
      .rcon-id { display:inline-flex; align-items:center; gap:.5rem; color: var(--talos-foreground); }
      .rcon-state { margin-left:.25rem; padding:.12rem .55rem; border:1px solid var(--talos-edge-subtle);
        color: var(--talos-success); letter-spacing:.18em; }
      .rcon-state[data-band="warn"] { color: var(--talos-warning); border-color: hsl(var(--talos-warning-hsl)/.5); }
      .rcon-state[data-band="crit"] { color: var(--talos-danger);  border-color: hsl(var(--talos-danger-hsl)/.6); }
      .rcon-clock { margin-left:auto; } .rcon-clock b { color: var(--talos-foreground); font-weight:400; }

      .rcon-body { display:grid; grid-template-columns: 1.55fr 1fr; gap:0; }
      .rcon-primary { padding:1.1rem 1.2rem; border-right:1px solid var(--talos-edge-subtle); display:flex; flex-direction:column; gap:.9rem; }
      .rcon-side { display:flex; flex-direction:column; }
      .rcon-sub { padding:1rem 1.2rem; }
      .rcon-sub + .rcon-sub { border-top:1px solid var(--talos-edge-subtle); }
      .rcon-cap { display:flex; align-items:baseline; justify-content:space-between; gap:.6rem; margin-bottom:.55rem;
        font-size:.72rem; letter-spacing:.06em; color: var(--talos-foreground); }
      .ires-why { font-size:.5rem; letter-spacing:.14em; text-transform:uppercase; font-weight:400;
        color: var(--talos-text-tertiary); border:1px solid var(--talos-edge-subtle); padding:.1rem .4rem; }

      /* PRIMARY trend with the big load number overlaid top-right. */
      .rcon-trend-wrap { position:relative; }
      .rcon-trend-wrap talos-trend { width:100%; display:block; }
      /* The big banded number is the rcon-bignum overlay; suppress the trend's
         own built-in readout so the figure isn't shown twice. */
      .rcon-trend-wrap talos-trend::part(readout),
      .rcon-trend-wrap talos-trend::part(caption) { display:none; }
      .rcon-bignum { position:absolute; top:-.2rem; right:0; display:flex; align-items:baseline; gap:.35rem;
        pointer-events:none; }
      .rcon-bignum b { font-size:3rem; font-weight:300; line-height:.9; letter-spacing:.01em;
        font-variant-numeric:tabular-nums; color: var(--talos-foreground); }
      .rcon-bignum b[data-band="warn"] { color: var(--talos-warning); }
      .rcon-bignum b[data-band="crit"] { color: var(--talos-danger); }
      .rcon-bignum i { font-style:normal; font-size:.55rem; letter-spacing:.12em; text-transform:uppercase; color: var(--talos-text-tertiary); }

      /* supporting micro-instrument rail under the primary trend. */
      .rcon-microrow { display:grid; grid-template-columns:repeat(4,1fr); gap:.5rem;
        padding-top:.85rem; border-top:1px solid var(--talos-edge-subtle); }
      .umetric { display:flex; align-items:baseline; gap:.35rem; font-size:.62rem; letter-spacing:.04em; }
      .umetric .uk { text-transform:uppercase; font-size:.5rem; letter-spacing:.12em; color: var(--talos-text-tertiary); min-width:2.4rem; }
      .umetric .uv { font-variant-numeric:tabular-nums; color: var(--talos-foreground); }
      .umetric .uv[data-band="warn"] { color: var(--talos-warning); }
      .umetric .uv[data-band="crit"] { color: var(--talos-danger); }
      .umetric .uu { font-size:.5rem; color: var(--talos-text-tertiary); }
      .rcon-subrow { display:flex; flex-wrap:wrap; gap:.4rem 1.1rem; margin-top:.6rem; }
      .rcon-side talos-meter { width:100%; display:block; }

      /* containment count instrument */
      .rcon-count { display:grid; grid-template-columns:auto auto 1fr; align-items:baseline; column-gap:.5rem; }
      .rcon-count .ires-num { font-size:2.4rem; font-weight:300; line-height:1; font-variant-numeric:tabular-nums; color: var(--talos-foreground); }
      .rcon-count i { font-style:normal; font-size:.55rem; letter-spacing:.12em; text-transform:uppercase; color: var(--talos-text-tertiary); }
      .rcon-count .delta { justify-self:end; align-self:center; }
      .rcon-count .spark { grid-column:1/-1; width:100%; height:18px; margin-top:.2rem; }
      .rcon-count .spark polyline { stroke: var(--talos-accent); }

      /* FOOTER aggregate rail */
      .rcon-foot { display:flex; align-items:center; gap:.85rem; padding:.7rem 1.1rem;
        border-top:1px solid var(--talos-edge-subtle); background: hsl(0 0% 100% / 0.012);
        font-size:.58rem; letter-spacing:.12em; text-transform:uppercase; color: var(--talos-text-tertiary); }
      .rcon-foot-k { color: var(--talos-foreground); }
      .rcon-foot-bar { flex:0 0 200px; height:4px; background: var(--talos-surface-2); position:relative; overflow:hidden; }
      .rcon-foot-bar > i { position:absolute; inset:0 auto 0 0; width:0%; background: var(--talos-accent);
        transition: width .3s var(--talos-ease-out,ease), background .3s ease; }
      .rcon-foot-v { font-variant-numeric:tabular-nums; color: var(--talos-foreground); min-width:3rem; }
      .rcon-foot-note { margin-left:auto; text-transform:none; letter-spacing:.02em; color: var(--talos-text-tertiary); }

      .dotmx { display:inline-flex; }

      @media (max-width: 860px) {
        .rcon-body { grid-template-columns:1fr; }
        .rcon-primary { border-right:0; border-bottom:1px solid var(--talos-edge-subtle); }
        .rcon-microrow { grid-template-columns:repeat(2,1fr); }
        .rcon-foot-note { display:none; }
      }
      /* Scene 02 — trend + signal-stats side panel */
      .signal-grid { display:grid; grid-template-columns: 1.7fr 1fr; gap:1.5rem; align-items:stretch; }
      .signal-main { display:flex; flex-direction:column; gap:1rem; }
      .signal-flows { display:flex; gap:1rem; align-items:center; color: var(--talos-text-tertiary);
        font-size:.6rem; text-transform:uppercase; letter-spacing:.14em; }
      .signal-stats { border:1px solid var(--talos-edge-subtle);
        background: linear-gradient(180deg, hsl(0 0% 100% / 0.015), transparent); padding:.7rem 1rem; }
      @media (max-width: 820px) { .signal-grid { grid-template-columns: 1fr; } }
      /* Scene 03 — zoned console shell (rail · scope · aside · status) */
      .cshell { display:grid; grid-template-columns: 8rem 1fr 13rem; grid-template-rows: 1fr auto;
        grid-template-areas: "rail scope aside" "status status status";
        border:1px solid var(--talos-edge-default); min-height:38vh; }
      .cshell-rail { grid-area:rail; display:flex; flex-direction:column; gap:.5rem; padding:.8rem;
        border-right:1px solid var(--talos-edge-subtle); background: var(--talos-surface-0); }
      .crail-brand { display:flex; align-items:center; gap:.4rem; font-size:.6rem; letter-spacing:.12em;
        color: var(--talos-foreground); margin-bottom:.5rem; }
      .crail-brand .dot { width:6px; height:6px; border-radius:50%; background: var(--talos-accent); box-shadow:0 0 6px var(--talos-accent); }
      .crail-item { font-size:.58rem; letter-spacing:.14em; color: var(--talos-text-tertiary); padding:.25rem 0; cursor:default; }
      .crail-item--on { color: var(--talos-foreground); border-left:2px solid var(--talos-accent); padding-left:.5rem; margin-left:-.5rem; }
      .crail-spacer { flex:1; }
      .crail-meta { font-size:.54rem; color: var(--talos-text-tertiary); font-variant-numeric:tabular-nums; }
      .cshell-scope { grid-area:scope; display:grid; grid-template-columns:repeat(3,1fr); gap:0; }
      .ccell { display:flex; flex-direction:column; align-items:center; gap:.4rem; padding:1rem .6rem;
        border-right:1px solid var(--talos-edge-subtle); }
      .ccell:last-child { border-right:0; }
      .ccell-t { font-size:.55rem; letter-spacing:.16em; color: var(--talos-text-tertiary); align-self:flex-start; }
      .ccell-sub { display:flex; align-items:center; gap:.4rem; width:100%; font-size:.58rem; }
      .ccell-sub .mk { color: var(--talos-text-tertiary); } .ccell-sub .spark { flex:1; }
      .ccell-sub .mv { color: var(--talos-foreground); font-variant-numeric:tabular-nums; }
      .cshell-aside { grid-area:aside; display:flex; flex-direction:column; gap:.45rem; padding:.8rem;
        border-left:1px solid var(--talos-edge-subtle); background: var(--talos-surface-0); }
      .caside-label { font-size:.55rem; letter-spacing:.14em; color: var(--talos-text-tertiary); margin-bottom:.2rem; }
      .cshell-status { grid-area:status; display:flex; align-items:center; gap:1rem; padding:.5rem .8rem;
        border-top:1px solid var(--talos-edge-default); font-size:.55rem; letter-spacing:.1em; }
      .cstat { color: hsl(var(--_status)); text-transform:uppercase; font-weight:500; }
      .cstat-sep { width:1px; height:12px; background: var(--talos-edge-default); }
      .cstat-k { color: var(--talos-text-tertiary); text-transform:uppercase; font-variant-numeric:tabular-nums; }
      .cstat-k b { color: var(--talos-foreground); font-weight:400; }
      @media (max-width: 820px) { .cshell { grid-template-columns:1fr; grid-template-areas:"scope" "aside" "status"; }
        .cshell-rail { display:none; } }
      /* Scene 05 — forms + telemetry/validation panel */
      .ctrl-grid { display:grid; grid-template-columns: 1.2fr 1fr; gap:1.5rem; align-items:start; }
      .ctrl-form { display:flex; flex-direction:column; gap:1rem; }
      .ctrl-panel { border:1px solid var(--talos-edge-subtle); padding:.8rem 1rem;
        background: linear-gradient(180deg, hsl(0 0% 100% / 0.015), transparent); display:flex; flex-direction:column; gap:.5rem; }
      .radial-rail { display:flex; gap:1.5rem; justify-content:space-around; padding:.5rem 0 .8rem; }
      @media (max-width: 820px) { .ctrl-grid { grid-template-columns:1fr; } }
      /* Scene 04 — orbital + subsystem legend table */
      .mesh-grid { display:grid; grid-template-columns: minmax(0,440px) 1fr; gap:1.5rem; align-items:center; }
      .mesh-orb { display:flex; justify-content:center; }
      .mesh-legend { border:1px solid var(--talos-edge-subtle); padding:.7rem 1rem;
        background: linear-gradient(180deg, hsl(0 0% 100% / 0.015), transparent); }
      /* :global so innerHTML-injected legend rows pick up the grid (Astro scopes
         <style> by a hash that injected nodes don't carry). Column widths sized
         for the longest reactor label (CONTAINMENT) so cells never collide. */
      :global(.mesh-row) { display:grid; grid-template-columns: 7.5rem 2.2rem 1fr 2.6rem; align-items:center; gap:.9rem;
        font-size:.6rem; padding:.32rem 0; border-bottom:1px solid var(--talos-edge-subtle); font-variant-numeric:tabular-nums; }
      :global(.mesh-row) > span { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
      :global(.mesh-row:last-child) { border-bottom:0; }
      .mesh-row--head { color: var(--talos-text-tertiary); text-transform:uppercase; letter-spacing:.12em;
        border-bottom:1px solid var(--talos-edge-default); }
      :global(.mesh-row .mn) { color: var(--talos-foreground); text-transform:uppercase; }
      :global(.mesh-row .mt) { color: var(--talos-text-tertiary); }
      :global(.mesh-row .mp) { display:flex; align-items:center; gap:.4rem; }
      :global(.mesh-row .mp .mbar) { flex:1; }
      :global(.mesh-row .ma) { color: var(--talos-text-tertiary); }
      @media (max-width: 820px) { .mesh-grid { grid-template-columns:1fr; } }

      /* the dial rail across the top of the wall — glanceable primaries */
      .console-dials { display:flex; gap:1.5rem; align-items:flex-end; flex-wrap:wrap;
        margin-top:1rem; }
      .console-dials .dwrap { display:flex; flex-direction:column; align-items:center; gap:.3rem; }
      .console-dials .dtag { font-size:.5rem; letter-spacing:.16em; text-transform:uppercase;
        color: var(--talos-text-tertiary); }
      .core-panel { width: 200px; }
      @media (max-width: 980px) { .console-wall { grid-template-columns: repeat(2,1fr); }
        .wall-block:nth-child(4n){border-right:1px solid var(--talos-edge-subtle);}
        .wall-block:nth-child(2n){border-right:0;} }

      @media (prefers-reduced-motion: reduce) { .scroll-cue { animation:none; } }
      @media (max-width: 720px) { .mini-console { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <div class="viewport">
      <div class="world" id="world">
        <div class="starfield" id="starfield"><!-- particles injected by the camera script --></div>

        <!-- 0 — THESIS. The hero is framed as a reactor console: every instrument
             below binds to a REAL signal of this tab, reframed as a core reading
             (load/coolant/flux). The numbers are honest telemetry; the stakes are
             the reactor. The page is the running system it depicts. -->
        <section class="scene" data-scene>
          <span class="eyebrow">// @j_shelfwood/talos-ui — v0.0.1 · CORE://TALOS-1</span>
          <h1 class="display">Interfaces that<br />visualise a<br />running system</h1>
          <p class="lede">This page is a reactor console — and the reactor is the page itself. Every gauge, trend and meter ahead is bound to a <em>real</em> signal of this tab, read as a core vital. Scroll to run it.</p>
        </section>

        <!-- 1 — CORE CONSOLE. Not three cards in the void — one zoned reactor
             panel that fills the field (philosophy #1: use the whole field; #4:
             density is a feature). Header rail = core id + LIVE aggregate state +
             clock. Body = a PRIMARY (core-load trend, given the room) flanked by
             SECONDARY vitals (coolant meter, containment count) and a rail of
             supporting micro-instruments. Footer = the aggregate pressure bar.
             The panel's own edge reflects aggregate pressure (activity-edge),
             so the whole console has a mood (#5). Every figure is real tab
             telemetry reframed as a reactor reading; nothing decorative. -->
        <section class="scene" data-scene>
          <span class="scene-title">01 — Core console</span>
          <div class="rcon activity-edge" id="rcon" style="--talos-rate:0">
            <!-- HEADER RAIL -->
            <header class="rcon-head">
              <span class="rcon-id"><span class="talos-dot" id="rcon-dot"></span> CORE://TALOS-1</span>
              <span class="rcon-state" id="rcon-state" data-band="">NOMINAL</span>
              <span class="rcon-clock">RUN <b id="rcon-clock">00:00</b></span>
            </header>

            <div class="rcon-body">
              <!-- PRIMARY — core load. The big trend; its slope is the core's
                   thermal trajectory. A bound sweep crosses it (motion=telemetry). -->
              <div class="rcon-primary">
                <div class="rcon-cap"><span>Core load</span><span class="ires-why">rate → trend</span></div>
                <div class="rcon-trend-wrap">
                  <talos-trend id="t-frame" min="0" max="100" label="" width="560" height="150"></talos-trend>
                  <span class="rcon-bignum"><b id="d-coreload">—</b><i>% budget</i></span>
                </div>
                <div class="rcon-microrow">
                  <div class="umetric"><span class="uk">fps</span><span class="uv" id="d-g1fps">—</span></div>
                  <div class="umetric"><span class="uk">flux</span><span class="uv" id="d-flux">—</span><span class="uu">u/s</span></div>
                  <div class="umetric"><span class="uk">stalls</span><span class="dotmx" id="dm-g1long"></span><span class="uv" id="d-g1long">—</span></div>
                  <div class="umetric"><span class="uk">link</span><span class="uv" id="d-rtt01">—</span><span class="uu">ms</span></div>
                </div>
              </div>

              <!-- SECONDARY COLUMN — coolant (meter) over containment (count). -->
              <div class="rcon-side">
                <div class="rcon-sub">
                  <div class="rcon-cap"><span>Coolant</span><span class="ires-why">load → meter</span></div>
                  <talos-meter id="mt-heap" value="0" warn="70" crit="90" unit="%" label="thermal load" width="240"></talos-meter>
                  <div class="rcon-subrow">
                    <span class="umetric"><span class="uk">used</span><span class="uv" id="d-g2used">—</span><span class="uu">MB</span></span>
                    <span class="umetric"><span class="uk">cap</span><span class="uv" id="d-g2tot">—</span><span class="uu">MB</span></span>
                    <span class="umetric"><span class="uk">peak</span><span class="uv" id="d-g2pk">—</span></span>
                  </div>
                </div>
                <div class="rcon-sub">
                  <div class="rcon-cap"><span>Containment</span><span class="ires-why">count → number</span></div>
                  <div class="rcon-count">
                    <b class="ires-num" id="d-m1n">—</b><i>nodes</i>
                    <span class="delta" id="dl-m1"></span>
                    <svg class="spark" id="sp-m1n"></svg>
                  </div>
                  <div class="rcon-subrow">
                    <span class="umetric"><span class="uk">depth</span><span class="dotmx" id="dm-m1d"></span><span class="uv" id="d-m1d">—</span></span>
                    <span class="umetric"><span class="uk">sheets</span><span class="dotmx" id="dm-m1c"></span><span class="uv" id="d-m1c">—</span></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- FOOTER STATUS RAIL — the aggregate that drives the core state. -->
            <footer class="rcon-foot">
              <span class="rcon-foot-k">Reactor pressure</span>
              <span class="rcon-foot-bar"><i id="rcon-pbar"></i></span>
              <span class="rcon-foot-v" id="rcon-pval">0%</span>
              <span class="rcon-foot-note" id="rcon-note">all subsystems nominal — push the page to load the core</span>
            </footer>
          </div>
        </section>

        <!-- 2 — NEUTRON FLUX & COOLANT LOOP. The "motion is telemetry" scene:
             the trend's shape is the flux rate, the flow dashes' speed is the
             coolant throughput. Both bound to the live sim — freeze the frame and
             the shape/level survive; only the travel (the rate) is lost. -->
        <section class="scene" data-scene>
          <span class="scene-title">02 — Flux &amp; coolant loop</span>
          <p class="lede" style="margin:.5rem 0 0;max-width:58ch">The line's shape is the neutron flux; the dash speed is coolant throughput. Freeze it and you keep the shape and the level — only the motion (the rate itself) is what's lost.</p>
          <div class="signal-grid" style="margin-top:1.5rem">
            <div class="signal-main">
              <div class="block-head" style="margin-bottom:.4rem"><span class="bt">Neutron flux</span><span class="bm">u/s · live</span></div>
              <talos-trend id="t1" min="200" max="1100" width="640" height="170" fill></talos-trend>
              <!-- coolant loop: feedwater pumps -> core -> heat exchanger. dash
                   speed = throughput; idle segments simply don't travel. -->
              <div class="signal-flows">
                <span>FEEDWATER</span>
                <talos-flow id="f1" rate="40" max="100" warn="70" crit="90" width="150" height="30"></talos-flow>
                <span>CORE</span>
                <talos-flow id="f2" rate="40" max="100" warn="70" crit="90" width="150" height="30" curve="12"></talos-flow>
                <span>EXCHANGER</span>
              </div>
            </div>
            <div class="signal-stats">
              <div class="block-head"><span class="bt">Flux window</span><span class="bm">live · u/s</span></div>
              <div class="metric"><span class="mk">current</span><span class="mr"><span class="mbar"><i id="b-s2cur"></i></span><span class="mv" id="d-s2cur">—</span><span class="delta" id="dl-s2cur"></span></span></div>
              <div class="metric"><span class="mk">avg</span><span class="mr"><svg class="spark" id="sp-s2"></svg><span class="mv" id="d-s2avg">—</span></span></div>
              <div class="metric"><span class="mk">min</span><span class="mr"><span class="mbar"><i id="b-s2min"></i></span><span class="mv" id="d-s2min">—</span><span class="mx">low</span></span></div>
              <div class="metric"><span class="mk">peak</span><span class="mr"><span class="mbar"><i id="b-s2max"></i></span><span class="mv" id="d-s2max">—</span><span class="mx">high</span></span></div>
              <div class="metric"><span class="mk">jitter</span><span class="mr"><span class="dotmx" id="dm-s2jit"></span><span class="mv" id="d-s2jit">—</span><span class="mx">σ</span></span></div>
              <div class="metric"><span class="mk">coolant</span><span class="mr"><span class="mbar"><i id="b-s2ing"></i></span><span class="mv" id="d-s2ing">—</span><span class="mx">%</span></span></div>
              <div class="metric"><span class="mk">load</span><span class="mr"><span class="mbar"><i id="b-s2lag"></i></span><span class="mv" id="d-s2lag">—</span><span class="mx">%</span></span></div>
            </div>
          </div>
        </section>

        <!-- 3 — COMPOSED CONSOLE (zoned shell: rail · cells · aside · status) -->
        <section class="scene" data-scene>
          <span class="scene-title">03 — Composed into a console</span>
          <p class="lede" style="margin:.5rem 0 0;max-width:58ch">The same instruments compose into a real cockpit — a non-document, zoned, fixed-viewport shell. Rail, instrument cells, telemetry aside, status bar. One reactor, one screen.</p>
          <div class="cshell" style="margin-top:1.25rem">
            <div class="cshell-rail">
              <span class="crail-brand"><span class="dot"></span>CORE://TALOS-1</span>
              <span class="crail-item crail-item--on">OVERVIEW</span>
              <span class="crail-item">SUBSYSTEMS</span>
              <span class="crail-item">LOG</span>
              <span class="crail-item">CONTROL</span>
              <span class="crail-spacer"></span>
              <span class="crail-meta" id="c-uptime">—</span>
            </div>
            <div class="cshell-scope">
              <div class="ccell"><span class="ccell-t">CORE LOAD</span><talos-gauge id="cg1" value="0" warn="70" crit="90" unit="%" size="120"></talos-gauge><div class="ccell-sub"><span class="mk">load</span><svg class="spark" id="sp-cg1"></svg><span class="mv" id="d-cg1">—</span></div></div>
              <div class="ccell"><span class="ccell-t">COOLANT</span><talos-meter id="cm2" value="0" warn="70" crit="90" unit="%" width="150"></talos-meter><div class="ccell-sub"><span class="mk">load</span><span class="mbar" style="flex:1"><i id="b-cg2"></i></span><span class="mv" id="d-cg2">—</span></div></div>
              <div class="ccell"><span class="ccell-t">FLUX</span><talos-trend id="ct3" min="200" max="1100" width="170" height="84" fill></talos-trend><div class="ccell-sub"><span class="mk">u/s</span><span class="mv" id="d-cg3">—</span></div></div>
            </div>
            <div class="cshell-aside">
              <span class="caside-label">// Telemetry</span>
              <div class="metric"><span class="mk">load</span><span class="mr"><span class="mbar"><i id="b-cab"></i></span><span class="mv" id="d-cab">—</span></span></div>
              <div class="metric"><span class="mk">press</span><span class="mr"><span class="mbar"><i id="b-cad"></i></span><span class="mv" id="d-cad">—</span></span></div>
              <div class="metric"><span class="mk">link</span><span class="mr"><svg class="spark" id="sp-cart"></svg><span class="mv" id="d-cart">—</span></span></div>
              <div class="metric"><span class="mk">trips</span><span class="mr"><span class="dotmx" id="dm-cac"></span><span class="mv" id="d-cac">—</span></span></div>
              <talos-meter id="cam" value="0" warn="70" crit="90" label="Pressure" unit="%" width="180"></talos-meter>
            </div>
            <div class="cshell-status">
              <span class="cstat" id="c-st1" style="--_status:var(--talos-success-hsl)">NOMINAL</span>
              <span class="cstat-sep"></span>
              <span class="cstat-k">coolant <b id="c-st-heap">—</b></span>
              <span class="cstat-k">flux <b id="c-st-fps">—</b></span>
              <span class="cstat-k">load <b id="c-st-nodes">—</b></span>
              <span class="crail-spacer"></span>
              <span class="cstat-k">CORE://TALOS-1</span>
            </div>
          </div>
        </section>

        <!-- 4 — REACTOR SUBSYSTEM MESH (orbital + live legend, same sim data) -->
        <section class="scene" data-scene>
          <span class="scene-title">04 — Reactor subsystems</span>
          <p class="lede" style="margin:.5rem 0 0;max-width:60ch">The core's eight subsystems — pumps, rods, exchanger, turbine, containment. Node colour = pressure, orbit speed = activity, ring = tier. The mesh and the legend are one dataset, two instruments.</p>
          <div class="mesh-grid" style="margin-top:1rem">
            <div class="mesh-orb">
              <talos-orbital id="orb" rings="3" warn="50" crit="80" core-label="CORE" core-sub="CORE://TALOS-1" size="440"></talos-orbital>
            </div>
            <div class="mesh-legend">
              <div class="block-head"><span class="bt">Subsystem map</span><span class="bm">8 subsystems · 3 tiers</span></div>
              <div class="mesh-row mesh-row--head"><span>subsystem</span><span>tier</span><span>pressure</span><span>activity</span></div>
              <div class="mesh-rows" id="mesh-rows"></div>
            </div>
          </div>
        </section>

        <!-- 5 — CONTROLS (forms + live validation/telemetry panel) -->
        <section class="scene" data-scene>
          <span class="scene-title">05 — Reactor controls</span>
          <p class="lede" style="margin:.5rem 0 0;max-width:58ch">A console is operated, not just read. Inputs, validation, and toggles carry the same chamfered HUD language — set a value out of safe range and the field shows it in colour, instantly.</p>
          <div class="ctrl-grid" style="margin-top:1.5rem">
            <div class="ctrl-form">
              <div class="talos-field">
                <label class="talos-label talos-label--required">Rod insertion</label>
                <input class="talos-input" value="62%" />
                <span class="talos-field__help">Control-rod depth, 0–100%.</span>
              </div>
              <div class="talos-field talos-field--error">
                <label class="talos-label">Coolant setpoint</label>
                <input class="talos-input talos-input--error" value="940°C" />
                <span class="talos-field__error">Above containment limit (≤ 850°C).</span>
              </div>
              <label style="display:flex;gap:.6rem;align-items:center;color:var(--talos-muted-foreground)"><input type="checkbox" class="talos-checkbox" checked /> Auto-governor</label>
              <label style="display:flex;gap:.6rem;align-items:center;color:var(--talos-muted-foreground)"><input type="checkbox" class="talos-switch" checked /> SCRAM arm</label>
            </div>
            <div class="ctrl-panel">
              <div class="block-head"><span class="bt">Control telemetry</span><span class="bm">live</span></div>
              <div class="radial-rail">
                <div class="radial-wrap"><div class="radial" id="rad-valid"><span class="rv" id="rv-valid">—</span></div><span class="rl">rods</span></div>
                <div class="radial-wrap"><div class="radial" id="rad-heap"><span class="rv" id="rv-heap">—</span></div><span class="rl">coolant</span></div>
                <div class="radial-wrap"><div class="radial" id="rad-frame"><span class="rv" id="rv-frame">—</span></div><span class="rl">load</span></div>
              </div>
              <div class="metric"><span class="mk">setpts</span><span class="mr"><span class="dotmx" id="dm-fields"></span><span class="mv">3 / 4</span></span></div>
              <div class="metric"><span class="mk">faults</span><span class="mr"><span class="mv" id="d-errs" data-band="warn">1</span><span class="mx">coolant</span></span></div>
              <div style="border-top:1px solid var(--talos-edge-subtle);padding-top:.6rem;margin-top:.3rem">
                <talos-readout id="hr1" value="0" unit="u/s" label="Neutron flux" warn="900" crit="1000"></talos-readout>
                <span class="eyebrow" style="display:block;margin-top:.4rem">↞ decoding on every change</span>
              </div>
            </div>
          </div>
        </section>

        <!-- 6 — MISSION CONSOLE (maximal density, ~50 live vitals) -->
        <section class="scene" data-scene>
          <span class="scene-title">06 — Defy the default</span>
          <p class="lede" style="margin:.5rem 0 0;max-width:64ch">Not a centered column — a mission console. Every signal this tab emits, at once: render, memory, DOM, network, timing, device, power, storage. ~50 live vitals, each a value, a bar, a range. Scanned, not read.</p>

          <!-- derived stat-strip — the headline aggregates -->
          <div class="console-strip">
            <div class="strip-cell"><span class="sk">Pressure</span><span class="sv" id="st-pressure">0<small>%</small></span></div>
            <div class="strip-cell"><span class="sk">Flux avg</span><span class="sv" id="st-fpsavg">60</span></div>
            <div class="strip-cell"><span class="sk">Coolant</span><span class="sv" id="st-heap">0<small>%</small></span></div>
            <div class="strip-cell"><span class="sk">Load</span><span class="sv" id="st-dom">0</span></div>
            <div class="strip-cell"><span class="sk">Link</span><span class="sv" id="st-net">—</span></div>
            <div class="strip-cell"><span class="sk">Run</span><span class="sv" id="st-uptime">0<small>s</small></span></div>
          </div>

          <!-- dial rail + pressure core — glanceable primaries over the data -->
          <div class="console-dials">
            <div class="dwrap"><talos-gauge id="s6-frame" value="0" warn="70" crit="90" unit="%" size="96"></talos-gauge><span class="dtag">Core load</span></div>
            <div class="dwrap"><talos-gauge id="s6-dom" value="0" warn="70" crit="90" unit="%" size="96"></talos-gauge><span class="dtag">Pressure</span></div>
            <div class="dwrap"><talos-gauge id="s6-heap" value="0" warn="70" crit="90" unit="%" size="96"></talos-gauge><span class="dtag">Coolant</span></div>
            <div class="glass-panel activity-edge core-panel" id="s6-pressure" style="--talos-rate:0">
              <div class="glass-panel-content" style="padding:.7rem 1rem;display:flex;flex-direction:column;gap:.25rem;align-items:center">
                <span class="dtag">System pressure</span>
                <talos-readout id="s6-read" value="0" unit="%" warn="70" crit="90" duration="300"></talos-readout>
              </div>
            </div>
            <div class="dwrap" style="flex:1;min-width:200px"><talos-trend id="s6-fps" value="60" points="80" warn="40" crit="20" width="320" height="60" fill></talos-trend><span class="dtag">Frame rate — live (60 ceiling)</span></div>
          </div>

          <!-- the telemetry wall — 8 blocks, every row = value · bar · range -->
          <div class="console-wall">

            <div class="wall-block">
              <div class="block-head"><span class="bt">Render</span><span class="bm">rAF · paint</span></div>
              <div class="metric"><span class="mk">fps</span><span class="mr"><svg class="spark" id="sp-fps"></svg><span class="mv" id="d-fps">—</span><span class="delta" id="dl-fps"></span></span></div>
              <div class="metric"><span class="mk">frame ms</span><span class="mr"><svg class="spark" id="sp-ms"></svg><span class="mv" id="d-ms">—</span><span class="mx" id="r-ms"></span></span></div>
              <div class="metric"><span class="mk">budget</span><span class="mr"><span class="mbar"><i id="b-budget"></i></span><span class="mv" id="d-budget">—</span><span class="mx">of 16.7</span></span></div>
              <div class="metric"><span class="mk">long tasks</span><span class="mr"><span class="dotmx" id="dm-long"></span><span class="mv" id="d-long">—</span><span class="mx">≥50ms</span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">Memory</span><span class="bm">JS heap</span></div>
              <div class="metric"><span class="mk">used</span><span class="mr"><span class="mbar"><i id="b-used"></i></span><span class="mv" id="d-used">—</span><span class="mx" id="r-used"></span></span></div>
              <div class="metric"><span class="mk">total</span><span class="mr"><span class="mbar"><i id="b-total"></i></span><span class="mv" id="d-total">—</span><span class="mx">alloc</span></span></div>
              <div class="metric"><span class="mk">limit</span><span class="mr"><span class="mbar"><i id="b-limit" style="width:100%"></i></span><span class="mv" id="d-limit">—</span><span class="mx">cap</span></span></div>
              <div class="metric"><span class="mk">heap %</span><span class="mr"><svg class="spark" id="sp-heap"></svg><span class="mv" id="d-heappct">—</span><span class="delta" id="dl-heap"></span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">DOM · render</span><span class="bm">tree</span></div>
              <div class="metric"><span class="mk">nodes</span><span class="mr"><span class="mbar"><i id="b-nodes"></i></span><span class="mv" id="d-nodes">—</span><span class="delta" id="dl-nodes"></span></span></div>
              <div class="metric"><span class="mk">depth</span><span class="mr"><span class="dotmx" id="dm-depth"></span><span class="mv" id="d-depth">—</span><span class="mx">levels</span></span></div>
              <div class="metric"><span class="mk">stylesheets</span><span class="mr"><span class="dotmx" id="dm-css"></span><span class="mv" id="d-css">—</span><span class="mx">CSSOM</span></span></div>
              <div class="metric"><span class="mk">custom el</span><span class="mr"><span class="dotmx" id="dm-ce"></span><span class="mv" id="d-ce">—</span><span class="mx">defined</span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">Network</span><span class="bm" id="d-conn">—</span></div>
              <div class="metric"><span class="mk">rtt</span><span class="mr"><svg class="spark" id="sp-rtt"></svg><span class="mv" id="d-rtt">—</span><span class="delta" id="dl-rtt"></span></span></div>
              <div class="metric"><span class="mk">downlink</span><span class="mr"><span class="mbar"><i id="b-down"></i></span><span class="mv" id="d-down">—</span><span class="mx">Mb/s</span></span></div>
              <div class="metric"><span class="mk">transfer</span><span class="mr"><span class="mbar"><i id="b-xfer"></i></span><span class="mv" id="d-xfer">—</span><span class="mx">KB</span></span></div>
              <div class="metric"><span class="mk">requests</span><span class="mr"><span class="dotmx" id="dm-reqs"></span><span class="mv" id="d-reqs">—</span><span class="mx">res</span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">Timing</span><span class="bm">navigation</span></div>
              <div class="metric"><span class="mk">ttfb</span><span class="mr"><span class="mbar"><i id="b-ttfb"></i></span><span class="mv" id="d-ttfb">—</span><span class="mx">ms</span></span></div>
              <div class="metric"><span class="mk">dom int</span><span class="mr"><span class="mbar"><i id="b-domi"></i></span><span class="mv" id="d-domi">—</span><span class="mx">ms</span></span></div>
              <div class="metric"><span class="mk">dom done</span><span class="mr"><span class="mbar"><i id="b-domc"></i></span><span class="mv" id="d-domc">—</span><span class="mx">ms</span></span></div>
              <div class="metric"><span class="mk">load</span><span class="mr"><span class="mbar"><i id="b-load"></i></span><span class="mv" id="d-load">—</span><span class="mx">ms</span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">Scroll · cam</span><span class="bm">journey</span></div>
              <div class="metric"><span class="mk">scroll px</span><span class="mr"><span class="mbar"><i id="b-scroll"></i></span><span class="mv" id="d-scroll">—</span><span class="mx" id="r-scroll"></span></span></div>
              <div class="metric"><span class="mk">cam.z</span><span class="mr"><span class="mbar"><i id="b-camz"></i></span><span class="mv" id="d-camz">—</span><span class="mx">depth</span></span></div>
              <div class="metric"><span class="mk">velocity</span><span class="mr"><span class="mbar"><i id="b-vel"></i></span><span class="mv" id="d-vel">—</span><span class="mx">sc/f</span></span></div>
              <div class="metric"><span class="mk">progress</span><span class="mr"><span class="mbar"><i id="b-prog"></i></span><span class="mv" id="d-prog">—</span><span class="mx">%</span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">Device</span><span class="bm" id="d-platform">—</span></div>
              <div class="metric"><span class="mk">cores</span><span class="mr"><span class="dotmx" id="dm-cores"></span><span class="mv" id="d-cores">—</span><span class="mx">CPU</span></span></div>
              <div class="metric"><span class="mk">memory</span><span class="mr"><span class="mbar"><i id="b-devmem"></i></span><span class="mv" id="d-devmem">—</span><span class="mx">GB</span></span></div>
              <div class="metric"><span class="mk">dpr</span><span class="mr"><span class="mbar"><i id="b-dpr"></i></span><span class="mv" id="d-dpr">—</span><span class="mx">×</span></span></div>
              <div class="metric"><span class="mk">viewport</span><span class="mr"><span class="mv" id="d-vp" style="min-width:5.5rem">—</span><span class="mx">px</span></span></div>
            </div>

            <div class="wall-block">
              <div class="block-head"><span class="bt">Power · store</span><span class="bm" id="d-online">—</span></div>
              <div class="metric"><span class="mk">battery</span><span class="mr"><span class="mbar"><i id="b-batt"></i></span><span class="mv" id="d-batt">—</span><span class="mx" id="r-batt"></span></span></div>
              <div class="metric"><span class="mk">storage</span><span class="mr"><span class="mbar"><i id="b-store"></i></span><span class="mv" id="d-store">—</span><span class="mx">used</span></span></div>
              <div class="metric"><span class="mk">quota</span><span class="mr"><span class="mv" id="d-quota">—</span><span class="mx">avail</span></span></div>
              <div class="metric"><span class="mk">uptime</span><span class="mr"><span class="mv" id="d-uptime">—</span><span class="mx">s live</span></span></div>
            </div>

          </div>
        </section>

        <!-- 7 — MANIFESTO + CTA -->
        <section class="scene center" data-scene>
          <p class="quote">The interface is an <span class="accent">instrument</span>, not a document.</p>
          <div class="cta">
            <a class="primary" href="/docs/getting-started/">Get started</a>
            <a href="/docs/philosophy/">Read the manifesto</a>
            <a href="/showcase/">See every component</a>
          </div>
        </section>
      </div>
    </div>

    <div class="scroll-proxy" id="proxy"></div>

    <div class="scanlines"></div>
    <div class="vignette"></div>
    <div class="hud">
      <div class="hud-line hud-line--top"></div>
      <div class="hud-line hud-line--bottom"></div>
      <span class="bracket bracket--tl"></span>
      <span class="bracket bracket--tr"></span>
      <span class="bracket bracket--bl"></span>
      <span class="bracket bracket--br"></span>
      <div class="hud-top">
        <a class="brand" href="/"><span class="dot"></span>SYS://TALOS-UI</a>
        <nav><a href="/docs/philosophy/">Manifesto</a><a href="/showcase/">Showcase</a><a href="/docs/getting-started/">Docs</a></nav>
      </div>
      <div class="hud-bottom">
        <span id="hud-scene">SCENE 00 / 07</span>
        <span>MIT — Shelfwood ◢</span>
      </div>

      <!-- left ruler with a marker that rides scroll progress -->
      <div class="ruler"><div class="ruler__track" id="ruler-track"></div>
        <div class="ruler__marker" id="ruler-marker" style="top:0"></div>
        <div class="ruler__pct" id="ruler-pct" style="top:0">0%</div>
      </div>

      <!-- live scroll telemetry (lower-left) -->
      <div class="readouts">
        <span><span class="k">SCROLL</span> <b id="ro-scroll">0000</b> PX</span>
        <span><span class="k">CAM.Z</span> <b id="ro-z">-0000</b></span>
        <span><span class="k">VEL</span> <b id="ro-vel">0.00</b></span>
        <span><span class="k">FOV</span> <b>62°</b></span>
      </div>

      <!-- right-edge coords scrubbing with scroll -->
      <div class="coords">
        <span><span class="k">SECT</span> <b id="ro-sect">00:08</b></span>
        <span><span class="k">LAT</span> <b id="ro-lat">+00.000</b></span>
        <span><span class="k">LON</span> <b id="ro-lon">+00.000</b></span>
        <span><span class="k">SIG</span> <b id="ro-sig">NOMINAL</b></span>
      </div>

      <!-- center-bottom big scroll value -->
      <div class="hud-progress" id="progress"></div>
      <div class="scroll-cue">Scroll ▼</div>
    </div>

    <script>
      import "@j_shelfwood/talos-ui/wc";
      import Lenis from "lenis";

      const scenes = Array.from(document.querySelectorAll<HTMLElement>("[data-scene]"));
      const N = scenes.length;
      const viewport = document.querySelector<HTMLElement>(".viewport")!;
      const proxy = document.getElementById("proxy")!;
      const world = document.getElementById("world")!;
      const starfield = document.getElementById("starfield")!;
      const progress = document.getElementById("progress")!;
      const hudScene = document.getElementById("hud-scene")!;
      const cue = document.querySelector<HTMLElement>(".scroll-cue")!;

      // live HUD readout refs
      const $id = (id: string) => document.getElementById(id)!;
      const roScroll = $id("ro-scroll"), roZ = $id("ro-z"), roVel = $id("ro-vel");
      const roSect = $id("ro-sect"), roLat = $id("ro-lat"), roLon = $id("ro-lon"), roSig = $id("ro-sig");
      const rulerMarker = $id("ruler-marker"), rulerPct = $id("ruler-pct");

      const GAP = 900; // px of Z between scenes
      proxy.style.height = `${N * 100}vh`;

      // ---- MOTION FEEL (ref: Hyper Scroll) -------------------------------------
      // Every magnitude the velocity-coupled effects use, in one tunable block.
      // Tuned RESTRAINED / instrument-grade: you feel these more than you see
      // them. Raise them toward the commented "brutal" values for arcade feel.
      const FEEL = {
        fovRest: 1100,   // perspective at rest (px) — matches the CSS default
        fovWarp: 320,    // max px the FOV tightens at full velocity (brutal: 600)
        fovVelK: 9,      // velocity→FOV gain
        tiltVelMax: 2.2, // deg the world dives forward under accel (brutal: 6)
        tiltMouseMax: 2, // deg the world leans toward the cursor (brutal: 5)
        starStretch: 6,  // max Z-scale on stars at speed (brutal: 10)
        starVelK: 1.3,   // velocity→star-stretch gain
        ghostMax: 1.6,   // max px of accent-ghost offset on scenes (brutal: 4)
        ghostVelK: 1.1,  // velocity→ghost gain
        velGate: 0.18,   // below this smoothed velocity, effects are suppressed
        velSmooth: 0.1,  // how fast the effect-velocity eases toward the camera's
      };
      const STAR_COUNT = 120;
      const STAR_SPREAD = 2600; // px box the stars fill in X/Y around the axis

      // mouse parallax target (-1..1), eased in the loop so the lean is buttery
      const mouse = { x: 0, y: 0, ex: 0, ey: 0 };
      addEventListener("pointermove", (e) => {
        mouse.x = (e.clientX / innerWidth - 0.5) * 2;
        mouse.y = (e.clientY / innerHeight - 0.5) * 2;
      }, { passive: true });

      // Real particle starfield — divs at random Z across the scene stack, each
      // Z-stretched under velocity for warp-streaks. Depth alpha keeps far stars
      // faint so they read as a field, not confetti.
      const stars = Array.from({ length: STAR_COUNT }, () => {
        const el = document.createElement("div");
        el.className = "star";
        starfield.appendChild(el);
        return {
          el,
          x: (Math.random() - 0.5) * STAR_SPREAD,
          y: (Math.random() - 0.5) * STAR_SPREAD,
          baseZ: -Math.random() * (N * GAP + GAP), // span the whole journey + 1
        };
      });
      const STAR_LOOP = N * GAP + GAP; // wrap span so stars recycle as you fly

      // build ruler ticks (every 5%, major every 25%)
      const rulerTrack = $id("ruler-track");
      let rt = "";
      for (let i = 0; i <= 20; i++) {
        const major = i % 5 === 0;
        rt += `<div class="ruler__tick${major ? " ruler__tick--major" : ""}" style="top:${i * 5}%"></div>`;
      }
      rulerTrack.innerHTML = rt;

      progress.innerHTML = scenes.map(() => "<span></span>").join("");
      const ticks = Array.from(progress.children) as HTMLElement[];
      hudScene.textContent = `SCENE 00 / ${String(N - 1).padStart(2, "0")}`;

      // place scenes at increasing depth
      scenes.forEach((s, i) => { s.dataset.z = String(-i * GAP); });

      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
      const clampN = (v: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, v));
      let target = 0, current = 0;
      let effVel = 0; // smoothed, decoupled velocity that drives the feel effects

      const lenis = new Lenis({ duration: 1.15, smoothWheel: true });
      // Read progress from the instance in the rAF loop (the scroll-event payload
      // shape varies across Lenis versions; lenis.scroll / lenis.limit are stable).

      // click a progress tick to jump
      ticks.forEach((t, i) => t.addEventListener("click", () => {
        const limit = (document.documentElement.scrollHeight - window.innerHeight);
        lenis.scrollTo((i / (N - 1)) * limit);
      }));

      function frame(time: number) {
        lenis.raf(time);
        const limit = (lenis as any).limit || (document.documentElement.scrollHeight - window.innerHeight);
        const scroll = (lenis as any).scroll ?? window.scrollY;
        target = limit > 0 ? (scroll / limit) * (N - 1) : 0;
        current = reduce ? target : lerp(current, target, 0.085);
        const camZ = current * GAP; // move camera into the scene stack

        // ---- velocity-coupled FEEL (ref: Hyper Scroll) -----------------------
        // One eased, gated velocity drives FOV warp, world tilt, star-stretch and
        // the accent ghost. Decoupled from the position lerp so the FEEL has its
        // own (softer) inertia — the camera can settle while the warp lingers a
        // frame, which is exactly what reads as "weight". reduce → all zero.
        const rawVel = Math.abs(target - current);            // scenes/frame-ish
        effVel = reduce ? 0 : effVel + (rawVel - effVel) * FEEL.velSmooth;
        // gate: ignore micro-jitter at rest so the frame is dead-still when idle
        const fv = Math.max(0, effVel - FEEL.velGate);
        // FOV warp — perspective tightens toward the axis under speed → pull.
        const fov = FEEL.fovRest - Math.min(fv * FEEL.fovVelK * 100, FEEL.fovWarp);
        viewport.style.setProperty("--cam-fov", fov.toFixed(0) + "px");
        // World tilt — velocity dive (pitch forward) + eased mouse lean. The
        // mouse ease keeps the parallax buttery instead of snapping per-event.
        mouse.ex = reduce ? 0 : lerp(mouse.ex, mouse.x, 0.06);
        mouse.ey = reduce ? 0 : lerp(mouse.ey, mouse.y, 0.06);
        const dive   = -clampN(fv * 4, 0, FEEL.tiltVelMax);          // pitch into motion
        const leanX  =  mouse.ey * FEEL.tiltMouseMax + dive;         // rotateX
        const leanY  =  mouse.ex * FEEL.tiltMouseMax;                // rotateY
        world.style.transform = `rotateX(${leanX.toFixed(2)}deg) rotateY(${leanY.toFixed(2)}deg)`;
        // Accent ghost px for the scenes (consumed via --ghost in CSS filter).
        const ghost = Math.min(fv * FEEL.ghostVelK, FEEL.ghostMax);

        scenes.forEach((s, i) => {
          const z = -i * GAP + camZ;        // this scene's Z relative to camera
          const dist = Math.abs(z) / GAP;    // 0 = at camera plane
          // hide far scenes for perf + clarity
          const visible = dist < 1.05;
          s.dataset.hidden = visible ? "0" : "1";
          if (!visible) { s.style.opacity = "0"; return; }
          // Smoothstep fade reaching ~0 exactly at the neighbour (dist 1): the
          // active scene stays dominant (no static ghosting at rest) while the
          // incoming scene rises as the outgoing falls (no dead black gaps in
          // the transition). Scenes that have passed the camera (z>0) drop fast.
          const t = Math.min(1, dist);
          const smooth = t * t * (3 - 2 * t);        // smoothstep 0..1
          let opacity = 1 - smooth;
          if (z > 0) opacity *= Math.max(0, 1 - z / 220); // crossing the lens → out
          s.style.transform = `translate(-50%, -50%) translateZ(${z.toFixed(0)}px)`;
          s.style.opacity = String(Math.max(0, opacity).toFixed(3));
          s.style.pointerEvents = dist < 0.4 ? "auto" : "none";
          // Accent ghost: strongest on the scene at the camera plane, fading with
          // distance so background scenes don't smear. Off entirely at rest.
          (s as HTMLElement).style.setProperty("--ghost", (ghost * (1 - t)).toFixed(2) + "px");
        });

        // Real starfield: fly each star toward the camera in Z, wrap it when it
        // passes, fade by depth, and stretch it along Z under velocity → the
        // warp-streak. translate3d(x,y,z) scale(1,1,stretch) — the scale only
        // elongates the dot along its travel axis, so stillness = points, speed
        // = streaks (motion is the signal, exactly the page's thesis).
        const stretch = 1 + Math.min(fv * FEEL.starVelK, FEEL.starStretch - 1);
        for (const st of stars) {
          // z relative to camera; wrap into a band ahead of the lens so the
          // field is infinite as you fly. Stars live behind the camera plane.
          let z = st.baseZ + camZ;
          z = ((z % STAR_LOOP) + STAR_LOOP) % STAR_LOOP; // 0..LOOP
          if (z > GAP) z -= STAR_LOOP;                    // pull the near band behind the lens
          // depth alpha — faint far, brighter as it approaches, gone past the lens
          const a = z > 0 ? 0 : clampN(1 + z / (STAR_LOOP * 0.6), 0, 1) * 0.7;
          st.el.style.opacity = a.toFixed(2);
          if (a <= 0) continue;
          st.el.style.transform =
            `translate3d(${st.x}px, ${st.y}px, ${z.toFixed(0)}px) scale3d(1, 1, ${stretch.toFixed(2)})`;
        }

        const active = Math.max(0, Math.min(N - 1, Math.round(current)));
        ticks.forEach((t, i) => t.classList.toggle("active", i === active));
        hudScene.textContent = `SCENE ${String(active).padStart(2, "0")} / ${String(N - 1).padStart(2, "0")}`;
        cue.style.opacity = current > 0.3 ? "0" : "";

        // ---- live HUD telemetry (all bound to real scroll state) ----
        const pct = (N > 1 ? current / (N - 1) : 0);
        const pctR = Math.round(pct * 100);
        const vel = Math.abs(target - current);                 // camera velocity (scenes/frame-ish)
        (window as any).__talosVel = vel;                       // expose to the self-instrument data loop
        roScroll.textContent = String(Math.round(scroll)).padStart(4, "0");
        roZ.textContent = (camZ >= 0 ? "-" : "+") + String(Math.round(camZ)).padStart(4, "0");
        roVel.textContent = vel.toFixed(2);
        roSect.textContent = `${String(active).padStart(2, "0")}:${String(N).padStart(2, "0")}`;
        // synthetic but deterministic "coordinates" derived from camera depth —
        // they scrub continuously with scroll so the frame reads as a live instrument
        roLat.textContent = (pct * 90 - 45 >= 0 ? "+" : "") + (pct * 90 - 45).toFixed(3);
        roLon.textContent = (current * 23.7 % 180 - 90 >= 0 ? "+" : "") + (current * 23.7 % 180 - 90).toFixed(3);
        roSig.textContent = vel > 0.25 ? "TRACKING" : "NOMINAL";
        roSig.style.color = vel > 0.25 ? "var(--talos-accent)" : "";
        rulerMarker.style.top = (pct * 100).toFixed(1) + "%";
        rulerPct.style.top = (pct * 100).toFixed(1) + "%";
        rulerPct.textContent = pctR + "%";

        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);

      // ======================================================================
      // SELF-INSTRUMENT — the running system this page visualises is ITSELF.
      // Every instrument below binds to a REAL runtime signal of this very tab.
      // No simulation, no Math.sin: the numbers are this page's own vitals, so
      // "interfaces that visualise a running system" is literal, not a metaphor.
      // Where a browser doesn't expose a signal (e.g. performance.memory outside
      // Chromium), the instrument degrades honestly and is labelled UNAVAIL —
      // never faked. (See the same honesty rule the instruments enforce.)
      // ======================================================================
      const $ = (id: string) => document.getElementById(id);
      const clamp = (v: number, hi = 100) => Math.max(0, Math.min(hi, v));
      const r2 = (v: number) => Math.round(v);

      // ---- real signal sources ----
      const perfMem = (performance as any).memory; // Chromium only
      const memSupported = !!perfMem;

      // Frame rate: sampled from the rAF clock as a rolling average. This IS the
      // render throughput of the page — the realest "is the system keeping up?".
      let fps = 60, frameMs = 16.7, lastFrameT = performance.now();
      // Event-loop lag: long tasks (>50ms) block the main thread. PerformanceObserver
      // reports them; we decay the reading so a stall spikes then recovers — exactly
      // how a real load indicator behaves.
      let loopLagMs = 0, longTaskCount = 0;
      if ("PerformanceObserver" in window) {
        try {
          new PerformanceObserver((list) => {
            for (const e of list.getEntries()) { loopLagMs = Math.max(loopLagMs, e.duration); longTaskCount++; }
          }).observe({ entryTypes: ["longtask"] });
        } catch { /* longtask unsupported — loopLag stays 0, honest */ }
      }
      // Scroll velocity is already computed in the camera loop; expose it.
      // (window as any).__talosVel is written by frame() each tick.
      const vel = () => (window as any).__talosVel ?? 0;

      // Sample the per-frame FPS off a dedicated rAF so it reflects true paint
      // cadence independent of the camera loop's own work.
      (function sampleFps(t: number) {
        const dt = t - lastFrameT; lastFrameT = t;
        if (dt > 0) { const inst = 1000 / dt; fps = fps * 0.9 + inst * 0.1; frameMs = frameMs * 0.9 + dt * 0.1; }
        requestAnimationFrame(sampleFps);
      })(performance.now());

      // rolling windows + peaks for the console's min/max/avg readouts
      const fpsHist: number[] = [];
      let usedPeak = 0;
      let coolPeak = 0; // reactor coolant-load peak (sim)
      const fluxHist: number[] = []; // neutron-flux window for Scene 02 stats

      // ---- DIVERSE-VIZ helper layer (sparkline/dot-matrix/radial/delta) -----
      // Per-metric history buffers feed sparklines + deltas; renderers paint
      // into pre-built elements by id. Shared across every scene.
      const hist: Record<string, number[]> = {};
      const prev: Record<string, number> = {};
      const pushHist = (key: string, v: number, cap = 32) => {
        (hist[key] ||= []).push(v); if (hist[key].length > cap) hist[key].shift();
      };
      // Sparkline: build an SVG polyline (0..100 domain over the buffer width).
      function spark(id: string, key: string, band?: "warn" | "crit", domainMax = 100) {
        const el = document.getElementById(id); if (!el) return;
        const h = hist[key] || []; if (h.length < 2) return;
        const w = 100, ht = 14, n = h.length;
        const pts = h.map((v, i) => `${((i / (n - 1)) * w).toFixed(1)},${(ht - clamp((v / domainMax) * 100) / 100 * ht).toFixed(1)}`).join(" ");
        const fillPts = `0,${ht} ${pts} ${w},${ht}`;
        el.setAttribute("viewBox", `0 0 ${w} ${ht}`); el.setAttribute("preserveAspectRatio", "none");
        if (band) el.setAttribute("data-band", band); else el.removeAttribute("data-band");
        el.innerHTML = `<polygon class="sparkfill" points="${fillPts}"/><polyline points="${pts}"/>`;
      }
      // Dot-matrix: fill `on` of `total` dots.
      function dotmx(id: string, on: number, total: number, band?: "warn" | "crit") {
        const el = document.getElementById(id); if (!el) return;
        const o = Math.max(0, Math.min(total, Math.round(on)));
        if (el.childElementCount !== total) el.innerHTML = Array.from({ length: total }, () => "<i></i>").join("");
        [...el.children].forEach((c, i) => c.classList.toggle("on", i < o));
        if (band) el.setAttribute("data-band", band); else el.removeAttribute("data-band");
      }
      // Radial micro-gauge: set --p (0..100) + center text + band.
      function radial(id: string, pct: number, band?: "warn" | "crit", text?: string) {
        const el = document.getElementById(id); if (!el) return;
        (el as HTMLElement).style.setProperty("--p", String(r2(clamp(pct))));
        if (band) el.setAttribute("data-band", band); else el.removeAttribute("data-band");
        if (text != null) { const rv = el.querySelector(".rv"); if (rv) rv.textContent = text; }
      }
      // Delta: arrow + magnitude vs previous tick.
      function delta(id: string, key: string, cur: number, fmt = (n: number) => String(Math.round(n))) {
        const el = document.getElementById(id); if (!el) return;
        const p = prev[key]; prev[key] = cur;
        if (p == null) { el.className = "delta delta--flat"; el.textContent = "0"; return; }
        const d = cur - p, eps = Math.abs(cur) * 0.005 + 0.01;
        el.className = "delta " + (d > eps ? "delta--up" : d < -eps ? "delta--down" : "delta--flat");
        el.textContent = fmt(Math.abs(d));
      }

      // ---- boot-once STATIC vitals (measured once, they don't change) ----
      function paintStatics() {
        const setV = (id: string, text: string, fillPct?: number) => {
          const v = $("d-" + id); if (v) v.textContent = text;
          const b = $("b-" + id); if (b && fillPct != null) (b as HTMLElement).style.width = clamp(fillPct) + "%";
        };
        const nav = performance.getEntriesByType("navigation")[0] as any || {};
        const res = performance.getEntriesByType("resource");
        // DOM structure
        let depth = 0; document.querySelectorAll("*").forEach((e) => { let d = 0, n: Element | null = e; while (n) { d++; n = n.parentElement; } depth = Math.max(depth, d); });
        setV("depth", String(depth)); dotmx("dm-depth", depth, 16, depth > 14 ? "warn" : undefined);
        const dmEl = $("d-m1d"); if (dmEl) dmEl.textContent = String(depth); dotmx("dm-m1d", depth, 16, depth>14?"warn":undefined);
        setV("css", String(document.styleSheets.length)); dotmx("dm-css", document.styleSheets.length, 10);
        const cmEl = $("d-m1c"); if (cmEl) cmEl.textContent = String(document.styleSheets.length); dotmx("dm-m1c", document.styleSheets.length, 10);
        const ce = ["talos-gauge","talos-trend","talos-meter","talos-flow","talos-orbital","talos-readout","talos-panel","talos-sheen"].filter((t) => customElements.get(t)).length;
        setV("ce", String(ce)); dotmx("dm-ce", ce, 8);
        // NETWORK static-ish
        setV("xfer", String(Math.round((nav.transferSize || 0) / 1024)), Math.min((nav.transferSize || 0) / 1024 / 5, 100));
        setV("reqs", String(res.length)); dotmx("dm-reqs", Math.round(res.length / 6), 8);
        // TIMING (navigation)
        setV("ttfb", String(Math.round((nav.responseStart || 0) - (nav.requestStart || 0))), Math.min((nav.responseStart - nav.requestStart) / 5, 100));
        setV("domi", String(Math.round(nav.domInteractive || 0)), Math.min((nav.domInteractive || 0) / 2, 100));
        setV("domc", String(Math.round(nav.domComplete || 0)), Math.min((nav.domComplete || 0) / 2, 100));
        setV("load", String(Math.round(nav.loadEventEnd || nav.domComplete || 0)), Math.min((nav.loadEventEnd || 0) / 2, 100));
        // DEVICE
        setV("cores", String(navigator.hardwareConcurrency || "—")); dotmx("dm-cores", navigator.hardwareConcurrency || 0, 16);
        setV("devmem", String((navigator as any).deviceMemory ?? "—"), (((navigator as any).deviceMemory || 0) / 32) * 100);
        setV("dpr", devicePixelRatio.toFixed(1), (devicePixelRatio / 3) * 100);
        const vp = $("d-vp"); if (vp) vp.textContent = `${innerWidth}×${innerHeight}`;
        const plat = $("d-platform"); if (plat) plat.textContent = (navigator as any).platform || "—";
        const onl = $("d-online"); if (onl) onl.textContent = navigator.onLine ? "online" : "offline";
        const conn = (navigator as any).connection; const cEl = $("d-conn"); if (cEl) cEl.textContent = conn?.effectiveType ?? "—";
      }
      // statics need the layout present; run after first paint + on resize for viewport
      setTimeout(paintStatics, 60);
      addEventListener("resize", () => { const vp = $("d-vp"); if (vp) vp.textContent = `${innerWidth}×${innerHeight}`; });

      // ---- async APIs: BATTERY + STORAGE (real, permissionless) ----
      if ("getBattery" in navigator) {
        (navigator as any).getBattery().then((bat: any) => {
          const paintBat = () => {
            const pct = Math.round(bat.level * 100);
            const v = $("d-batt"); if (v) v.textContent = pct + "%";
            const b = $("b-batt"); if (b) (b as HTMLElement).style.width = pct + "%";
            const r = $("r-batt"); if (r) r.textContent = bat.charging ? "charging" : "on batt";
          };
          paintBat(); bat.addEventListener("levelchange", paintBat); bat.addEventListener("chargingchange", paintBat);
        }).catch(() => {});
      } else { const v = $("d-batt"); if (v) v.textContent = "n/a"; }
      if (navigator.storage?.estimate) {
        navigator.storage.estimate().then((est) => {
          const usedMB = ((est.usage || 0) / 1048576).toFixed(1);
          const quotaMB = ((est.quota || 0) / 1048576 / 1024).toFixed(1);
          const v = $("d-store"); if (v) v.textContent = usedMB + "MB";
          const q = $("d-quota"); if (q) q.textContent = quotaMB + "GB";
          const b = $("b-store"); if (b && est.quota) (b as HTMLElement).style.width = clamp(((est.usage || 0) / est.quota) * 100) + "%";
        }).catch(() => {});
      }

      // ---- the real subsystems behind the orbital "service mesh" ----
      // Each node is an actual runtime subsystem of this tab; its activity is the
      // genuine pressure on that subsystem right now.
      const orb = $("orb") as any;

      // Trend ring-buffer is fed real FPS each tick (the shape IS the frame rate).
      let domCount = document.querySelectorAll("*").length;
      // DOM count changes rarely; refresh it occasionally rather than every tick.
      let domTick = 0;

      function heapPct(): number {
        if (!memSupported) return 0;
        // Against the CURRENTLY-ALLOCATED heap (totalJSHeapSize), not the 4GB
        // hard cap — used/limit is always ~0% and dead. used/total is the real
        // "how full is the heap we've been given", and it actually moves as the
        // page allocates and the GC reclaims.
        const denom = perfMem.totalJSHeapSize || perfMem.jsHeapSizeLimit;
        return clamp((perfMem.usedJSHeapSize / denom) * 100);
      }
      function heapMB(): number {
        return memSupported ? perfMem.usedJSHeapSize / 1048576 : 0;
      }

      // ---- REACTOR SIMULATION ------------------------------------------------
      // The hero depicts a reactor, and the reactor is a real (if fictional)
      // running system — a small deterministic model with genuine feedback, so
      // the instruments actually MOVE and the bands trip for real. This is the
      // honest answer to "an idle tab flatlines": we visualise a system that is
      // genuinely doing something. Labelled SIM in the UI; nothing here pretends
      // to be live tab telemetry.
      //
      // Model: demand drives core LOAD; load heats the core; coolant DRAINS while
      // hot and recovers while cool; PRESSURE rises with heat and falls as coolant
      // works; a rare TRANSIENT spikes demand toward a SCRAM threshold. Subsystems
      // (pumps/rods/exchanger/…) carry their own derived load + activity.
      const reactor = {
        t: 0,
        load: 28,        // % of core budget in use
        coolant: 18,     // % thermal load on the coolant loop (low = cool)
        pressure: 30,    // aggregate stress
        flux: 540,       // neutron flux, u/s
        demand: 28,      // target load the governor chases
        transient: 0,    // decays; injects extra demand
      };
      const SUB = [
        { id: "pump-a",   label: "PUMP-A",     ring: 1, base: 0.30 },
        { id: "pump-b",   label: "PUMP-B",     ring: 1, base: 0.28 },
        { id: "rods",     label: "ROD-BANK",   ring: 2, base: 0.55 },
        { id: "exch",     label: "EXCHANGER",  ring: 2, base: 0.62 },
        { id: "turbine",  label: "TURBINE",    ring: 3, base: 0.70 },
        { id: "feedwtr",  label: "FEEDWATER",  ring: 3, base: 0.40 },
        { id: "contain",  label: "CONTAINMENT",ring: 3, base: 0.20 },
        { id: "aux",      label: "AUX-BUS",    ring: 2, base: 0.33 },
      ];
      function tickReactor(): void {
        const r = reactor;
        r.t += 1;
        // Demand: slow sine baseline + periodic load steps + decaying transients.
        const baseline = 34 + 18 * Math.sin(r.t / 22) + 8 * Math.sin(r.t / 7);
        if (r.t % 47 === 0) r.demand = 40 + Math.random() * 45;       // load event
        if (r.t % 130 === 0) r.transient = 55 + Math.random() * 30;   // rare transient
        r.transient *= 0.86;                                          // transients decay
        const target = clamp(Math.max(baseline, r.demand) + r.transient);
        r.load += (target - r.load) * 0.14;                           // governor chases demand
        // Coolant heats when load is high, recovers when low (the feedback loop).
        const heatIn = Math.max(0, r.load - 55) * 0.10;
        const cool = Math.max(0, 45 - r.load) * 0.04 + 0.6;
        r.coolant = clamp(r.coolant + heatIn - cool);
        // Pressure: worst of load and coolant heat, eased (the aggregate stress).
        const pTarget = Math.max(r.load * 0.9, r.coolant * 1.05);
        r.pressure += (pTarget - r.pressure) * 0.2;
        // Flux tracks load with a little noise (neutron economy).
        r.flux = 200 + r.load * 9 + (Math.random() - 0.5) * 40;
      }

      setInterval(() => {
        // ---- Advance the reactor sim, then map its state onto the foundational
        //      signal names every scene reads. (Same variable names as before so
        //      the per-scene blocks below are unchanged — only the SOURCE moved
        //      from flatlining idle-tab metrics to the live reactor model.) ----
        tickReactor();
        const frameBudget = r2(reactor.load);          // CORE LOAD
        const heap = r2(reactor.coolant);              // COOLANT thermal load
        const pressure = r2(reactor.pressure);         // aggregate reactor pressure
        const fluxV = Math.round(reactor.flux);        // neutron flux u/s

        if (++domTick % 8 === 0) domCount = document.querySelectorAll("*").length;
        const domLoad = r2(reactor.pressure);          // containment ~ tracks pressure

        // fps history still feeds Scene 02's trend stats (real paint cadence).
        fpsHist.push(fps); if (fpsHist.length > 60) fpsHist.shift();
        const fpsMin = Math.round(Math.min(...fpsHist)), fpsMax = Math.round(Math.max(...fpsHist));
        const fpsAvg = Math.round(fpsHist.reduce((a, b) => a + b, 0) / fpsHist.length);
        if (memSupported) usedPeak = Math.max(usedPeak, perfMem.usedJSHeapSize);
        const scrollRate = fluxV;                       // flux drives the throughput readouts
        const lagRate = r2(clamp(reactor.coolant * 1.1)); // coolant-loop work
        const conn = (navigator as any).connection || {};
        const rtt = conn.rtt ?? 0;
        const camZ = current * GAP;
        const scrollPx = Math.round((lenis as any).scroll ?? window.scrollY);
        const progPct = r2((scrollPx / Math.max(1, document.documentElement.scrollHeight - innerHeight)) * 100);

        // ---- Scene 01: CORE CONSOLE — one zoned reactor panel, all real tab
        // telemetry reframed. CORE LOAD = frame budget (trend). COOLANT = heap %
        // (meter). CONTAINMENT = DOM count (number). FLUX = camera velocity,
        // LINK = connection RTT. Aggregate `pressure` drives the core STATE +
        // the panel's own activity-edge mood (philosophy #5: the system shows it).
        {
          const setBand = (el: Element | null, b?: string) => {
            if (!el) return; if (b) el.setAttribute("data-band", b); else el.removeAttribute("data-band");
          };

          // PRIMARY — core LOAD trend (its own readout shows the number; no
          // duplicate overlay). The sim gives the line real shape now.
          ($("t-frame") as any)?.push(frameBudget);
          const loadBand = frameBudget >= 90 ? "crit" : frameBudget >= 70 ? "warn" : undefined;
          const loadEl = $("d-coreload");
          if (loadEl) { loadEl.textContent = String(Math.round(frameBudget)); setBand(loadEl, loadBand); }
          // FLUX — neutron flux (u/s) from the sim; STALLS — coolant-pump trips;
          // LINK — real connection RTT (the one genuinely-live garnish).
          $("d-flux")!.textContent = fluxV.toLocaleString();
          const linkEl = $("d-rtt01"); if (linkEl) { linkEl.textContent = rtt ? String(rtt) : "—";
            setBand(linkEl, rtt > 300 ? "crit" : rtt > 150 ? "warn" : undefined); }
          const trips = reactor.coolant > 80 ? 2 : reactor.coolant > 60 ? 1 : 0;
          dotmx("dm-g1long", trips, 8, trips>0?"warn":undefined);
          $("d-g1long")!.textContent = String(trips);

          // SECONDARY — COOLANT meter (sim thermal load; high = bad). USED/CAP/PEAK
          // expressed as coolant-loop figures derived from the sim.
          $("mt-heap")?.setAttribute("value", String(heap));
          $("d-g2used")!.textContent = (reactor.coolant * 1.8 + 12).toFixed(0);
          $("d-g2tot")!.textContent = "200";
          coolPeak = Math.max(coolPeak, reactor.coolant);
          $("d-g2pk")!.textContent = (coolPeak * 1.8 + 12).toFixed(0) + " u";

          // CONTAINMENT — node count drifts with pressure (integrity load). The
          // count is the headline; spark = drift, delta = direction.
          const contain = Math.round(1200 + reactor.pressure * 14);
          pushHist("nodes", contain, 32);
          $("d-m1n")!.textContent = contain.toLocaleString();
          spark("sp-m1n", "nodes", undefined, 1200 + 100 * 14);
          delta("dl-m1", "m1nodes", contain);

          // HEADER STATE + FOOTER AGGREGATE + PANEL MOOD — all from `pressure`,
          // the worst of {core load, coolant, containment load}. One signal, the
          // whole console responds: state word, dot, pressure bar, and the edge.
          const aggBand = pressure >= 90 ? "crit" : pressure >= 70 ? "warn" : undefined;
          const stateEl = $("rcon-state");
          if (stateEl) { stateEl.textContent = aggBand === "crit" ? "CRITICAL" : aggBand === "warn" ? "ELEVATED" : "NOMINAL";
            setBand(stateEl, aggBand); }
          const dotEl = $("rcon-dot");
          if (dotEl) (dotEl as HTMLElement).style.background = aggBand === "crit" ? "var(--talos-danger)"
            : aggBand === "warn" ? "var(--talos-warning)" : "var(--talos-accent)";
          const pbar = $("rcon-pbar");
          if (pbar) { (pbar as HTMLElement).style.width = clamp(pressure)+"%";
            (pbar as HTMLElement).style.background = aggBand === "crit" ? "var(--talos-danger)"
              : aggBand === "warn" ? "var(--talos-warning)" : "var(--talos-accent)"; }
          $("rcon-pval")!.textContent = Math.round(pressure)+"%";
          const note = $("rcon-note");
          if (note) note.textContent = aggBand === "crit"
            ? "core load exceeding safe budget — frames dropping"
            : aggBand === "warn" ? "one subsystem elevated — under load"
            : "all subsystems nominal — push the page to load the core";
          // The panel's edge haloes at the aggregate rate. activity-edge expects
          // --talos-rate ~0..1 (period/rate = revolution time); pressure is a
          // 0..100 %, so SCALE to 0..1 and CAP — feeding raw 0..100 made the
          // ring spin ~18×/s (a strobe / photosensitivity hazard). Cap at 0.5
          // (≥8s/rev) so it reads as a slow, calm halo even at full pressure.
          $("rcon")?.style.setProperty("--talos-rate", String(Math.min(0.5, pressure / 200)));
          // RUN clock — real uptime since page load, mm:ss.
          const up = Math.floor(performance.now()/1000);
          $("rcon-clock")!.textContent = `${String(Math.floor(up/60)).padStart(2,"0")}:${String(up%60).padStart(2,"0")}`;
        }

        // ---- Scene 02: FLUX & COOLANT LOOP ----
        // Trend = neutron flux (u/s) from the sim — a real moving shape, scaled
        // 200..1100 so it reads as flux, not a pinned percentage. The flux window
        // stats are ALL computed from one coherent flux history (no contradictory
        // min>current nonsense), and the flows carry coolant throughput.
        ($("t1") as any)?.push(fluxV);
        fluxHist.push(fluxV); if (fluxHist.length > 48) fluxHist.shift();
        {
          const setRow = (id: string, txt: string, fill?: number, bnd?: "warn"|"crit") => {
            const v = $("d-" + id); if (v) { v.textContent = txt; bnd?v.setAttribute("data-band",bnd):v.removeAttribute("data-band"); }
            const b = $("b-" + id); if (b && fill != null) (b as HTMLElement).style.width = clamp(fill) + "%";
          };
          const fMin = Math.round(Math.min(...fluxHist)), fMax = Math.round(Math.max(...fluxHist));
          const fAvg = Math.round(fluxHist.reduce((a, b) => a + b, 0) / fluxHist.length);
          // % of the flux scale (200..1100) for the bar fills — a real common scale.
          const pct = (v: number) => clamp(((v - 200) / 900) * 100);
          const loadBnd = reactor.load >= 90 ? "crit" : reactor.load >= 70 ? "warn" : undefined;
          setRow("s2cur", fluxV.toLocaleString(), pct(fluxV), loadBnd); delta("dl-s2cur", "s2cur", fluxV);
          setRow("s2avg", fAvg.toLocaleString()); pushHist("s2", pct(fluxV)); spark("sp-s2", "s2", loadBnd, 100);
          setRow("s2min", fMin.toLocaleString(), pct(fMin));
          setRow("s2max", fMax.toLocaleString(), pct(fMax));
          const jit = fluxHist.length > 1 ? Math.round(Math.sqrt(fluxHist.reduce((a, b) => a + (b - fAvg) ** 2, 0) / fluxHist.length)) : 0;
          setRow("s2jit", String(jit)); dotmx("dm-s2jit", Math.round(jit / 20), 8, jit > 120 ? "warn" : undefined);
          setRow("s2ing", Math.round(reactor.coolant) + "", reactor.coolant, reactor.coolant > 70 ? "warn" : undefined);
          setRow("s2lag", Math.round(reactor.load) + "", reactor.load, loadBnd);
        }
        // Coolant loop flows: feedwater throughput (= demand met) and core→exchanger
        // transfer (= heat being moved). Both bound to live sim rates.
        $("f1")?.setAttribute("rate", String(r2(clamp(reactor.load))));
        $("f2")?.setAttribute("rate", String(r2(clamp(reactor.coolant + 25))));

        // ---- Scene 03: composed console — the zoned reactor cockpit shell.
        // Three cells of DIFFERENT instruments (load gauge · coolant meter ·
        // flux trend), an aside, and a status bar — all on the sim. The point of
        // this scene is COMPOSITION (non-document zoned shell), so it reuses the
        // core readings rather than introducing new ones. ----
        {
          const setT = (id: string, txt: string) => { const e = $(id); if (e) e.textContent = txt; };
          const setB = (id: string, fill: number) => { const e = $(id); if (e) (e as HTMLElement).style.width = clamp(fill) + "%"; };
          $("cg1")?.setAttribute("value", String(frameBudget));            // CORE LOAD gauge
          $("cm2")?.setAttribute("value", String(heap));                  // COOLANT meter
          ($("ct3") as any)?.push(fluxV);                                 // FLUX trend
          setT("d-cg1", Math.round(frameBudget) + "%"); spark("sp-cg1", "s2", undefined, 100);
          setT("d-cg2", Math.round(heap) + "%"); setB("b-cg2", heap);
          setT("d-cg3", fluxV.toLocaleString());
          // aside telemetry
          setT("d-cab", Math.round(frameBudget) + "%"); setB("b-cab", frameBudget);
          setT("d-cad", Math.round(reactor.pressure) + "%"); setB("b-cad", reactor.pressure);
          setT("d-cart", String(rtt)); spark("sp-cart", "rtt", band(rtt,150,300), 300);
          const subTrips = reactor.pressure > 70 ? 3 : reactor.pressure > 50 ? 2 : 1;
          setT("d-cac", String(subTrips) + "/8"); dotmx("dm-cac", subTrips, 8, subTrips>5?"warn":undefined);
          $("cam")?.setAttribute("value", String(pressure));
          // status bar — reactor figures
          setT("c-uptime", `↑ ${Math.floor(performance.now()/1000)}s`);
          setT("c-st-heap", Math.round(heap) + "%");
          setT("c-st-fps", fluxV.toLocaleString());
          setT("c-st-nodes", Math.round(frameBudget) + "%");
          const st1 = $("c-st1");
          if (st1) { const sev = pressure >= 90 ? ["SCRAM","--talos-danger-hsl"] : pressure >= 70 ? ["ELEVATED","--talos-warning-hsl"] : ["NOMINAL","--talos-success-hsl"];
            st1.textContent = sev[0]; (st1 as HTMLElement).style.setProperty("--_status", `var(${sev[1]})`); }
        }

        // ---- Scene 05: reactor controls — readout + control-telemetry radials ----
        // Flux readout (scramble-decodes on change); radials = rods/coolant/load
        // from the sim. The one form error (coolant setpoint over limit) is static.
        $("hr1")?.setAttribute("value", fluxV.toLocaleString());
        const rods = r2(clamp(62 + (reactor.load - 50) * 0.4));     // governor trims rods to load
        radial("rad-valid", rods, undefined, rods + "%");
        radial("rad-heap", heap, band(heap,70,90), Math.round(heap) + "%");
        radial("rad-frame", frameBudget, band(frameBudget,70,90), Math.round(frameBudget) + "%");
        dotmx("dm-fields", 3, 4, "warn");

        // ============ Scene 06: MISSION CONSOLE — ~50 live vitals ============
        // Primary dials = the reactor's three headline vitals (load/pressure/
        // coolant) from the sim; the dense rows below mix sim figures with a few
        // honest live-tab garnish signals — "every signal at once" is the point.
        $("s6-frame")?.setAttribute("value", String(frameBudget));      // core load
        $("s6-dom")?.setAttribute("value", String(pressure));           // pressure
        $("s6-heap")?.setAttribute("value", String(heap));              // coolant
        ($("s6-fps") as any)?.push(clamp(((fluxV - 200) / 900) * 100)); // flux trend
        $("s6-read")?.setAttribute("value", String(pressure));
        $("s6-pressure")?.style.setProperty("--talos-rate", (pressure / 100).toFixed(2));

        // a row = value text (+band) + bar fill% (+band) + optional range text
        // NB: function declaration (hoisted) — earlier scene blocks call band()
        // before this line, which a `const` arrow would TDZ-throw on.
        function band(v: number, w: number, c: number): "warn" | "crit" | undefined {
          return v >= c ? "crit" : v >= w ? "warn" : undefined;
        }
        const setM = (id: string, text: string, fillPct?: number, bnd?: "warn" | "crit", range?: string) => {
          const v = $("d-" + id); if (v) { v.textContent = text; bnd ? v.setAttribute("data-band", bnd) : v.removeAttribute("data-band"); }
          const b = $("b-" + id); if (b && fillPct != null) { (b as HTMLElement).style.width = clamp(fillPct) + "%";
            const bar = b.parentElement!; bnd ? bar.setAttribute("data-band", bnd) : bar.removeAttribute("data-band"); }
          if (range != null) { const r = $("r-" + id); if (r) r.textContent = range; }
        };
        const mb = (bytes: number) => (bytes / 1048576).toFixed(0);

        // RENDER — sparklines (live history) + delta + dot-matrix, not bars
        const fpsBand = band(60 - fps, 20, 30), msBand = band(frameMs, 20, 33);
        pushHist("fps", fps); pushHist("ms", frameMs);
        setM("fps", String(Math.round(fps)), undefined, fpsBand);
        spark("sp-fps", "fps", fpsBand, 80); delta("dl-fps", "fps", fps);
        setM("ms", frameMs.toFixed(1), undefined, msBand, `${fpsMin}-${fpsMax}`);
        spark("sp-ms", "ms", msBand, 40);
        setM("budget", frameBudget + "%", frameBudget, band(frameBudget, 70, 90));   // keeps a bar (contrast)
        setM("long", String(longTaskCount), undefined, longTaskCount > 0 ? "warn" : undefined);
        dotmx("dm-long", longTaskCount, 8, longTaskCount > 0 ? "warn" : undefined);
        // MEMORY
        if (memSupported) {
          const u = perfMem.usedJSHeapSize, t = perfMem.totalJSHeapSize, l = perfMem.jsHeapSizeLimit;
          setM("used", mb(u), (u / t) * 100, band(heap, 70, 90), `pk ${mb(usedPeak)}`);
          setM("total", mb(t), (t / l) * 100);
          setM("limit", mb(l), 100);
          const hBand = band(heap, 70, 90); pushHist("heap", heap);
          setM("heappct", heap + "%", undefined, hBand);
          spark("sp-heap", "heap", hBand, 100); delta("dl-heap", "heap", heap);
        } else { ["used","total","limit","heappct"].forEach(i => setM(i, "n/a", 0)); }
        // DOM — node count keeps a bar + gains a delta (it climbs as scenes mount)
        setM("nodes", String(domCount), (domCount / 1200) * 100, band(domLoad, 70, 90));
        delta("dl-nodes", "nodes", domCount);
        // NETWORK — rtt sparkline + delta
        const rBand = band(rtt, 150, 300); pushHist("rtt", rtt);
        setM("rtt", rtt ? String(rtt) : "—", undefined, rBand);
        spark("sp-rtt", "rtt", rBand, 300); delta("dl-rtt", "rtt", rtt);
        setM("down", conn.downlink ? String(conn.downlink) : "—", conn.downlink ? (conn.downlink / 20) * 100 : 0);
        // SCROLL · CAM
        setM("scroll", String(scrollPx), progPct, undefined, `${Math.round(camZ)}z`);
        setM("camz", String(Math.round(camZ)), (Math.abs(camZ) / (N * GAP)) * 100);
        setM("vel", vel().toFixed(2), vel() * 100, vel() > 0.5 ? "warn" : undefined);
        setM("prog", progPct + "%", progPct);

        // stat-strip aggregates
        const setS = (id: string, html: string) => { const e = $(id); if (e) e.innerHTML = html; };
        setS("st-pressure", `${Math.round(pressure)}<small>%</small>`);
        setS("st-fpsavg", `${fluxV.toLocaleString()}`);
        setS("st-heap", `${Math.round(heap)}<small>%</small>`);
        setS("st-dom", `${Math.round(frameBudget)}<small>%</small>`);
        setS("st-net", conn.effectiveType ? `${conn.effectiveType} · ${rtt}<small>ms</small>` : `${rtt}<small>ms</small>`);
        setS("st-uptime", `${Math.floor(performance.now() / 1000)}<small>s</small>`);
        // POWER · STORE live row
        setM("uptime", `${Math.floor(performance.now() / 1000)}`);

        // ---- Scene 04: the orbital IS the reactor's subsystem mesh ----
        // Each node is a real reactor subsystem (pumps/rods/exchanger/…) whose
        // pressure + activity derive from the sim — so the mesh and the legend
        // move with the core, and stay coherent with the reactor framing.
        const meshNodes = SUB.map((s) => {
          const v = clamp(s.base * 100 * (0.5 + reactor.load / 100) + (reactor.pressure - 40) * 0.3);
          const act = clamp(40 + reactor.flux / 12 + s.base * 30);
          return { id: s.id, ring: s.ring, label: s.label, value: r2(v),
                   load: 0.3 + 0.5 * (v / 100), rate: r2(act) };
        });
        if (orb) orb.nodes = meshNodes;
        // Scene 04 legend table — same node data as the mesh, one row each.
        // NOTE: rows are injected via innerHTML, so their layout styles must be
        // GLOBAL (Astro scopes <style> by a class hash that injected nodes don't
        // carry — that's why the columns previously collapsed into run-on text).
        const meshEl = $("mesh-rows");
        if (meshEl) {
          meshEl.innerHTML = meshNodes.map((n) => {
            const v = r2(n.value), bnd = v >= 80 ? "crit" : v >= 50 ? "warn" : "";
            const col = bnd === "crit" ? "var(--talos-danger)" : bnd === "warn" ? "var(--talos-warning)" : "var(--talos-accent)";
            return `<div class="mesh-row"><span class="mn">${n.label}</span><span class="mt">R${n.ring}</span>`
              + `<span class="mp"><span class="mbar" style="position:relative;overflow:hidden;height:3px;background:var(--talos-surface-2)"><i style="position:absolute;inset:0 auto 0 0;width:${v}%;background:${col}"></i></span><span style="color:${col};min-width:2.6rem;text-align:right">${v}%</span></span>`
              + `<span class="ma">${r2(n.rate)}</span></div>`;
          }).join("");
        }
      }, 280);

      // ---- HUD: replace the synthetic lat/lon with REAL vitals, labelled true ----
      const hudFps = $("ro-lat"), hudHeap = $("ro-lon"), hudSig = $("ro-sig");
      // relabel the coord cluster keys to their real meaning
      const coordKeys = document.querySelectorAll(".coords .k");
      if (coordKeys[1]) coordKeys[1].textContent = "FPS";
      if (coordKeys[2]) coordKeys[2].textContent = "HEAP";
      setInterval(() => {
        if (hudFps) hudFps.textContent = String(Math.round(fps)).padStart(2, "0") + " fps";
        if (hudHeap) hudHeap.textContent = memSupported ? heapMB().toFixed(1) + " MB" : "N/A";
        // SIG already reflects scroll tracking from the camera loop; overlay a
        // real health verdict when the frame budget blows out.
        if (hudSig && frameMs > 24) { hudSig.textContent = "FRAME DROP"; (hudSig as HTMLElement).style.color = "var(--talos-warning, orange)"; }
      }, 280);
    </script>
  </body>
</html>
