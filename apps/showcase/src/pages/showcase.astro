    .spine-lens { font-family: var(--talos-font-display); font-size: 0.56rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--talos-muted-foreground); }
    .spine-lens b { color: var(--talos-foreground); font-weight: 500; }
    .spine-spacer { flex: 1 1 auto; }
    .spine-status { display: inline-flex; align-items: center; gap: 1rem; font-family: var(--talos-font-display); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--talos-muted-foreground); }
