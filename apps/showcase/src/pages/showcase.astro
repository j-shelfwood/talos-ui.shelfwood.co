    .con-rail { gap: 1rem; }
    .con-rail-meta { display: inline-flex; gap: 1rem; align-items: baseline; font-family: var(--talos-font-display); font-size: 0.6rem; letter-spacing: var(--talos-tracking-hud); text-transform: uppercase; color: var(--talos-muted-foreground); }
    .con-rail-meta b { color: var(--talos-foreground); font-weight: 500; font-variant-numeric: tabular-nums; display: inline-block; min-width: 3.2ch; text-align: right; }
    .num { font-variant-numeric: tabular-nums; }

    .con-k { font-family: var(--talos-font-display); font-size: 0.6rem; letter-spacing: var(--talos-tracking-hud); text-transform: uppercase; color: var(--talos-muted-foreground); display: block; }
    .con-k--dim { opacity: 0.6; }
    .con-k--accent { color: var(--talos-accent, hsl(140 90% 60%)); }
