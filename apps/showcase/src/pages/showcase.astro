---
// Showcase — CONSTELLATION OPS WALL, as a DRILL-DOWN THREAD.
//
// Four stacked consoles that zoom into each other: FLEET (all 1,584 sats) →
// POWER (the same fleet as distributions) → PLANE (the 22 sats of one selected
// orbital plane, with their real ISL links) → SATELLITE (one sat + its real
// neighbours, located back in the full grid). A single selection — a plane and a
// slot — flows down the wall: click a cell in the fleet matrix and the plane
// console fills with that column's 22 satellites; click one of those and the
// satellite console drills in. Each level is a visible magnification of the one
// above, so the scale is coherent, not four unrelated widgets.
//
// One ConstellationModel (typed arrays over 1,584 sats) is the single source of
// truth; the consoles are lenses on it, all live (PHILOSOPHY.md: live not static;
// motion is telemetry; selection is state). Grounded figures: shell = 72×22 =
// 1,584 @ 550 km / 53° / ~95 min; compute 120 kW sustained per "AI1"-class sat;
// solar ~150 kW; eclipse ≈ 35% of each orbit; radiator band ~0–30 °C; ISL mesh.
import Landing from "../layouts/Landing.astro";
import BrandMark from "@j_shelfwood/talos-ui/astro/BrandMark.astro";
---

<Landing title="Showcase" navActive="showcase">
  <header class="sc-intro talos-stack">
    <span class="talos-eyebrow">// Constellation ops · drill-down</span>
    <h1 style="font-size:clamp(2rem,4.5vw,3.4rem);letter-spacing:.005em;line-height:1.06">
      Drill from 1,584 satellites down to one.
    </h1>
    <p class="talos-muted" style="max-width:62ch;font-size:1.05rem">
      Seventy-two orbital planes, twenty-two compute satellites each. The five
      lenses below are one continuous zoom: the whole fleet, the fleet as
      distributions, a single plane's 22 satellites and their laser links, one
      satellite in detail, and its anatomy in 3D. <b style="color:var(--talos-foreground);font-weight:500">Click any
      cell</b> in the fleet grid to choose a plane; click a satellite to focus it.
      The selection threads down the spine while the whole shell keeps flying.
    </p>
  </header>

  <div class="ops-wall">
    <!-- Left rail: a connector threading the five lenses, with a live "you are here" node. -->
    <nav class="ops-rail" aria-label="Lens navigation">
      <div class="ops-nodes">
        <a class="ops-node" href="#lens-1" data-lens="1"><b>L1</b> Fleet ×1</a>
        <a class="ops-node" href="#lens-2" data-lens="2"><b>L2</b> Power ×1584</a>
        <a class="ops-node" href="#lens-3" data-lens="3"><b>L3</b> Plane ×72</a>
        <a class="ops-node" href="#lens-4" data-lens="4"><b>L4</b> Sat ×1584</a>
        <a class="ops-node" href="#lens-5" data-lens="5"><b>L5</b> Anatomy 3D</a>
      </div>
    </nav>

    <div class="ops-content">
      <!-- Sticky mission spine: the live drill-down path + the selected sat's status. -->
      <div class="ops-spine">
        <span class="spine-crumb">
          <a href="#lens-1">FLEET</a>
          <span class="sep">▸</span>
          <a href="#lens-3">P<b id="spine-plane">00</b></a>
          <span class="sep">▸</span>
          <a href="#lens-4">S<b id="spine-slot">00</b></a>
        </span>
        <span class="spine-lens">LENS <b id="spine-lens">1</b>/5</span>
        <span class="spine-spacer"></span>
        <span class="spine-status">
          <span id="spine-state">SUNLIT</span>
          <span>CORE <b id="spine-temp">—</b></span>
          <span>BATT <b id="spine-batt">—</b></span>
        </span>
        <talos-status id="sc-rollup" label="GROUND STATION" channels="ok,ok,ok,ok" scan style="min-width:230px"></talos-status>
      </div>

  <!-- ════ CONSOLE 1 — FLEET (all 1,584) ══════════════════════════════════════ -->
  <section class="sc-panel" id="lens-1">
    <div class="talos-console sc-console">
      <div class="console-rail con-rail">
        <span class="console-rail__brand">
          <talos-led id="con-led" state="ok" live size="9"></talos-led>
          SYS://FLEET
        </span>
        <span class="console-rail__spacer"></span>
        <span class="con-rail-meta">
          <span>SUN <b id="m-sun">—</b></span>
          <span>ECL <b id="m-ecl">—</b></span>
          <span>SEL <b id="m-sel">P00·S00</b></span>
        </span>
      </div>

      <div class="console-scope con-scope">
        <div class="view-a">
          <div class="va-main">
            <div class="va-head">
              <span class="con-k">Fleet health · 72 planes × 22 satellites · <span class="con-k--accent">click a cell to select a plane</span></span>
              <span class="con-k con-k--dim">terminator sweeping →</span>
            </div>
            <talos-matrix id="a-matrix" cols="72" rows="22" warn="70" crit="88" terminator="0" terminator-width="0.32" gap="1"></talos-matrix>
            <div class="va-head" style="margin-top:.75rem">
              <span class="con-k">Ground track · sub-satellite points & gateways</span>
            </div>
            <talos-groundtrack id="a-track" inclination="53" tracks="6"></talos-groundtrack>
          </div>
          <aside class="va-side">
            <div class="con-cell span2">
              <span class="con-k">Constellation compute</span>
              <div class="con-cell__row">
                <talos-gauge id="a-compute" value="0" warn="82" crit="94" unit="%" size="100"></talos-gauge>
                <div class="con-cell__side">
                  <talos-readout id="a-kw" value="0" unit="MW" label="fleet draw"></talos-readout>
                  <span class="con-sub">1,584 × ~120 kW</span>
                </div>
              </div>
            </div>
            <div class="va-stats">
              <div class="va-stat"><span class="va-stat__k">Operational</span><span class="va-stat__v num" id="a-online">—</span></div>
              <div class="va-stat"><span class="va-stat__k">In eclipse</span><span class="va-stat__v num" id="a-ecl">—</span></div>
              <div class="va-stat"><span class="va-stat__k">Downlink</span><span class="va-stat__v num" id="a-link">—</span></div>
              <div class="va-stat"><span class="va-stat__k">Batt. margin</span><span class="va-stat__v num" id="a-margin">—</span></div>
            </div>
            <div class="con-cell">
              <span class="con-k">Selected plane <b class="con-k--accent" id="a-pl-id">P00</b></span>
              <div class="va-stats va-stats--col" style="gap:.4rem">
                <div class="va-stat"><span class="va-stat__k">Mean SoC</span><span class="va-stat__v num" id="a-pl-soc">—</span></div>
                <div class="va-stat"><span class="va-stat__k">Mean temp</span><span class="va-stat__v num" id="a-pl-temp">—</span></div>
              </div>
            </div>
            <div class="con-cell span2">
              <span class="con-k">Mean core temp · fleet</span>
              <talos-meter id="a-temp" value="0" min="-20" max="45" warn="28" crit="36" unit="°C"></talos-meter>
            </div>
          </aside>
        </div>
      </div>

      <div class="console-status">
        <span class="console-status__stat">shell <b>1,584 sats</b></span>
        <span class="console-status__stat">alt <b>550 km</b></span>
        <span class="console-status__stat">incl <b>53°</b></span>
        <span class="console-status__stat">period <b>95 min</b></span>
        <span class="console-status__spacer"></span>
        <span class="console-status__stat">CONSOLE 1 · FLEET</span>
      </div>
    </div>
  </section>

  <!-- ════ CONSOLE 2 — POWER & THERMAL (fleet distributions) ═══════════════════ -->
  <section class="sc-panel" id="lens-2">
    <div class="talos-console sc-console">
      <div class="console-rail con-rail">
        <span class="console-rail__brand"><talos-led state="ok" live size="9"></talos-led> SYS://POWER-THERMAL</span>
        <span class="console-rail__spacer"></span>
        <span class="con-rail-meta"><span>SOLAR <b id="m2-solar">—</b></span><span>MEAN SOC <b id="m2-soc">—</b></span></span>
      </div>

      <div class="console-scope con-scope">
        <div class="view-b">
          <div class="vb-col">
            <div class="vb-hist">
              <span class="con-k">Battery state-of-charge · across 1,584 sats</span>
              <talos-histogram id="b-batt" bins="28" min="0" max="100" warn="45" crit="28" invert style="height:150px"></talos-histogram>
              <span class="con-sub">The eclipse cohort sits to the left; the bulk of the fleet holds charge on the right.</span>
            </div>
            <div class="vb-hist">
              <span class="con-k">Core temperature · distribution (°C)</span>
              <talos-histogram id="b-temp" bins="28" min="0" max="45" warn="29" crit="34" style="height:150px"></talos-histogram>
              <span class="con-sub">A right-shifting bulk signals the constellation warming through the sunlit arc.</span>
            </div>
          </div>
          <aside class="vb-side">
            <div class="con-cell">
              <span class="con-k">Selected plane <b class="con-k--accent" id="b-plane">P00</b></span>
              <div class="va-stats">
                <div class="va-stat"><span class="va-stat__k">Plane SoC</span><span class="va-stat__v num" id="b-psoc">—</span></div>
                <div class="va-stat"><span class="va-stat__k">Plane temp</span><span class="va-stat__v num" id="b-ptemp">—</span></div>
              </div>
            </div>
            <div class="con-cell">
              <span class="con-k">Fleet solar input</span>
              <talos-meter id="b-solar" value="0" warn="40" crit="15" invert unit="%"></talos-meter>
              <span class="con-k" style="margin-top:.75rem">Mean battery SoC</span>
              <talos-meter id="b-battm" value="100" warn="42" crit="28" invert unit="%"></talos-meter>
              <span class="con-k" style="margin-top:.75rem">Radiator dissipation</span>
              <talos-readout id="b-rad" value="0" unit="MW" label="fleet dump"></talos-readout>
            </div>
            <div class="con-cell con-cell--trend">
              <span class="con-k">Fleet power draw · live window</span>
              <talos-trend id="b-trend" min="0" max="200" height="80" fill></talos-trend>
            </div>
          </aside>
        </div>
      </div>

      <div class="console-status">
        <span class="console-status__stat">solar array <b>~150 kW/sat</b></span>
        <span class="console-status__stat">radiator band <b>0–30 °C</b></span>
        <span class="console-status__spacer"></span>
        <span class="console-status__stat">CONSOLE 2 · POWER & THERMAL</span>
      </div>
    </div>
  </section>

  <!-- ════ CONSOLE 3 — PLANE (the selected plane's 22 sats + ISL ring) ════════ -->
  <section class="sc-panel" id="lens-3">
    <div class="talos-console sc-console">
      <div class="console-rail con-rail">
        <span class="console-rail__brand"><talos-led id="c-led" state="ok" live size="9"></talos-led> SYS://PLANE-<span id="c-plane-id">00</span></span>
        <span class="console-rail__spacer"></span>
        <span class="con-rail-meta"><span>SATS <b>22</b></span><span>ISL <b>laser ×4</b></span></span>
      </div>

      <div class="console-scope con-scope">
        <div class="view-c">
          <div class="vc-ring">
            <talos-plane id="c-ring" slots="22" plane-label="P00"></talos-plane>
            <span class="con-sub" style="text-align:center;margin-top:.5rem">Click a satellite to focus it · fore/aft = in-plane ISL · radial stubs = cross-plane links</span>
          </div>
          <div class="vc-slots-col">
            <span class="con-k">Slot roster · 22 sats</span>
            <div class="vc-slots" id="c-slots"><!-- rows bound from the plane ring[] each frame --></div>
          </div>
          <aside class="vc-side">
            <span class="con-k">Plane <b class="con-k--accent" id="c-plane-id2">P00</b> · health</span>
            <div class="va-stats va-stats--col">
              <div class="va-stat"><span class="va-stat__k">Nominal</span><span class="va-stat__v num" id="c-nom">—</span></div>
              <div class="va-stat"><span class="va-stat__k">In eclipse</span><span class="va-stat__v num" id="c-ecl">—</span></div>
              <div class="va-stat"><span class="va-stat__k">Plane downlink</span><span class="va-stat__v num" id="c-dl">—</span></div>
              <div class="va-stat"><span class="va-stat__k">ISL links up</span><span class="va-stat__v num" id="c-links">—</span></div>
            </div>
            <div class="con-cell con-cell--trend">
              <span class="con-k">Plane mean SoC · live</span>
              <talos-trend id="c-trend" min="0" max="100" height="64" fill></talos-trend>
            </div>
          </aside>
        </div>
      </div>

      <div class="console-status">
        <span class="console-status__stat">ISL <b>laser · 10 Gbps–Tbps</b></span>
        <span class="console-status__stat">topology <b>grid-mesh ×4</b></span>
        <span class="console-status__spacer"></span>
        <span class="console-status__stat">CONSOLE 3 · PLANE</span>
      </div>
    </div>
  </section>

  <!-- ════ CONSOLE 4 — SATELLITE (focus + locator) ════════════════════════════ -->
  <section class="sc-panel" id="lens-4">
    <div class="talos-console sc-console">
      <div class="console-rail con-rail">
        <span class="console-rail__brand"><talos-led id="d-led" state="ok" live size="9"></talos-led> SYS://SAT-<span id="d-name">P00-S00</span></span>
        <span class="console-rail__spacer"></span>
        <span class="con-rail-meta"><span id="d-state">SUNLIT</span></span>
      </div>

      <div class="console-scope con-scope">
        <div class="view-d">
          <div class="vd-left">
            <div class="vd-loc-cell">
              <span class="con-k">Locator · where in the shell</span>
              <talos-matrix id="d-loc" cols="72" rows="22" warn="70" crit="88" gap="1" style="--talos-success:hsl(140 30% 28%);--talos-warning:hsl(38 40% 30%);--talos-danger:hsl(0 45% 32%)"></talos-matrix>
            </div>
            <div class="vd-orbital-cell">
              <span class="con-k">ISL neighbourhood</span>
              <div class="vd-orbital">
                <talos-orbital id="d-orb" rings="2" warn="70" crit="88" core-label="SAT" core-sub="ISL NEIGHBOURHOOD" size="300"></talos-orbital>
              </div>
            </div>
          </div>
          <aside class="vd-side">
            <div class="con-detail">
              <div class="con-detail__row"><span>Sun state</span><span class="con-detail__v" id="d-phase">—</span></div>
              <div class="con-detail__row"><span>Compute</span><span class="con-detail__v num" id="d-cpu">—</span></div>
              <div class="con-detail__row"><span>Core temp</span><span class="con-detail__v num" id="d-temp">—</span></div>
              <div class="con-detail__row"><span>Battery</span><span class="con-detail__v num" id="d-batt">—</span></div>
              <div class="con-detail__row"><span>Plane / slot</span><span class="con-detail__v num" id="d-loc-id">—</span></div>
              <div class="con-detail__row"><span>ISL neighbours</span><span class="con-detail__v" id="d-nb">—</span></div>
              <div class="con-detail__row"><span>Next sunlight</span><span class="con-detail__v" id="d-next">—</span></div>
            </div>
            <div class="con-cell" style="margin-top:1rem">
              <span class="con-k">GPU thermal · live</span>
              <talos-trend id="d-trend" min="0" max="45" height="64" fill></talos-trend>
            </div>
          </aside>
        </div>
      </div>

      <div class="console-status">
        <span class="console-status__stat">payload <b>AMD Versal AI</b></span>
        <span class="console-status__stat">compute <b>120 kW sustained</b></span>
        <span class="console-status__spacer"></span>
        <span class="console-status__stat">CONSOLE 4 · SATELLITE</span>
      </div>
    </div>
  </section>

  <!-- ════ CONSOLE 5 — ANATOMY (the selected sat as 3D geometry) ═══════════════ -->
  <section class="sc-panel" id="lens-5">
    <div class="talos-console sc-console">
      <div class="console-rail con-rail">
        <span class="console-rail__brand"><talos-led id="e-led" state="ok" live size="9"></talos-led> SYS://ANATOMY-<span id="e-name">P00-S00</span></span>
        <span class="console-rail__spacer"></span>
        <span class="con-rail-meta"><span>7 subsystems</span><span id="e-worst">NOMINAL</span></span>
      </div>

      <div class="console-scope con-scope">
        <div class="view-e">
          <div class="ve-stage">
            <talos-spacecraft-3d id="e-craft"></talos-spacecraft-3d>
            <span class="con-sub" style="text-align:center;margin-top:.5rem">Hover or click a subsystem · each part's glow is its live health band · slow auto-orbit</span>
          </div>
          <aside class="ve-side">
            <div class="ve-focus" id="e-focus" data-empty>
              <div class="ve-focus__head">
                <span class="ve-focus__name" id="e-fname">SELECT A SUBSYSTEM</span>
                <span class="ve-focus__band" id="e-fband">—</span>
              </div>
              <p class="ve-focus__role" id="e-frole">Click a part on the model to lock its live telemetry here.</p>
              <div class="ve-focus__metric">
                <span class="ve-focus__val num" id="e-fval">—</span>
                <span class="ve-focus__unit" id="e-funit"></span>
              </div>
              <talos-meter id="e-fmeter" value="0" min="0" max="100" style="width:100%"></talos-meter>
            </div>
            <span class="con-k" style="margin-top:1.25rem">All subsystems</span>
            <div class="con-detail" id="e-parts">
              <div class="con-detail__row" data-part="bus"><span>Bus</span><span class="con-detail__v" id="e-bus">—</span></div>
              <div class="con-detail__row" data-part="gpu"><span>GPU / compute</span><span class="con-detail__v" id="e-gpu">—</span></div>
              <div class="con-detail__row" data-part="solarL"><span>Solar wing L</span><span class="con-detail__v" id="e-solarL">—</span></div>
              <div class="con-detail__row" data-part="solarR"><span>Solar wing R</span><span class="con-detail__v" id="e-solarR">—</span></div>
              <div class="con-detail__row" data-part="radL"><span>Radiator L</span><span class="con-detail__v" id="e-radL">—</span></div>
              <div class="con-detail__row" data-part="radR"><span>Radiator R</span><span class="con-detail__v" id="e-radR">—</span></div>
              <div class="con-detail__row" data-part="antenna"><span>Downlink antenna</span><span class="con-detail__v" id="e-antenna">—</span></div>
            </div>
            <div class="ve-legend">
              <span class="con-k">Band · colour is the state</span>
              <div class="ve-legend__row"><span class="ve-dot" style="--c:var(--talos-success)"></span> Nominal — within limits</div>
              <div class="ve-legend__row"><span class="ve-dot" style="--c:var(--talos-warning)"></span> Warning — approaching a threshold</div>
              <div class="ve-legend__row"><span class="ve-dot" style="--c:var(--talos-danger)"></span> Critical — past the limit</div>
              <p class="con-sub" style="margin-top:.75rem">Each subsystem's glow on the model is its live band, derived from the same fleet signals driving every console above. Click a part to lock the readout.</p>
            </div>
          </aside>
        </div>
      </div>

      <div class="console-status">
        <span class="console-status__stat">render <b>WebGL · procedural</b></span>
        <span class="console-status__stat">bind <b>.parts → emissive band</b></span>
        <span class="console-status__spacer"></span>
        <span class="console-status__stat">CONSOLE 5 · ANATOMY (3D)</span>
      </div>
    </div>
  </section>
    </div><!-- /.ops-content -->
  </div><!-- /.ops-wall -->

  <p class="talos-muted sc-note">
    One continuous zoom, five lenses, real shell scale — the selection threads
    fleet → plane → satellite → anatomy down the spine while everything stays live.
    New instruments built for this: <b>talos-matrix</b> (1,584-cell grid, clickable +
    terminator), <b>talos-plane</b> (a plane's 22 sats + ISL links),
    <b>talos-groundtrack</b> (sub-satellite map), <b>talos-histogram</b> (fleet
    distributions), and a procedural <b>3D anatomy</b> — alongside gauge, meter,
    trend, orbital, readout and the status rollup. Every value is bound to the model.
  </p>

  <footer class="sc-footer talos-row" style="justify-content:space-between;align-items:center;border-top:1px solid var(--talos-border);padding-top:1.5rem">
    <BrandMark />
    <span class="talos-eyebrow talos-muted">1,584 sats · fleet → plane → sat · MIT</span>
  </footer>

  <style>
    .sc-intro { margin-bottom: 1.5rem; }
    .sc-intro b { color: var(--talos-foreground); }
    /* Clear BOTH sticky bars (nav + the mission spine) when an anchor jump lands
       on a console, so the targeted console never hides under the spine. */
    .sc-panel { margin-bottom: 1.5rem; scroll-margin-top: calc(var(--site-nav-h) + 5rem); }

    /* ── Ops wall: a left connector rail threads the five consoles together. ── */
    .ops-wall {
      --sel-accent: var(--talos-accent, hsl(140 90% 60%));
      display: grid; grid-template-columns: 92px minmax(0, 1fr); column-gap: 2rem;
    }
    .ops-rail { position: relative; }
    .ops-rail::before {
      content: ""; position: absolute; left: 14px; top: 12px; bottom: 12px; width: 1px;
      background: linear-gradient(var(--talos-hud-edge, hsl(0 0% 100% / 0.18)), transparent 96%);
    }
    .ops-nodes { position: sticky; top: calc(var(--site-nav-h) + 4.2rem); display: flex; flex-direction: column; gap: 1rem; }
    .ops-node {
      position: relative; display: block; padding-left: 1.7rem; text-decoration: none;
      font-family: var(--talos-font-display); font-size: 0.5rem; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--talos-muted-foreground); line-height: 1.3;
      transition: color 160ms ease;
    }
    .ops-node::before {
      content: ""; position: absolute; left: 10px; top: 2px; width: 9px; height: 9px;
      border: 1px solid var(--talos-muted-foreground); border-radius: 50%;
      background: var(--talos-background); transition: all 180ms ease;
    }
    .ops-node b { display: block; color: var(--talos-foreground); font-size: 0.56rem; font-weight: 500; }
    .ops-node[data-active] { color: var(--talos-foreground); }
    .ops-node[data-active]::before {
      border-color: var(--sel-accent); background: var(--sel-accent);
      box-shadow: 0 0 8px var(--sel-accent);
    }
    .ops-node:hover { color: var(--talos-foreground); }

    /* ── Sticky mission spine: the live drill-down path + selected-sat status. ── */
    /* Stays a SINGLE ROW wherever the left rail is visible (>720px), so the rail's
       fixed sticky offset never has to chase a wrapping spine. Below 720px the rail
       is hidden, so the spine may wrap freely. */
    .ops-spine {
      position: sticky; top: var(--site-nav-h); z-index: 5;
      display: flex; align-items: center; gap: 1rem 1.25rem; flex-wrap: nowrap;
      padding: 0.55rem 1rem; margin-bottom: 1.5rem;
      border: 1px solid var(--talos-hud-edge, hsl(0 0% 100% / 0.18));
