    .con-scope { padding: 1.5rem; }

    .view-a { display: grid; grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr); gap: 1.75rem; align-items: start; }
    .va-main { min-width: 0; }
    .va-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.5rem; gap: 1rem; }
    #a-matrix, #a-track { width: 100%; }
    /* FLEET aside fills its width: a 2-col grid; wide cells span both columns,
       the stats + the selected-plane mini-rollup sit side by side. */
    .va-side { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem 1.25rem; align-content: start; }
    .va-side .span2 { grid-column: 1 / -1; }
    .va-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem 1rem; }
    .va-stats--col { grid-template-columns: 1fr; }
    .va-stat { display: flex; flex-direction: column; gap: 0.15rem; }
    .va-stat__k { font-family: var(--talos-font-display); font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--talos-muted-foreground); }
    .va-stat__v { font-size: 1.1rem; color: var(--talos-foreground); }

    .view-b { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(240px, 1fr); gap: 1.75rem; align-items: start; }
    .vb-col { min-width: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-content: start; }
    .vb-col .vb-hist { min-width: 0; }
    .vb-side { display: flex; flex-direction: column; gap: 1.25rem; }

    /* PLANE: ring | per-slot strip | health+trend. */
    .view-c { display: grid; grid-template-columns: minmax(0, 1fr) minmax(150px, 0.7fr) minmax(220px, 1fr); gap: 1.5rem; align-items: start; }
    .vc-ring { display: flex; flex-direction: column; align-items: center; min-width: 0; }
    .vc-ring talos-plane { width: 100%; max-width: 340px; }
    .vc-side { display: flex; flex-direction: column; gap: 1.25rem; }
    /* per-slot strip — 22 rows bound from the plane ring[] each frame. */
    .vc-slots { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .vc-slot {
      display: flex; align-items: center; gap: 0.5rem; padding: 0.16rem 0.4rem;
      font-family: var(--talos-font-display); font-size: 0.56rem; letter-spacing: 0.06em;
      color: var(--talos-muted-foreground); border-left: 2px solid transparent; cursor: pointer;
    }
    .vc-slot:hover { background: hsl(0 0% 100% / 0.03); }
    .vc-slot[data-sel] { border-left-color: var(--sel-accent); color: var(--talos-foreground); background: hsl(0 0% 100% / 0.04); }
    .vc-slot__dot { width: 6px; height: 6px; border-radius: 50%; flex: 0 0 auto; background: var(--c, var(--talos-success)); }
    .vc-slot__id { min-width: 3ch; }
    .vc-slot__b { margin-left: auto; opacity: 0.8; }

    .view-d { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(240px, 1fr); gap: 1.75rem; align-items: start; }
    .view-e { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 320px); gap: 1.75rem; align-items: start; }
    .ve-stage { display: flex; flex-direction: column; min-width: 0; }
    .ve-stage talos-spacecraft-3d {
      display: block; width: 100%; height: 420px;
      border: 1px solid var(--talos-glass-border, hsl(0 0% 100% / 0.12));
      background: radial-gradient(ellipse at 50% 40%, hsl(0 0% 6%) 0%, hsl(0 0% 0%) 70%);
    }
    .ve-side { display: flex; flex-direction: column; gap: 0.5rem; }
    .ve-side .con-detail__row[data-part] { transition: color 120ms ease; }
    .ve-legend { margin-top: 1.5rem; border-top: 1px solid var(--talos-glass-border, hsl(0 0% 100% / 0.12)); padding-top: 1rem; }
    .ve-legend__row {
      display: flex; align-items: center; gap: 0.5rem; margin-top: 0.4rem;
      font-size: 0.72rem; color: var(--talos-muted-foreground, hsl(0 0% 60%));
    }
    .ve-dot {
      width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto;
      background: var(--c); box-shadow: 0 0 8px var(--c);
    }
    .ve-focus {
      border: 1px solid var(--talos-glass-border, hsl(0 0% 100% / 0.12));
      background: hsl(0 0% 100% / 0.02); padding: 0.9rem 1rem;
      --_fc: var(--talos-foreground);
    }
    .ve-focus[data-empty] { opacity: 0.55; }
    .ve-focus__head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
    .ve-focus__name {
      font-family: var(--talos-font-display); font-size: 0.78rem; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--talos-foreground);
    }
    .ve-focus__band {
      font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--_fc); border: 1px solid var(--_fc); padding: 0.1rem 0.4rem; border-radius: 0;
    }
    .ve-focus__role { font-size: 0.72rem; line-height: 1.5; color: var(--talos-muted-foreground); margin: 0.5rem 0 0.75rem; min-height: 2.1em; }
    .ve-focus__metric { display: flex; align-items: baseline; gap: 0.3rem; margin-bottom: 0.6rem; }
    .ve-focus__val { font-size: 1.8rem; font-weight: 300; line-height: 1; color: var(--_fc); font-variant-numeric: tabular-nums; }
    .ve-focus__unit { font-size: 0.7rem; color: var(--talos-muted-foreground); text-transform: uppercase; letter-spacing: 0.1em; }
    .vd-left { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; min-width: 0; align-items: start; }
    .vd-left .vd-loc-cell { min-width: 0; }
    #d-loc { width: 100%; }
    .vd-orbital { display: flex; align-items: center; justify-content: center; }
    .vd-orbital talos-orbital { width: 100%; max-width: 320px; }
    .vd-side { display: flex; flex-direction: column; gap: 0.75rem; }
    /* satellite detail rows in 2 columns to fill the wider aside. */
    .vd-side .con-detail { display: grid; grid-template-columns: 1fr 1fr; gap: 0 1.25rem; }

    .con-cell { display: flex; flex-direction: column; gap: 0.5rem; }
    .con-cell__row { display: flex; align-items: center; gap: 1rem; }
    .con-cell__side { display: flex; flex-direction: column; gap: 0.3rem; }
    .con-cell talos-meter { display: block; width: 100% !important; }
    .con-cell--trend talos-trend { display: block; width: 100% !important; }
    /* talos-readout is a small scramble-decode widget; where the showcase uses it
       as a headline figure (fleet draw / dump), scale the host so its value reads
       as a metric, not body text. */
    #a-kw, #b-rad { font-size: 1.5rem; line-height: 1; }

    .con-detail__row { display: flex; justify-content: space-between; font-family: var(--talos-font-display); font-size: 0.66rem; letter-spacing: 0.03em; color: var(--talos-muted-foreground); padding: 0.3rem 0; border-bottom: 1px solid hsl(0 0% 100% / 0.06); }
    .con-detail__v { color: var(--talos-foreground); }

    .sc-note { font-size: 0.82rem; margin: 1.5rem 0 1rem; max-width: 78ch; }
    .sc-note b { color: var(--talos-foreground); font-weight: 500; }

    @media (max-width: 900px) {
      .view-a, .view-b, .view-c, .view-d, .view-e { grid-template-columns: 1fr; }
      .vb-col { grid-template-columns: 1fr; }
      .vd-left { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    import type { TalosMatrix, TalosGroundtrack, TalosHistogram, TalosPlane, OrbitalNode } from "@j_shelfwood/talos-ui/wc";
    // Showcase-local 3D anatomy console (CONSOLE 5). Self-registers
    // <talos-spacecraft-3d>; consumes Three.js, so it lives in the site, not the pack.
    import { TalosSpacecraft3D } from "../components/spacecraft-3d/talos-spacecraft-3d";

    // ════ ONE CONSTELLATION MODEL · one selection threads through it ══════════
    const PLANES = 72, SLOTS = 22, N = PLANES * SLOTS, INCL = 53;
    const PERIOD_MS = 36_000, ECLIPSE_FRAC = 0.35;
    const clamp = (n: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, n));

    const phase0 = new Float32Array(N), raan = new Float32Array(N), batt = new Float32Array(N), tbias = new Float32Array(N);
    for (let p = 0; p < PLANES; p++) for (let s = 0; s < SLOTS; s++) {
      const i = p * SLOTS + s;
      phase0[i] = (p / PLANES) * 0.6 + (s / SLOTS);
      raan[i] = (p / PLANES) * 360 - 180;
      batt[i] = 74 + Math.cos(p * 0.5 + s) * 14;
      tbias[i] = ((i * 13) % 7) - 3;
    }
    const cellVal = new Float32Array(N), battArr = new Float32Array(N), tempArr = new Float32Array(N);
    const computeArr = new Float32Array(N), eclArr = new Uint8Array(N), bandArr = new Uint8Array(N), linkArr = new Float32Array(N);

    // The selection that threads down the wall.
    let selPlane = 0;   // 0..71
    let selSlot = 0;    // 0..21
    const idxOf = (plane: number, slot: number) => plane * SLOTS + slot;

    type Snap = {
      sunlit: number; meanComputePct: number; fleetDrawMW: number; meanTemp: number;
      meanBattPct: number; solarPct: number; radMW: number; downlinkTbps: number;
      nominal: number; warning: number; critical: number; terminator: number;
    };

    function step(base: number, dtMs: number): Snap {
      const dtH = (dtMs / PERIOD_MS) * (95 / 60);
      let sunlit = 0, sumC = 0, sumT = 0, sumB = 0, sumSolar = 0, sumRad = 0, sumLink = 0, nN = 0, nW = 0, nC = 0;
      for (let i = 0; i < N; i++) {
        const p = (base + phase0[i]) % 1;
        const eclipse = p >= (1 - ECLIPSE_FRAC);
        eclArr[i] = eclipse ? 1 : 0;
        if (!eclipse) sunlit++;
        const sun = eclipse ? 0 : Math.sin((p / (1 - ECLIPSE_FRAC)) * Math.PI);
        const solarKw = eclipse ? 0 : clamp(230 * (0.45 + 0.55 * sun), 0, 240);
        const computeKw = clamp(108 + Math.sin((p + i * 0.13) * 6) * 10, 70, 150);
        const draw = computeKw + 8;
        batt[i] = clamp(batt[i] + (solarKw - draw) * dtH * 0.4, 30, 100);
        const eclipseRise = eclipse ? 9 * ((p - (1 - ECLIPSE_FRAC)) / ECLIPSE_FRAC) : 0;
        const temp = 14 + (computeKw - 108) / 150 * 10 + eclipseRise + tbias[i] * 0.6;
        const radKw = clamp(draw * (eclipse ? 0.6 : 1) * 0.9, 30, 160);
        const link = eclipse ? 0.42 : clamp(0.6 + Math.sin(p * 19 + i) * 0.3, 0, 1);
        const tB = temp >= 34 ? 2 : temp >= 29 ? 1 : 0;
        const bB = batt[i] <= 28 ? 2 : batt[i] <= 42 ? 1 : 0;
        const cB = computeKw >= 146 ? 2 : computeKw >= 138 ? 1 : 0;
        const worst = Math.max(tB, bB, cB);
        if (worst === 2) nC++; else if (worst === 1) nW++; else nN++;
        bandArr[i] = worst;
        cellVal[i] = worst === 2 ? 94 : worst === 1 ? 78 : 30 + (temp - 14) * 1.5;
        battArr[i] = batt[i]; tempArr[i] = temp; computeArr[i] = computeKw; linkArr[i] = link;
        sumC += computeKw; sumT += temp; sumB += batt[i]; sumSolar += solarKw; sumRad += radKw; sumLink += link;
      }
      return {
        sunlit, meanComputePct: (sumC / N / 150) * 100, fleetDrawMW: (sumC + N * 8) / 1000,
        meanTemp: sumT / N, meanBattPct: sumB / N, solarPct: (sumSolar / N / 150) * 100,
        radMW: (sumRad / N) * N / 1000, downlinkTbps: (sumLink / N) * N * 0.01,
        nominal: nN, warning: nW, critical: nC, terminator: (base + (1 - ECLIPSE_FRAC / 2)) % 1,
      };
    }

    const $ = (id: string) => document.getElementById(id);
    const set = (el: Element | null, a: string, v: string) => el?.setAttribute(a, v);
    const txt = (el: Element | null, v: string) => { if (el) el.textContent = v; };
    const pad2 = (n: number) => String(n).padStart(2, "0");

    const rollup = $("sc-rollup"), conLed = $("con-led"), mSun = $("m-sun"), mEcl = $("m-ecl"), mSel = $("m-sel");
    const aMatrix = $("a-matrix") as TalosMatrix | null, aTrack = $("a-track") as TalosGroundtrack | null;
    const aCompute = $("a-compute"), aKw = $("a-kw"), aTemp = $("a-temp");
    const aOnline = $("a-online"), aEcl = $("a-ecl"), aLink = $("a-link"), aMargin = $("a-margin");
    const bBatt = $("b-batt") as TalosHistogram | null, bTemp = $("b-temp") as TalosHistogram | null;
    const bSolar = $("b-solar"), bBattm = $("b-battm"), bRad = $("b-rad"), bTrend = $("b-trend");
    const m2Solar = $("m2-solar"), m2Soc = $("m2-soc"), bPlane = $("b-plane"), bPsoc = $("b-psoc"), bPtemp = $("b-ptemp");
    const cRing = $("c-ring") as TalosPlane | null, cLed = $("c-led"), cPlaneId = $("c-plane-id"), cPlaneId2 = $("c-plane-id2");
    const cNom = $("c-nom"), cEcl = $("c-ecl"), cDl = $("c-dl"), cLinks = $("c-links"), cTrend = $("c-trend");
    const dLoc = $("d-loc") as TalosMatrix | null, dOrb = $("d-orb") as (HTMLElement & { nodes: OrbitalNode[] }) | null;
    const dLed = $("d-led"), dName = $("d-name"), dState = $("d-state"), dTrend = $("d-trend");
    const dPhase = $("d-phase"), dCpu = $("d-cpu"), dTempEl = $("d-temp"), dBatt = $("d-batt"), dLocId = $("d-loc-id"), dNb = $("d-nb"), dNext = $("d-next");
    // Sticky mission spine + FLEET selected-plane rollup + Console-3 slot strip.
    const spinePlane = $("spine-plane"), spineSlot = $("spine-slot"), spineLens = $("spine-lens"), spineState = $("spine-state"), spineTemp = $("spine-temp"), spineBatt = $("spine-batt");
    const aPlId = $("a-pl-id"), aPlSoc = $("a-pl-soc"), aPlTemp = $("a-pl-temp");
    const cSlots = $("c-slots");
    // Build the 22 slot rows once; the loop updates their band dot + selected state.
    const slotRows: HTMLElement[] = [];
    if (cSlots) {
      for (let s = 0; s < SLOTS; s++) {
        const row = document.createElement("div");
        row.className = "vc-slot";
        row.innerHTML = `<span class="vc-slot__dot"></span><span class="vc-slot__id">S${pad2(s)}</span><span class="vc-slot__b">—</span>`;
        row.addEventListener("click", () => setSelection(selPlane, s));
        cSlots.appendChild(row);
        slotRows.push(row);
      }
    }
    // Console 5: 3D anatomy.
    const eCraft = $("e-craft") as (HTMLElement & { parts: Record<string, { band?: number }> }) | null;
    const eLed = $("e-led"), eName = $("e-name"), eWorst = $("e-worst");
    const eFocus = $("e-focus"), eFname = $("e-fname"), eFband = $("e-fband"), eFrole = $("e-frole"), eFval = $("e-fval"), eFunit = $("e-funit"), eFmeter = $("e-fmeter");
    const PART_LABEL: Record<string, string> = { bus: "Bus", gpu: "GPU / compute", solarL: "Solar wing L", solarR: "Solar wing R", radL: "Radiator L", radR: "Radiator R", antenna: "Downlink antenna" };
    const bandWord = (b: number) => (b === 2 ? "CRITICAL" : b === 1 ? "WARNING" : "NOMINAL");
    const bandColor = (b: number) => (b === 2 ? "var(--talos-danger)" : b === 1 ? "var(--talos-warning)" : "var(--talos-success)");
    // Per-subsystem telemetry: what each part actually reads, pulled live from the
    // selected sat's signals. role = what it does; pick = its current value + unit.
    type PartTele = { role: string; unit: string; max: number; pick: (i: number) => number; band: (i: number) => number };
    const TELE: Record<string, PartTele> = {
      bus:     { role: "Spacecraft bus — power & avionics backbone. Band tracks compute draw.", unit: "kW", max: 150, pick: (i) => computeArr[i] + 8, band: (i) => (computeArr[i] >= 146 ? 2 : computeArr[i] >= 138 ? 1 : 0) },
      gpu:     { role: "AI compute payload. The hot, busy heart — band is sustained compute load.", unit: "kW", max: 150, pick: (i) => computeArr[i], band: (i) => (computeArr[i] >= 146 ? 2 : computeArr[i] >= 138 ? 1 : 0) },
      solarL:  { role: "Port solar wing. Makes no power in eclipse — band reflects supply margin.", unit: "%", max: 100, pick: (i) => (eclArr[i] ? 0 : clamp((computeArr[i] / 150) * 110, 0, 100)), band: (i) => (eclArr[i] ? Math.max(1, batt[i] <= 28 ? 2 : 1) : 0) },
      solarR:  { role: "Starboard solar wing. Mirror of port; both feed the bus + battery.", unit: "%", max: 100, pick: (i) => (eclArr[i] ? 0 : clamp((computeArr[i] / 150) * 110, 0, 100)), band: (i) => (eclArr[i] ? Math.max(1, batt[i] <= 28 ? 2 : 1) : 0) },
      radL:    { role: "Port radiator. Dumps waste heat — band is core temperature.", unit: "°C", max: 45, pick: (i) => tempArr[i], band: (i) => (tempArr[i] >= 34 ? 2 : tempArr[i] >= 29 ? 1 : 0) },
      radR:    { role: "Starboard radiator. Thermal pair to port — band is core temperature.", unit: "°C", max: 45, pick: (i) => tempArr[i], band: (i) => (tempArr[i] >= 34 ? 2 : tempArr[i] >= 29 ? 1 : 0) },
      antenna: { role: "Downlink antenna. Ground/ISL contact — band is link quality.", unit: "%", max: 100, pick: (i) => linkArr[i] * 100, band: (i) => (linkArr[i] <= 0.3 ? 2 : linkArr[i] <= 0.5 ? 1 : 0) },
    };
    let focusedPart: string | null = null;
    // Selecting a subsystem LOCKS its live telemetry into the focus panel;
    // clicking it again (part:null) clears the lock.
    eCraft?.addEventListener("talos:part", (e) => {
      const part = (e as CustomEvent).detail.part as string | null;
      focusedPart = part;
      if (!part) {
        eFocus?.setAttribute("data-empty", "");
        txt(eFname, "SELECT A SUBSYSTEM");
        if (eFrole) eFrole.textContent = "Click a part on the model to lock its live telemetry here.";
        txt(eFval, "—"); txt(eFband, "—"); if (eFunit) eFunit.textContent = "";
        if (eFocus) (eFocus as HTMLElement).style.removeProperty("--_fc");
        return;
      }
      eFocus?.removeAttribute("data-empty");
      const t = TELE[part];
      txt(eFname, PART_LABEL[part] ?? part);
      if (eFrole) eFrole.textContent = t?.role ?? "";
      if (eFunit) eFunit.textContent = t?.unit ?? "";
      if (eFmeter && t) eFmeter.setAttribute("max", String(t.max));
    });

    // ── Selection wiring: fleet matrix → plane; plane ring → sat. ─────────────
    function setSelection(plane: number, slot: number) {
      selPlane = clamp(plane, 0, PLANES - 1);
      selSlot = clamp(slot, 0, SLOTS - 1);
      const tag = `P${pad2(selPlane)}·S${pad2(selSlot)}`;
      txt(mSel, tag);
      txt(bPlane, `P${pad2(selPlane)}`);
      txt(cPlaneId, pad2(selPlane)); txt(cPlaneId2, `P${pad2(selPlane)}`);
      txt(dName, `P${pad2(selPlane)}-S${pad2(selSlot)}`);
      txt(eName, `P${pad2(selPlane)}-S${pad2(selSlot)}`);
      txt(dLocId, `${pad2(selPlane)} / ${pad2(selSlot)}`);
      // Spine breadcrumb + FLEET selected-plane rollup id.
      txt(spinePlane, pad2(selPlane));
      txt(spineSlot, pad2(selSlot));
      txt(aPlId, `P${pad2(selPlane)}`);
      // Slot strip: mark the selected row.
      slotRows.forEach((r, s) => r.toggleAttribute("data-sel", s === selSlot));
      if (aMatrix) aMatrix.highlight = { col: selPlane };
      if (dLoc) dLoc.highlight = { index: idxOf(selPlane, selSlot) };
      if (cRing) cRing.setAttribute("plane-label", `P${pad2(selPlane)}`);
    }
    aMatrix?.addEventListener("talos:cell", (e) => {
      const { col, row } = (e as CustomEvent).detail;   // col = plane, row = slot
      setSelection(col, row);
    });
    cRing?.addEventListener("talos:sat", (e) => {
      setSelection(selPlane, (e as CustomEvent).detail.slot);
    });
    setSelection(0, 0);

    const gateways = [
      { lon: -122, lat: 37 }, { lon: -74, lat: 40 }, { lon: -47, lat: -23 }, { lon: 0, lat: 51 },
      { lon: 13, lat: 52 }, { lon: 28, lat: -26 }, { lon: 55, lat: 25 }, { lon: 77, lat: 13 },
      { lon: 121, lat: 31 }, { lon: 139, lat: 35 }, { lon: 151, lat: -34 }, { lon: 174, lat: -37 },
    ];

    let lastMatrix = 0, lastHist = 0;
    function frame(now: number) {
      const dtMs = now - (frame as any)._last || 16; (frame as any)._last = now;
      if (!(frame as any)._t0) (frame as any)._t0 = now;
      const base = ((now - (frame as any)._t0) % PERIOD_MS) / PERIOD_MS;
      const snap = step(base, dtMs);

      // ── Console 1: FLEET ──
      if (aMatrix && now - lastMatrix > 80) {
        lastMatrix = now;
        aMatrix.cells = cellVal;
        aMatrix.setAttribute("terminator", snap.terminator.toFixed(3));
        if (dLoc) dLoc.cells = cellVal;
      }
      if (aTrack) {
        const sats: { lon: number; lat: number; band: number }[] = [];
        for (let p = 0; p < PLANES; p += 2) for (let s = 0; s < SLOTS; s += 2) {
          const i = p * SLOTS + s;
          const ph = (base + phase0[i]) % 1, orbitAngle = ph * 360;
          const lat = INCL * Math.sin((orbitAngle * Math.PI) / 180);
          let lon = (raan[i] + orbitAngle * 4) % 360; if (lon > 180) lon -= 360;
          sats.push({ lon, lat, band: bandArr[i] });
        }
        aTrack.sats = sats;
        aTrack.gateways = gateways.map((g) => ({ ...g, active: sats.some((s) => Math.abs(s.lon - g.lon) < 14 && Math.abs(s.lat - g.lat) < 14) }));
      }
      set(aCompute, "value", snap.meanComputePct.toFixed(0));
      set(aKw, "value", snap.fleetDrawMW.toFixed(1));
      set(aTemp, "value", snap.meanTemp.toFixed(0));
      txt(aOnline, (N - snap.critical).toLocaleString());
      txt(aEcl, `${N - snap.sunlit}`);
      txt(aLink, `${snap.downlinkTbps.toFixed(1)} Tbps`);
      txt(aMargin, `+${clamp(snap.meanBattPct - 28, 0, 100).toFixed(0)}%`);
      txt(mSun, `${snap.sunlit}`); txt(mEcl, `${N - snap.sunlit}`);
      const chans: string[] = [];
      for (let k = 0; k < 40; k++) { const f = k / 40; chans.push(f < snap.critical / N ? "crit" : f < (snap.critical + snap.warning) / N ? "warn" : "ok"); }
      set(rollup, "channels", chans.join(","));
      set(conLed, "state", snap.critical > 0 ? "crit" : snap.warning > 0 ? "warn" : "ok");

      // ── Console 2: POWER (+ selected-plane figures) ──
      if (now - lastHist > 120) { lastHist = now; if (bBatt) bBatt.values = battArr; if (bTemp) bTemp.values = tempArr; }
      set(bSolar, "value", snap.solarPct.toFixed(0));
      set(bBattm, "value", snap.meanBattPct.toFixed(0));
      set(bRad, "value", snap.radMW.toFixed(1));
      set(bTrend, "value", snap.fleetDrawMW.toFixed(0));
      txt(m2Solar, `${snap.solarPct.toFixed(0)}%`); txt(m2Soc, `${snap.meanBattPct.toFixed(0)}%`);
      let pSoc = 0, pTemp = 0;
      for (let s = 0; s < SLOTS; s++) { const i = idxOf(selPlane, s); pSoc += battArr[i]; pTemp += tempArr[i]; }
      txt(bPsoc, `${(pSoc / SLOTS).toFixed(0)}%`); txt(bPtemp, `${(pTemp / SLOTS).toFixed(0)}°C`);
      // FLEET selected-plane mini-rollup (same sums).
      txt(aPlSoc, `${(pSoc / SLOTS).toFixed(0)}%`); txt(aPlTemp, `${(pTemp / SLOTS).toFixed(0)}°C`);

      // ── Console 3: PLANE (the selected plane's 22 sats) ──
      if (cRing) {
        const ring: { band: number; eclipse: boolean; selected: boolean }[] = [];
        let nom = 0, ecl = 0, dl = 0, pmSoc = 0;
        for (let s = 0; s < SLOTS; s++) {
          const i = idxOf(selPlane, s);
          ring.push({ band: bandArr[i], eclipse: !!eclArr[i], selected: s === selSlot });
          if (bandArr[i] === 0) nom++; if (eclArr[i]) ecl++; dl += linkArr[i]; pmSoc += battArr[i];
          // per-slot strip row: band dot colour + word + eclipse hint.
          const row = slotRows[s];
          if (row) {
            const dot = row.querySelector(".vc-slot__dot") as HTMLElement;
            const bw = row.querySelector(".vc-slot__b") as HTMLElement;
            const c = bandArr[i] === 2 ? "var(--talos-danger)" : bandArr[i] === 1 ? "var(--talos-warning)" : "var(--talos-success)";
            if (dot) dot.style.setProperty("--c", c);
            if (bw) bw.textContent = eclArr[i] ? "ECL" : bandArr[i] === 2 ? "CRIT" : bandArr[i] === 1 ? "WARN" : "OK";
          }
        }
        cRing.sats = ring;
        // Eclipse arc on the ring: the shadow occupies the tail of the orbit;
        // map each slot's eclipse to an arc fraction. Slot 0 = phase0[plane,0].
        const fi = idxOf(selPlane, 0);
        const planePhase = (base + phase0[fi]) % 1;
        cRing.setAttribute("eclipse-from", (((1 - ECLIPSE_FRAC) - planePhase + 1) % 1).toFixed(3));
        cRing.setAttribute("eclipse-to", ((1 - planePhase + 1) % 1).toFixed(3));
        txt(cNom, `${nom}/22`); txt(cEcl, `${ecl}/22`);
        txt(cDl, `${(dl * 0.4).toFixed(0)} Tbps`); txt(cLinks, `${(22 * 4 - ecl).toFixed(0)}`);
        set(cTrend, "value", (pmSoc / SLOTS).toFixed(0));
        set(cLed, "state", nom < 14 ? "warn" : "ok");
      }

      // ── Console 4: SATELLITE (focus + locator + real neighbours) ──
      const fi = idxOf(selPlane, selSlot);
      const ph = (base + phase0[fi]) % 1, eclipse = ph >= (1 - ECLIPSE_FRAC);
      // Real ISL neighbours: in-plane ±1 slot, cross-plane ±1 plane (same slot).
      const nbIdx = [
        fi,
        idxOf(selPlane, (selSlot + 1) % SLOTS),
        idxOf(selPlane, (selSlot - 1 + SLOTS) % SLOTS),
        idxOf((selPlane + 1) % PLANES, selSlot),
        idxOf((selPlane - 1 + PLANES) % PLANES, selSlot),
      ];
      if (dOrb) dOrb.nodes = nbIdx.map((i, k) => ({
        id: String(i), ring: k === 0 ? 1 : 2, value: cellVal[i], load: clamp(computeArr[i] / 150, 0.3, 1),
        rate: eclArr[i] ? 0.15 : 0.7, label: k === 0 ? "SAT" : k <= 2 ? `S${k}` : `P${k - 2}`,
      }));
      const fb = bandArr[fi] === 2 ? "crit" : bandArr[fi] === 1 ? "warn" : "ok";
      set(dLed, "state", fb);
      txt(dState, eclipse ? "ECLIPSE" : "SUNLIT");
      txt(dPhase, eclipse ? "ECLIPSE (shadow)" : "SUNLIT");
      txt(dCpu, `${computeArr[fi].toFixed(0)} kW`);
      txt(dTempEl, `${tempArr[fi].toFixed(1)} °C`);
      txt(dBatt, `${batt[fi].toFixed(0)} %`);
      txt(dNb, "2 in-plane · 2 cross-plane");
      txt(dNext, eclipse ? `${((1 - ph) * 95).toFixed(0)} min` : "in sunlight");
      set(dTrend, "value", tempArr[fi].toFixed(1));
      // Sticky spine status: the selected sat, live.
      txt(spineState, eclipse ? "ECLIPSE" : "SUNLIT");
      txt(spineTemp, `${tempArr[fi].toFixed(0)}°C`);
      txt(spineBatt, `${batt[fi].toFixed(0)}%`);

      // ── Console 5: ANATOMY (3D) — derive a per-subsystem band from the same
      //    selected-sat signals, then bind it to the 3D craft's emissive parts. ──
      const computeBand = computeArr[fi] >= 146 ? 2 : computeArr[fi] >= 138 ? 1 : 0;
      const thermBand = tempArr[fi] >= 34 ? 2 : tempArr[fi] >= 29 ? 1 : 0;
      const battBand = batt[fi] <= 28 ? 2 : batt[fi] <= 42 ? 1 : 0;
      const linkBand = linkArr[fi] <= 0.3 ? 2 : linkArr[fi] <= 0.5 ? 1 : 0;
      // solar wings: stressed when eclipsed AND battery is draining low.
      const solarBand = eclipse ? Math.max(1, battBand) : 0;
      const parts: Record<string, { band: number }> = {
        bus: { band: computeBand },
        gpu: { band: computeBand },
        solarL: { band: solarBand },
        solarR: { band: solarBand },
        radL: { band: thermBand },
        radR: { band: thermBand },
        antenna: { band: linkBand },
      };
      if (eCraft) {
        eCraft.parts = parts;
        eCraft.toggleAttribute("eclipse", eclipse);
      }
      // worst-band rail indicator + per-row band words.
      const worst = Math.max(computeBand, thermBand, solarBand, linkBand);
      set(eLed, "state", worst === 2 ? "crit" : worst === 1 ? "warn" : "ok");
      txt(eWorst, bandWord(worst));
      for (const id of Object.keys(parts)) {
        const el = $(`e-${id}`);
        if (el) {
          el.textContent = bandWord(parts[id].band);
          el.style.color =
            parts[id].band === 2 ? "var(--talos-danger)" : parts[id].band === 1 ? "var(--talos-warning)" : "var(--talos-muted-foreground)";
        }
      }
      // Locked focus panel: keep the selected subsystem's value live each frame.
      if (focusedPart && TELE[focusedPart]) {
        const t = TELE[focusedPart];
        const val = t.pick(fi), b = t.band(fi);
        txt(eFval, t.unit === "%" || t.unit === "°C" ? val.toFixed(0) : val.toFixed(0));
        txt(eFband, bandWord(b));
        if (eFocus) (eFocus as HTMLElement).style.setProperty("--_fc", bandColor(b));
        if (eFmeter) {
          eFmeter.setAttribute("value", String(val.toFixed(1)));
          // colour the meter band via warn/crit at the part's thresholds
          if (focusedPart === "radL" || focusedPart === "radR") { eFmeter.setAttribute("warn", "29"); eFmeter.setAttribute("crit", "34"); }
          else if (focusedPart === "antenna") { eFmeter.setAttribute("warn", "50"); eFmeter.setAttribute("crit", "30"); eFmeter.setAttribute("invert", ""); }
          else if (focusedPart === "bus" || focusedPart === "gpu") { eFmeter.setAttribute("warn", "138"); eFmeter.setAttribute("crit", "146"); }
        }
      }

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    // ── "You are here": light the rail node + spine lens for the console in view.
    //    Read-only; never touches the model or the selection.
    const nodes = Array.from(document.querySelectorAll<HTMLElement>(".ops-node"));
    const lenses = Array.from(document.querySelectorAll<HTMLElement>("[id^=lens-]"));
    if (nodes.length && lenses.length && "IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            const n = e.target.id.split("-")[1]; // "lens-3" → "3"
            nodes.forEach((node) => node.toggleAttribute("data-active", node.dataset.lens === n));
            txt(spineLens, n);
          }
        },
        { rootMargin: "-120px 0px -55% 0px" },
      );
      lenses.forEach((l) => io.observe(l));
    }
  </script>
</Landing>
