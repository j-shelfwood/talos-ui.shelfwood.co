---
import Landing from "../layouts/Landing.astro";
import GlassPanel from "@shelfwood/talos-ui/astro/GlassPanel.astro";
import Button from "@shelfwood/talos-ui/astro/Button.astro";
---

<Landing title="Showcase — Talos UI">
  <!-- HERO -->
  <header class="stack">
    <div class="row" style="justify-content:space-between">
      <span class="eyebrow">// Component showcase</span>
      <span class="row" style="gap:.5rem">
        <span class="dot"></span>
        <span class="eyebrow">v0.0.1</span>
      </span>
    </div>
    <h1 style="font-size:clamp(2.25rem,5vw,4rem);letter-spacing:.005em;line-height:1.05">
      Panels, buttons,<br />notched components
    </h1>
    <p class="muted" style="max-width:46ch;font-size:1.05rem">
      The chrome layer — chamfered hairline panels, Oxanium type, and composable
      notched-panel web components. For the live instruments, see the
      <a class="doclink" href="/" style="border-bottom:1px solid var(--talos-accent)">home console</a>;
      for the CSS primitive reference, the <a class="doclink" href="/gallery/" style="border-bottom:1px solid var(--talos-accent)">gallery</a>.
    </p>
    <div class="row" style="margin-top:.5rem">
      <Button href="/docs/getting-started/">Get started</Button>
      <Button variant="secondary" href="/gallery/">Gallery</Button>
      <Button variant="ghost" href="https://github.com/shelfwood">Source</Button>
    </div>
  </header>

  <!-- PANELS -->
  <section class="stack">
    <span class="eyebrow">// 01 — Panels</span>
    <div class="grid bento-stagger">
      <GlassPanel as="a" href="/docs/components/" class="pad">
        <h3 style="font-size:1.1rem">Glass panel</h3>
        <p class="muted">Two-layer chamfer hairline. Hover for lift, sheen, brackets.</p>
      </GlassPanel>
      <GlassPanel as="a" href="/docs/tokens/" class="pad">
        <h3 style="font-size:1.1rem">Tokens</h3>
        <p class="muted">Every decision is a <code>--talos-*</code> property.</p>
      </GlassPanel>
      <GlassPanel as="a" href="/docs/web-components/" class="pad">
        <h3 style="font-size:1.1rem">Web components</h3>
        <p class="muted">Composable notched panels via custom elements.</p>
      </GlassPanel>
      <GlassPanel as="a" href="/docs/blade/" class="pad">
        <h3 style="font-size:1.1rem">Laravel / Blade</h3>
        <p class="muted">CSS + a module script. No Composer package.</p>
      </GlassPanel>
    </div>
  </section>

  <!-- BUTTONS -->
  <section class="stack">
    <span class="eyebrow">// 02 — Buttons</span>
    <div class="row">
      <Button>Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="ghost">Ghost</Button>
      <Button size="sm">Small</Button>
      <Button size="lg">Large</Button>
    </div>
  </section>

  <!-- WEB COMPONENTS -->
  <section class="stack">
    <span class="eyebrow">// 03 — Notched panels (web components)</span>
    <div class="row" style="gap:2rem;align-items:flex-start">
      <talos-panel panel-width="360" panel-height="200" animate>
        <talos-corner edge="top-right" radius="24"></talos-corner>
        <talos-corner edge="bottom-left" radius="24"></talos-corner>
        <talos-notch edge="top" width="90" depth="14"></talos-notch>
        <div class="pad">
          <span class="eyebrow">SYS://PANEL</span>
          <h3 style="font-size:1.05rem;margin-top:.5rem">Corners + top notch</h3>
        </div>
      </talos-panel>

      <talos-panel panel-width="360" panel-height="200">
        <talos-notch edge="left" width="70" depth="16"></talos-notch>
        <talos-notch edge="right" width="70" depth="16"></talos-notch>
        <div class="pad">
          <span class="eyebrow">SYS://PANEL</span>
          <h3 style="font-size:1.05rem;margin-top:.5rem">Side notches</h3>
        </div>
      </talos-panel>
    </div>
  </section>

  <!-- LIVE COMPONENTS — feedback / data / nav families -->
  <section class="stack">
    <span class="eyebrow">// 04 — Live components</span>

    <div class="row" style="gap:.6rem">
      <span class="talos-badge talos-badge--success talos-badge--dot">Online</span>
      <span class="talos-badge talos-badge--info">Build 0.0.1</span>
      <span class="talos-badge talos-badge--warning">Beta</span>
      <span class="talos-badge talos-badge--neutral">MIT</span>
    </div>

    <div class="grid" style="margin-top:.5rem">
      <div class="talos-stat">
        <span class="talos-stat__label">Components</span>
        <span class="talos-stat__value">48</span>
        <span class="talos-stat__delta">CSS + WC</span>
      </div>
      <div class="talos-stat">
        <span class="talos-stat__label">Token vars</span>
        <span class="talos-stat__value">120+</span>
        <span class="talos-stat__delta">retheme on :root</span>
      </div>
      <div class="talos-stat">
        <span class="talos-stat__label">Bundle</span>
        <span class="talos-stat__value">0 JS</span>
        <span class="talos-stat__delta">CSS-only core</span>
      </div>
    </div>

    <div class="talos-alert talos-alert--info" role="status" style="margin-top:.5rem">
      <span class="talos-alert__icon">◆</span>
      <div>
        <div class="talos-alert__title">Dogfooded</div>
        <div class="talos-alert__body">
          This page and the docs are built from Talos UI itself — every panel,
          badge, stat card, and code block is a library component.
        </div>
      </div>
    </div>

    <div class="talos-tabs talos-tabs--segmented" role="tablist" style="margin-top:.75rem">
      <button class="talos-tab" role="tab" aria-selected="true">Astro</button>
      <button class="talos-tab" role="tab" aria-selected="false">Web components</button>
      <button class="talos-tab" role="tab" aria-selected="false">Blade</button>
    </div>
  </section>

  <footer class="row muted" style="justify-content:space-between;border-top:1px solid var(--talos-border);padding-top:1.5rem">
    <span class="eyebrow">SYS://TALOS-UI</span>
    <span class="eyebrow">MIT — Shelfwood ◢</span>
  </footer>

  <script>
    // Minimal segmented-tab toggle so the showcase strip is interactive.
    document.querySelectorAll<HTMLElement>('.talos-tabs[role="tablist"]').forEach((list) => {
      list.addEventListener("click", (e) => {
        const tab = (e.target as HTMLElement).closest('[role="tab"]');
        if (!tab) return;
        list.querySelectorAll('[role="tab"]').forEach((t) =>
          t.setAttribute("aria-selected", String(t === tab)),
        );
      });
    });
  </script>
</Landing>
