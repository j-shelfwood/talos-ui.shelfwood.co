---
import Landing from "../layouts/Landing.astro";
import GlassPanel from "@j_shelfwood/talos-ui/astro/GlassPanel.astro";
import Button from "@j_shelfwood/talos-ui/astro/Button.astro";
import TitlePanel from "@j_shelfwood/talos-ui/astro/TitlePanel.astro";
import ServicePanel from "@j_shelfwood/talos-ui/astro/ServicePanel.astro";
import ToolkitPanel from "@j_shelfwood/talos-ui/astro/ToolkitPanel.astro";
import ProjectPanel from "@j_shelfwood/talos-ui/astro/ProjectPanel.astro";
---

<Landing title="Showcase" navActive="showcase">
  <!-- HERO -->
  <header class="talos-stack">
    <div class="talos-row" style="justify-content:space-between">
      <span class="talos-eyebrow">// Component showcase</span>
      <span class="talos-row" style="gap:.5rem">
        <span class="talos-dot"></span>
        <span class="talos-eyebrow">v0.1.0</span>
      </span>
    </div>
    <h1 style="font-size:clamp(2.25rem,5vw,4rem);letter-spacing:.005em;line-height:1.05">
      Panels, buttons,<br />notched components
    </h1>
    <p class="talos-muted" style="max-width:46ch;font-size:1.05rem">
      The chrome layer — chamfered hairline panels, Oxanium type, and composable
      notched-panel web components. For the live instruments, see the
      <a class="doclink" href="/" style="border-bottom:1px solid var(--talos-accent)">home console</a>;
      for the CSS primitive reference, the <a class="doclink" href="/gallery/" style="border-bottom:1px solid var(--talos-accent)">gallery</a>.
    </p>
    <div class="talos-row" style="margin-top:.5rem">
      <Button href="/docs/getting-started/">Get started</Button>
      <Button variant="secondary" href="/gallery/">Gallery</Button>
      <Button variant="ghost" href="https://github.com/shelfwood">Source</Button>
    </div>
  </header>

  <!-- PANELS -->
  <section class="talos-stack">
    <span class="talos-eyebrow">// 01 — Panels</span>
    <div class="talos-grid-auto bento-stagger">
      <GlassPanel as="a" href="/docs/components/" class="talos-pad">
        <h3 style="font-size:1.1rem">Glass panel</h3>
        <p class="talos-muted">Two-layer chamfer hairline. Hover for lift, sheen, brackets.</p>
      </GlassPanel>
      <GlassPanel as="a" href="/docs/tokens/" class="talos-pad">
        <h3 style="font-size:1.1rem">Tokens</h3>
        <p class="talos-muted">Every decision is a <code>--talos-*</code> property.</p>
      </GlassPanel>
      <GlassPanel as="a" href="/docs/web-components/" class="talos-pad">
        <h3 style="font-size:1.1rem">Web components</h3>
        <p class="talos-muted">Composable notched panels via custom elements.</p>
      </GlassPanel>
      <GlassPanel as="a" href="/docs/blade/" class="talos-pad">
        <h3 style="font-size:1.1rem">Laravel / Blade</h3>
        <p class="talos-muted">CSS + a module script. No Composer package.</p>
      </GlassPanel>
    </div>
  </section>

  <!-- BUTTONS -->
  <section class="talos-stack">
    <span class="talos-eyebrow">// 02 — Buttons</span>
    <div class="talos-row">
      <Button>Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="ghost">Ghost</Button>
      <Button size="sm">Small</Button>
      <Button size="lg">Large</Button>
    </div>
  </section>

  <!-- WEB COMPONENTS -->
  <section class="talos-stack">
    <span class="talos-eyebrow">// 03 — Notched panels (web components)</span>
    <div class="talos-row" style="gap:2rem;align-items:flex-start">
      <talos-panel panel-width="360" panel-height="200" animate>
        <talos-corner edge="top-right" radius="24"></talos-corner>
        <talos-corner edge="bottom-left" radius="24"></talos-corner>
        <talos-notch edge="top" width="90" depth="14"></talos-notch>
        <div class="talos-pad">
          <span class="talos-eyebrow">SYS://PANEL</span>
          <h3 style="font-size:1.05rem;margin-top:.5rem">Corners + top notch</h3>
        </div>
      </talos-panel>

      <talos-panel panel-width="360" panel-height="200">
        <talos-notch edge="left" width="70" depth="16"></talos-notch>
        <talos-notch edge="right" width="70" depth="16"></talos-notch>
        <div class="talos-pad">
          <span class="talos-eyebrow">SYS://PANEL</span>
          <h3 style="font-size:1.05rem;margin-top:.5rem">Side notches</h3>
        </div>
      </talos-panel>
    </div>
  </section>

  <!-- LIVE COMPONENTS — feedback / data / nav families -->
  <section class="talos-stack">
    <span class="talos-eyebrow">// 04 — Live components</span>

    <div class="talos-row" style="gap:.6rem">
      <span class="talos-badge talos-badge--success talos-badge--dot">Online</span>
      <span class="talos-badge talos-badge--info">Build 0.1.0</span>
      <span class="talos-badge talos-badge--warning">Beta</span>
      <span class="talos-badge talos-badge--neutral">MIT</span>
    </div>

    <div class="talos-grid-auto" style="margin-top:.5rem">
      <div class="talos-stat">
        <span class="talos-stat__label">Components</span>
        <span class="talos-stat__value">48</span>
        <span class="talos-stat__delta">CSS + WC</span>
      </div>
      <div class="talos-stat">
        <span class="talos-stat__label">Token vars</span>
        <span class="talos-stat__value">120+</span>
        <span class="talos-stat__delta">retheme on :root</span>
      </div>
      <div class="talos-stat">
        <span class="talos-stat__label">Bundle</span>
        <span class="talos-stat__value">0 JS</span>
        <span class="talos-stat__delta">CSS-only core</span>
      </div>
    </div>

    <div class="talos-alert talos-alert--info" role="status" style="margin-top:.5rem">
      <span class="talos-alert__icon">◆</span>
      <div>
        <div class="talos-alert__title">Dogfooded</div>
        <div class="talos-alert__body">
          This page and the docs are built from Talos UI itself — every panel,
          badge, stat card, and code block is a library component.
        </div>
      </div>
    </div>

    <div class="talos-tabs talos-tabs--segmented" role="tablist" style="margin-top:.75rem">
      <button class="talos-tab" role="tab" aria-selected="true">Astro</button>
      <button class="talos-tab" role="tab" aria-selected="false">Web components</button>
      <button class="talos-tab" role="tab" aria-selected="false">Blade</button>
    </div>
  </section>

  <!-- INTERACTION — pointer affordances + decode-on-change -->
  <section class="talos-stack">
    <span class="talos-eyebrow">// 05 — Interaction</span>
    <p class="talos-muted" style="max-width:52ch">
      Pointer affordances bound to the same law as the instruments: the sheen
      tracks pointer presence, the activity edge spins at a rate, the readout
      decodes when its value changes.
    </p>

    <div class="talos-row" style="gap:2rem;align-items:flex-start;flex-wrap:wrap">
      <talos-sheen>
        <div class="glass-panel interactive-panel" style="width:260px;height:130px">
          <div class="glass-panel-content talos-pad">
            <span class="talos-eyebrow">SHEEN</span>
            <h3 style="font-size:1.05rem;margin-top:.4rem">Pointer-tracked</h3>
            <p class="talos-muted" style="font-size:.85rem">Move across me.</p>
          </div>
        </div>
      </talos-sheen>

      <div class="glass-panel activity-edge" id="sc-activity" style="--talos-rate:.5;width:260px;height:130px">
        <div class="glass-panel-content talos-pad">
          <span class="talos-eyebrow">ACTIVITY EDGE</span>
          <h3 style="font-size:1.05rem;margin-top:.4rem">Rate-bound ring</h3>
          <p class="talos-muted" style="font-size:.85rem">Speed = throughput.</p>
        </div>
      </div>

      <div class="talos-row" style="gap:2rem;align-items:center">
        <talos-readout id="sc-readout" value="1042" unit="req/s" label="Ingest" warn="2000" crit="4000"></talos-readout>
      </div>
    </div>
  </section>

  <section class="talos-stack">
    <span class="talos-eyebrow">// Panel composition</span>
    <p class="talos-muted" style="max-width:60ch">
      The same chamfered chrome, composed into a bento mosaic — title, service,
      toolkit, and project panels share one outline language.
    </p>
    <div class="talos-grid bento-stagger" style="margin-top:.5rem">
      <TitlePanel
        class="col-span-12"
        title="Component library"
        subtitle="Every panel is the same chamfered chrome — composed into a bento mosaic."
      />

      <ServicePanel
        class="col-span-12 lg:col-span-6"
        title="Design systems"
        description="Token-driven, framework-agnostic UI that scales across Astro and Laravel."
        features={[
          { title: "Plain-CSS core", description: "No Tailwind required to consume the look." },
          { title: "Web components", description: "Composable notched panels via custom elements." },
          { title: "Astro wrappers", description: "Ergonomic .astro components for the common cases." },
        ]}
      />

      <ToolkitPanel
        class="col-span-12 lg:col-span-6"
        groups={[
          { level: "Expert", emphasis: "high", items: ["Astro", "TypeScript", "CSS", "Laravel", "Bun"] },
          { level: "Working", emphasis: "low", items: ["Web Components", "Vite", "PHP", "SQLite"] },
        ]}
      />

      <ProjectPanel
        class="col-span-12 md:col-span-4"
        title="talos-ui"
        description="This design system — monochrome HUD chrome packaged for reuse."
        tags={["css", "astro"]}
        href="/"
      />
      <ProjectPanel
        class="col-span-12 md:col-span-4"
        title="tesseract-dash"
        description="Hardware telemetry dashboard — rings, sparklines, scatter."
        tags={["dashboard", "canvas"]}
        href="https://github.com/shelfwood"
        external
      />
      <ProjectPanel
        class="col-span-12 md:col-span-4"
        title="shelfwood.co"
        description="The studio site — origin of the refined monochrome direction."
        tags={["astro"]}
        href="https://shelfwood.co"
        external
      />
    </div>
  </section>

  <footer class="talos-row talos-muted" style="justify-content:space-between;border-top:1px solid var(--talos-border);padding-top:1.5rem">
    <span class="talos-eyebrow">SYS://TALOS-UI</span>
    <span class="talos-eyebrow">MIT — Shelfwood ◢</span>
  </footer>

  <script>
    // Minimal segmented-tab toggle so the showcase strip is interactive.
    document.querySelectorAll<HTMLElement>('.talos-tabs[role="tablist"]').forEach((list) => {
      list.addEventListener("click", (e) => {
        const tab = (e.target as HTMLElement).closest('[role="tab"]');
        if (!tab) return;
        list.querySelectorAll('[role="tab"]').forEach((t) =>
          t.setAttribute("aria-selected", String(t === tab)),
        );
      });
    });

    // Drive the interaction demos from a tiny pseudo-telemetry loop so the
    // readout decodes on real value changes and the activity edge varies rate —
    // the same "motion is data" contract the home console runs at full scale.
    const readout = document.getElementById("sc-readout");
    const activity = document.getElementById("sc-activity");
    let ingest = 1042;
    setInterval(() => {
      ingest = Math.max(200, Math.round(ingest + (Math.random() - 0.45) * 600));
      readout?.setAttribute("value", String(ingest));
      // rate 0..1 from the same signal: more ingest → faster ring
      activity?.style.setProperty("--talos-rate", (Math.min(ingest, 4000) / 4000).toFixed(2));
    }, 1800);
  </script>
</Landing>
