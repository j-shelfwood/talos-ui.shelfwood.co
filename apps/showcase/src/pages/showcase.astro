    }
    .sc-console { height: auto; border: 1px solid var(--talos-hud-edge, hsl(0 0% 100% / 0.18)); border-radius: 4px; overflow: hidden; }
    /* The pack console reserves a right "aside" grid column we don't use — every
       console drives its own internal view-* grid inside the scope. Collapse the
       console to a single full-width column so the scope fills the card (no dead
       right third) and rail/status span the full width. */
    .sc-console {
      grid-template-areas: "rail" "scope" "status";
