---
// Shared persistent top nav — fixed pill that collapses on scroll. Consumed by
// Landing.astro (showcase, gallery) and DocsShell.astro so every non-hero page
// has a Home affordance and a consistent route set. The 3D hero (index.astro)
// keeps its own bespoke HUD nav by design.
//
// The .talos-navbar / .talos-nav-link primitives live HERE (is:global below),
// not in the design system: this is site-specific marketing chrome, not
// reusable instrument-library surface. The pack dropped its prose/marketing
// module (talos-blog) to match the manifesto — see talos-ui PHILOSOPHY.md.
import GlassPanel from "@j_shelfwood/talos-ui/astro/GlassPanel.astro";
import BrandMark from "@j_shelfwood/talos-ui/astro/BrandMark.astro";

interface Props {
  /** Collection id / route key of the current page, for active state. */
  active?: string;
}
const { active } = Astro.props;

const links = [
  { label: "Home", href: "/", key: "home" },
  { label: "Showcase", href: "/showcase/", key: "showcase" },
  { label: "Gallery", href: "/gallery/", key: "gallery" },
  { label: "Docs", href: "/docs/getting-started/", key: "docs" },
];
const pathname = Astro.url.pathname;
const isActive = (l: (typeof links)[number]) =>
  active === l.key ||
  (l.href !== "/" && pathname.startsWith(l.href)) ||
  (l.key === "home" && pathname === "/");
---

<header class="talos-navbar" id="site-navbar" data-compact="false">
  <GlassPanel class="talos-navbar-pill glass-panel--navbar-dense" style="overflow:visible">
    <div class="talos-navbar-inner">
      <a class="talos-nav-link talos-nav-brand" href="/" aria-label="Home">
        <BrandMark />
      </a>
      <span class="talos-navbar-sep" aria-hidden="true"></span>
      <nav class="site-nav-links">
        {
          links
            .filter((l) => l.key !== "home")
            .map((l) => (
              <a
                class="talos-nav-link"
                href={l.href}
                aria-current={isActive(l) ? "page" : undefined}
                data-active={isActive(l) ? "true" : undefined}
              >
                <span class="talos-nav-text">{l.label}</span>
              </a>
            ))
        }
      </nav>
    </div>
  </GlassPanel>
</header>

<script>
  const nav = document.getElementById("site-navbar");
  const onScroll = () =>
    nav?.setAttribute("data-compact", String(window.scrollY > 48));
  addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>

<style>
  .site-nav-links {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    /* Collapses to a zero-width track in compact (see is:global rule below) —
       max-width animates so the pill reclaims the space, not just hides it. */
    overflow: hidden;
    transition: max-width 0.4s var(--talos-ease-out);
  }
  .talos-nav-link[data-active="true"] {
    color: var(--talos-foreground);
  }
</style>

<!-- Marketing navbar primitives — site-owned (see header comment). Global
     because they target the .talos-navbar markup above, not scoped classes. -->
<style is:global>
  .talos-navbar {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    padding: 1rem;
    display: flex;
    justify-content: center;
  }
  /* Auto-width pill: hugs its contents (no forced 600px void). Centered by the
     fixed header's justify-content. */
  .talos-navbar-pill {
    width: auto;
    max-width: calc(100vw - 2rem);
    padding: 0.6rem 1.5rem;
    transition: padding 0.35s var(--talos-ease-out);
  }
  /* HUD notch in the pill's top edge — a centered trapezoidal bite, the
     <talos-notch> motif applied to the container (distinct from the logomark's
     chamfer). Overrides GlassPanel's chamfer clip-path on BOTH layers (host
     outline + ::before fill) with one shared 8-point polygon: the two chamfer
     corners PLUS the top-centre notch. --_ch is the corner chamfer; --_nw/--_nd
     the notch half-width / depth. */
  .talos-navbar-pill {
    --_ch: 14px;
    --_nw: 22px;
    --_nd: 7px;
    --_notch-poly:
      0 0,
      calc(50% - var(--_nw)) 0,
      calc(50% - var(--_nw) + var(--_nd)) var(--_nd),
      calc(50% + var(--_nw) - var(--_nd)) var(--_nd),
      calc(50% + var(--_nw)) 0,
      calc(100% - var(--_ch)) 0,
      100% var(--_ch),
      100% 100%,
      var(--_ch) 100%,
      0 calc(100% - var(--_ch));
    clip-path: polygon(var(--_notch-poly));
  }
  .talos-navbar-pill::before {
    clip-path: polygon(var(--_notch-poly)) !important;
  }
  /* Single dense row: brand · hairline separator · links. No flex:1 spread —
     contents sit close together, the pill is only as wide as it needs to be. */
  .talos-navbar-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 2.5rem;
    transition: gap 0.4s var(--talos-ease-out);
  }
  /* A hairline tick between brand and nav — HUD divider, not dead space. */
  .talos-navbar-sep {
    width: 1px;
    align-self: stretch;
    margin: 0.4rem 0;
    background: var(--talos-edge-default, hsl(0 0% 100% / 0.18));
    transition: width 0.4s var(--talos-ease-out), opacity 0.35s var(--talos-ease-out);
  }
  .talos-nav-brand { font-weight: 500; color: var(--talos-foreground); }

  /* Compact (scrolled): tighten padding + collapse the nav-LINK labels. The
     brand persists (see .nav-brand-label note below) so the pill never empties. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-navbar-pill {
    padding: 0.5rem 1.1rem;
  }
  /* When links collapse, drop the separator too so the compact pill is just the
     brand — no orphan tick floating beside it. Collapse its WIDTH + margins (not
     just opacity): an opacity:0 tick still reserves its 1px flex track, which —
     with the inner gap on both sides — left ~145px of dead space to the brand's
     right and made the pill read as left-weighted. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-navbar-sep {
    opacity: 0;
    width: 0;
    margin-inline: 0;
  }
  /* Brand is the only visible child once links + separator collapse — zero the
     inner gap so no phantom 1.5rem track trails the brand. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-navbar-inner {
    gap: 0;
  }
  /* Collapse the nav-links track itself, not just its text: max-width:0 reclaims
     the ~48px the dot-gaps + inter-link gap held even with labels hidden. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .site-nav-links {
    max-width: 0;
  }
  .talos-nav-text {
    white-space: nowrap;
    transition: opacity 0.4s var(--talos-ease-out), max-width 0.4s var(--talos-ease-out);
  }
  /* The brand label is NOT a .talos-nav-text, so the compact collapse below
     never touches it — "● TALOS UI" stays put as the home affordance and the
     collapsed pill is never an empty box. (Earlier attempts to exempt it via a
     :not() or a re-show rule were silently dropped by the CSS minifier; keeping
     the brand out of the collapsed class entirely needs no exemption rule.) */
  /* Compact: collapse the nav-LINK labels only. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-nav-text {
    opacity: 0;
    max-width: 0;
    overflow: hidden;
  }
  /* Compact brand: drop the wordmark to the Notch-T mark alone — the two-size
     lockup (full wordmark expanded, mark-only collapsed). The mark always
     persists so the pill never empties. */
  .talos-brand-word {
    transition: opacity 0.4s var(--talos-ease-out), max-width 0.4s var(--talos-ease-out);
  }
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-brand-word {
    opacity: 0;
    max-width: 0;
    margin-right: 0;
    overflow: hidden;
  }
  /* Zero the lockup's own mark↔word gap in compact, else the collapsed (zero-
     width) wordmark still leaves its 0.55rem track and the pill won't hug the
     lone mark — same flex-track trap as the nav-links collapse above. */
  .talos-brand {
    transition: gap 0.4s var(--talos-ease-out);
  }
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-brand {
    gap: 0;
  }
  .talos-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--talos-font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: var(--talos-tracking-hud-tight);
    color: var(--talos-muted-foreground);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .talos-nav-link:hover { color: var(--talos-foreground); }
</style>
