---
// Shared persistent top nav — fixed pill that collapses on scroll. Consumed by
// Landing.astro (showcase, gallery) and DocsShell.astro so every non-hero page
// has a Home affordance and a consistent route set. The 3D hero (index.astro)
// keeps its own bespoke HUD nav by design.
//
// The .talos-navbar / .talos-nav-link primitives live HERE (is:global below),
// not in the design system: this is site-specific marketing chrome, not
// reusable instrument-library surface. The pack dropped its prose/marketing
// module (talos-blog) to match the manifesto — see talos-ui PHILOSOPHY.md.
import GlassPanel from "@j_shelfwood/talos-ui/astro/GlassPanel.astro";

interface Props {
  /** Collection id / route key of the current page, for active state. */
  active?: string;
}
const { active } = Astro.props;

const links = [
  { label: "Home", href: "/", key: "home" },
  { label: "Showcase", href: "/showcase/", key: "showcase" },
  { label: "Gallery", href: "/gallery/", key: "gallery" },
  { label: "Docs", href: "/docs/getting-started/", key: "docs" },
];
const pathname = Astro.url.pathname;
const isActive = (l: (typeof links)[number]) =>
  active === l.key ||
  (l.href !== "/" && pathname.startsWith(l.href)) ||
  (l.key === "home" && pathname === "/");
---

<header class="talos-navbar" id="site-navbar" data-compact="false">
  <GlassPanel class="talos-navbar-pill glass-panel--navbar-dense" style="overflow:visible">
    <div class="talos-navbar-inner">
      <a class="talos-nav-link talos-nav-brand" href="/" aria-label="Home">
        <span class="talos-dot"></span>
        <span class="nav-brand-label">Talos&nbsp;UI</span>
      </a>
      <span class="talos-navbar-sep" aria-hidden="true"></span>
      <nav class="site-nav-links">
        {
          links
            .filter((l) => l.key !== "home")
            .map((l) => (
              <a
                class="talos-nav-link"
                href={l.href}
                aria-current={isActive(l) ? "page" : undefined}
                data-active={isActive(l) ? "true" : undefined}
              >
                <span class="talos-nav-text">{l.label}</span>
              </a>
            ))
        }
      </nav>
    </div>
  </GlassPanel>
</header>

<script>
  const nav = document.getElementById("site-navbar");
  const onScroll = () =>
    nav?.setAttribute("data-compact", String(window.scrollY > 48));
  addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>

<style>
  .site-nav-links {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
  }
  .talos-nav-link[data-active="true"] {
    color: var(--talos-foreground);
  }
</style>

<!-- Marketing navbar primitives — site-owned (see header comment). Global
     because they target the .talos-navbar markup above, not scoped classes. -->
<style is:global>
  .talos-navbar {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    padding: 1rem;
    display: flex;
    justify-content: center;
  }
  /* Auto-width pill: hugs its contents (no forced 600px void). Centered by the
     fixed header's justify-content. */
  .talos-navbar-pill {
    width: auto;
    max-width: calc(100vw - 2rem);
    padding: 0.6rem 1.5rem;
    transition: padding 0.35s var(--talos-ease-out);
  }
  /* Single dense row: brand · hairline separator · links. No flex:1 spread —
     contents sit close together, the pill is only as wide as it needs to be. */
  .talos-navbar-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 2.5rem;
  }
  /* A hairline tick between brand and nav — HUD divider, not dead space. */
  .talos-navbar-sep {
    width: 1px;
    align-self: stretch;
    margin: 0.4rem 0;
    background: var(--talos-edge-default, hsl(0 0% 100% / 0.18));
  }
  .talos-nav-brand { font-weight: 500; color: var(--talos-foreground); }

  /* Compact (scrolled): tighten padding + collapse the nav-LINK labels. The
     brand persists (see .nav-brand-label note below) so the pill never empties. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-navbar-pill {
    padding: 0.5rem 1.1rem;
  }
  /* When links collapse, drop the separator too so the compact pill is just the
     brand — no orphan tick floating beside it. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-navbar-sep {
    opacity: 0;
  }
  .talos-nav-text {
    white-space: nowrap;
    transition: opacity 0.4s var(--talos-ease-out), max-width 0.4s var(--talos-ease-out);
  }
  /* The brand label is NOT a .talos-nav-text, so the compact collapse below
     never touches it — "● TALOS UI" stays put as the home affordance and the
     collapsed pill is never an empty box. (Earlier attempts to exempt it via a
     :not() or a re-show rule were silently dropped by the CSS minifier; keeping
     the brand out of the collapsed class entirely needs no exemption rule.) */
  .nav-brand-label { white-space: nowrap; }
  /* Compact: collapse the nav-LINK labels only. */
  .talos-navbar[data-compact="true"]:not(.toc-expanded) .talos-nav-text {
    opacity: 0;
    max-width: 0;
    overflow: hidden;
  }
  .talos-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--talos-font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: var(--talos-tracking-hud-tight);
    color: var(--talos-muted-foreground);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .talos-nav-link:hover { color: var(--talos-foreground); }
</style>
