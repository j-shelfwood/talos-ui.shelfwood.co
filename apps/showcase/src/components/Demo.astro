---
// Live-preview surface for docs pages (rendered inside DocsShell's .docs-prose).
// Pulls in the full talos.css layer so component demos render styled. The
// `.not-content` class on the wrapper is the prose opt-out boundary — DocsShell
// resets the leaking prose rules for anything under .docs-prose .not-content.
import "@j_shelfwood/talos-ui/talos.css";

interface Props {
  /** Optional label override; defaults to "PREVIEW". */
  label?: string;
}
const { label = "PREVIEW" } = Astro.props;
---

<div class="talos-demo not-content">
  <span class="talos-demo__label">{label}</span>
  <div class="talos-demo__surface">
    <slot />
  </div>
</div>

<style>
  /* The .not-content wrapper opts this block out of DocsShell's prose styling
     (the reset lives in DocsShell so it can override the .docs-prose rules). */
  .talos-demo {
    position: relative;
    margin: 1.25rem 0 1.75rem;
    border: 1px solid var(--talos-hud-edge, rgba(255, 255, 255, 0.14));
    border-radius: 4px;
    background: var(--talos-background, #08090b);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 28px 28px;
    color: var(--talos-foreground, #e7e9ec);
  }
  .talos-demo__label {
    position: absolute;
    top: 0.5rem;
    left: 0.75rem;
    font-family: var(--talos-font-display, system-ui);
    font-size: 0.6rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: var(--talos-tracking-hud, 0.22em);
    color: var(--talos-muted-foreground, rgba(231, 233, 236, 0.55));
    pointer-events: none;
  }
  .talos-demo__surface {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding: 2.25rem 1.75rem 1.75rem;
  }
</style>
