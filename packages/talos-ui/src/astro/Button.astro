---
/**
 * Button — chamfered HUD CTA. Renders <a> when href is set, else <button>.
 * Requires "@shelfwood/talos-ui/talos.css".
 */
interface Props {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = "primary", size = "md", href, class: className, ...rest } =
  Astro.props;
const Element = href ? "a" : "button";
const cls = [
  "talos-button",
  variant !== "primary" && `talos-button--${variant}`,
  size !== "md" && `talos-button--${size}`,
  className,
]
  .filter(Boolean)
  .join(" ");
const elementProps = href ? { href, ...rest } : rest;

// The chamfer outline is a single SVG <path> (fill + 1px non-scaling stroke).
// One path = one source of truth for the cut, so the diagonal gets a clean,
// uniform border with no doubled-edge "shadow" and no "chopped corner". The
// host carries NO background/clip-path so the SVG isn't clipped. Nominal
// 200×40 viewBox stretched to fit (non-scaling-stroke keeps the line 1px);
// the cut is 10 units deep.
---

<Element class={cls} {...elementProps}>
  <svg class="talos-button__shape" viewBox="0 0 200 40" preserveAspectRatio="none" aria-hidden="true" focusable="false">
    <path d="M0.5 0.5 H199.5 V29.5 L189.5 39.5 H0.5 Z" vector-effect="non-scaling-stroke" />
  </svg>
  <span class="talos-button__label"><slot /></span>
</Element>
