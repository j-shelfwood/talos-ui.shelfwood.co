---
/**
 * ToolkitPanel — skills/toolkit card: title header + grouped chip clusters.
 * Each group exposes a level heading and a flex-wrap of pills; emphasis "high"
 * brightens the chips, "low" mutes them. De-Tailwinded; self-contained styles.
 * Requires "@shelfwood/talos-ui/talos.css".
 */
import GlassPanel from "./GlassPanel.astro";

interface Group {
  level: string;
  emphasis?: "high" | "low";
  items: string[];
}
interface Props {
  title?: string;
  groups: Group[];
  class?: string;
}
const { title = "Toolkit", groups, class: className } = Astro.props;
---

<GlassPanel class={["toolkit-card", "talos-pad-lg", className].filter(Boolean).join(" ")}>
  <div class="toolkit-card__head">
    <span class="toolkit-card__title">{title}</span>
  </div>

  <div class="toolkit-card__groups">
    {groups.map((group) => (
      <div class="toolkit-card__group">
        <h3
          class={[
            "toolkit-card__level",
            group.emphasis === "high" ? "toolkit-card__level--high" : "toolkit-card__level--low",
          ].join(" ")}
        >
          {group.level}
        </h3>
        <div class="toolkit-card__chips">
          {group.items.map((item) => (
            <span
              class={[
                "toolkit-card__chip",
                group.emphasis === "high" ? "toolkit-card__chip--high" : "toolkit-card__chip--low",
              ].join(" ")}
            >
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</GlassPanel>

<style>
  .toolkit-card { display: flex; flex-direction: column; }
  .toolkit-card__head {
    display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.5rem;
  }
  .toolkit-card__title {
    font-family: var(--talos-font-display); font-size: 0.78rem; font-weight: 400;
    text-transform: uppercase; letter-spacing: var(--talos-tracking-hud);
    color: hsl(0 0% 100% / 0.92);
  }
  .toolkit-card__groups {
    display: flex; flex-direction: column; gap: 1.5rem; flex: 1;
  }
  .toolkit-card__group { display: flex; flex-direction: column; gap: 0.75rem; }
  .toolkit-card__level {
    font-family: var(--talos-font-display); font-weight: 400; font-size: 0.62rem;
    text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); margin: 0;
  }
  .toolkit-card__level--high { color: hsl(0 0% 100% / 0.9); }
  .toolkit-card__level--low { color: hsl(0 0% 100% / 0.45); }
  .toolkit-card__chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .toolkit-card__chip {
    font-family: var(--talos-font-display); font-weight: 300; font-size: 0.72rem;
    letter-spacing: var(--talos-tracking-hud-tight);
    padding: 0.3rem 0.75rem; border-radius: 999px; border: 1px solid transparent;
  }
  .toolkit-card__chip--high {
    background: hsl(0 0% 100% / 0.15); border-color: hsl(0 0% 100% / 0.2);
    color: hsl(0 0% 100%);
  }
  .toolkit-card__chip--low {
    background: hsl(0 0% 100% / 0.05); border-color: hsl(0 0% 100% / 0.1);
    color: var(--talos-muted-foreground);
  }
</style>
