---
/**
 * ServicePanel — service offering card: header (title + optional `icon` slot),
 * description, and a list of FeatureItem rows pinned with a system footer.
 * De-Tailwinded; self-contained styles.
 * Requires "@shelfwood/talos-ui/talos.css".
 */
import GlassPanel from "./GlassPanel.astro";
import FeatureItem from "./FeatureItem.astro";

interface Feature {
  title: string;
  description: string;
}
interface Props {
  title: string;
  description: string;
  features: Feature[];
  footer?: string;
  class?: string;
}
const {
  title,
  description,
  features,
  footer = "SYS://SERVICE",
  class: className,
} = Astro.props;

const hasIcon = Astro.slots.has("icon");
---

<GlassPanel class={["service-card", "talos-pad-lg", className].filter(Boolean).join(" ")}>
  <div class="service-card__head">
    {hasIcon && (
      <span class="service-card__icon" aria-hidden="true"><slot name="icon" /></span>
    )}
    <h3 class="service-card__title">{title}</h3>
  </div>

  <p class="service-card__desc">{description}</p>

  <hr class="talos-rule" style="margin:0 0 1.5rem" />

  <ul class="service-card__features">
    {features.map((feature) => (
      <li>
        <FeatureItem title={feature.title} description={feature.description} />
      </li>
    ))}
  </ul>

  <div class="service-card__foot"><span>{footer}</span><span class="caret">◢</span></div>
</GlassPanel>

<style>
  .service-card { display: flex; flex-direction: column; }
  .service-card__head {
    display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.9rem;
  }
  .service-card__icon {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 1.5rem; height: 1.5rem; color: var(--talos-muted-foreground);
  }
  .service-card__title {
    font-family: var(--talos-font-display); font-weight: 400; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: var(--talos-tracking-hud);
    color: var(--talos-foreground); margin: 0;
  }
  .service-card__desc {
    font-size: 0.9rem; line-height: 1.6; color: var(--talos-muted-foreground);
    margin: 0 0 1.5rem; text-wrap: balance;
  }
  .service-card__features {
    list-style: none; margin: 0; padding: 0; flex: 1;
    display: flex; flex-direction: column; gap: 1rem;
  }
  .service-card__foot {
    margin-top: 1.5rem; display: flex; justify-content: flex-end; align-items: center; gap: 0.5rem;
    font-family: var(--talos-font-display); font-size: 0.6rem;
    letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.3);
  }
  .service-card__foot .caret { font-size: 0.55rem; color: hsl(0 0% 100% / 0.4); }
</style>
