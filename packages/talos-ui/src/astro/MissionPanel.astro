---
/**
 * MissionPanel — ethos/mission card: header (title + slug), mission statement,
 * gradient rule, indexed axes list, system footer. De-Tailwinded.
 * Requires "@shelfwood/talos-ui/talos.css".
 */
import GlassPanel from "./GlassPanel.astro";

interface Axis {
  key: string;
  description: string;
}
interface Props {
  title?: string;
  slug?: string;
  label?: string;
  statement: string;
  axes?: Axis[];
  footer?: string;
  class?: string;
}
const {
  title = "Why",
  slug = "//02",
  label = "// Mission",
  statement,
  axes = [],
  footer = "SYS://ETHOS",
  class: className,
} = Astro.props;
---

<GlassPanel class={["mission-card", "talos-pad-lg", className].filter(Boolean).join(" ")}>
  <div class="mission-card__head">
    <span class="mission-card__title">{title}</span>
    <span class="mission-card__slug">{slug}</span>
  </div>
  <p class="mission-card__label">{label}</p>
  <p class="mission-card__statement">{statement}</p>
  <hr class="talos-rule" style="margin:0 0 1.5rem" />
  {axes.length > 0 && (
    <ol class="mission-card__axes">
      {axes.map((a, i) => (
        <li class="mission-card__axis">
          <span class="mission-card__index">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <p class="mission-card__axis-key">{a.key}</p>
            <p class="mission-card__axis-desc">{a.description}</p>
          </div>
        </li>
      ))}
    </ol>
  )}
  <div class="mission-card__foot"><span>{footer}</span><span class="caret">◢</span></div>
</GlassPanel>

<style>
  .mission-card { display: flex; flex-direction: column; }
  .mission-card__head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.25rem;
  }
  .mission-card__title {
    font-family: var(--talos-font-display); font-size: 0.78rem; font-weight: 400;
    text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.92);
  }
  .mission-card__slug {
    font-family: var(--talos-font-display); font-size: 0.68rem;
    letter-spacing: var(--talos-tracking-hud-tight); color: hsl(0 0% 100% / 0.35);
    font-variant-numeric: tabular-nums;
  }
  .mission-card__label {
    font-family: var(--talos-font-display); font-size: 0.62rem; text-transform: uppercase;
    letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.4); margin: 0 0 0.5rem;
  }
  .mission-card__statement {
    font-family: var(--talos-font-display); font-weight: 300; font-size: 1.05rem;
    line-height: 1.35; letter-spacing: 0.01em; color: hsl(0 0% 100% / 0.95);
    margin: 0 0 1.5rem; text-wrap: balance;
  }
  .mission-card__axes { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.1rem; flex: 1; }
  .mission-card__axis { display: grid; grid-template-columns: 2.25rem 1fr; gap: 0.75rem; align-items: baseline; }
  .mission-card__index {
    font-family: var(--talos-font-display); font-size: 0.78rem; font-weight: 400;
    letter-spacing: var(--talos-tracking-hud-tight); color: hsl(0 0% 100% / 0.5);
    font-variant-numeric: tabular-nums; text-align: right;
    border-right: 1px solid hsl(0 0% 100% / 0.12); padding-right: 0.6rem;
  }
  .mission-card__axis-key {
    font-family: var(--talos-font-display); font-size: 0.72rem; font-weight: 500;
    text-transform: uppercase; letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100%); margin: 0 0 0.3rem;
  }
  .mission-card__axis-desc { font-size: 0.85rem; line-height: 1.5; color: hsl(0 0% 100% / 0.65); margin: 0; text-wrap: pretty; }
  .mission-card__foot {
    margin-top: 1.5rem; display: flex; justify-content: flex-end; align-items: center; gap: 0.5rem;
    font-family: var(--talos-font-display); font-size: 0.6rem; letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.3);
  }
  .mission-card__foot .caret { font-size: 0.55rem; color: hsl(0 0% 100% / 0.4); }
</style>
