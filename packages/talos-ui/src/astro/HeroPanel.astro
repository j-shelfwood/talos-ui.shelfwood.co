---
/**
 * HeroPanel — full-width identity hero with HUD header (label + status dot +
 * version slug), large uppercase headline, summary + vitals split, and a
 * system footer. De-Tailwinded; self-contained scoped styles.
 * Requires "@shelfwood/talos-ui/talos.css".
 */
import GlassPanel from "./GlassPanel.astro";

interface Vital {
  key: string;
  value: string;
}
interface Props {
  label?: string;
  status?: string;
  version?: string;
  eyebrow?: string;
  headline: string;
  summary?: string;
  vitals?: Vital[];
  footer?: string;
  class?: string;
}
const {
  label = "// Identity",
  status = "Online",
  version = "v0.0.1",
  eyebrow,
  headline,
  summary,
  vitals = [],
  footer = "SYS://HOME",
  class: className,
} = Astro.props;
---

<GlassPanel class={["hero-card", "talos-pad-lg", className].filter(Boolean).join(" ")}>
  <div class="hero-card__head">
    <span class="hero-card__label">{label}</span>
    <span class="hero-card__div"></span>
    <span class="hero-card__status">
      <span class="talos-dot"></span>{status}
    </span>
    <span class="hero-card__slug">{version}</span>
  </div>

  <div class="hero-card__hero">
    {eyebrow && <span class="hero-card__eyebrow">{eyebrow}</span>}
    <h1 class="hero-card__headline">{headline}<span class="hero-card__dot">.</span></h1>
  </div>

  <hr class="talos-rule" style="margin:0 0 2rem" />

  <div class="hero-card__split">
    {summary && <p class="hero-card__summary">{summary}</p>}
    {vitals.length > 0 && (
      <dl class="hero-card__vitals">
        {vitals.map((v) => (
          <div class="hero-card__vital">
            <dt class="hero-card__vital-key">{v.key}</dt>
            <dd class="hero-card__vital-val"><span class="slash">/</span>{v.value}</dd>
          </div>
        ))}
      </dl>
    )}
  </div>

  <div class="hero-card__foot">
    <span>{footer}</span><span class="caret">◢</span>
  </div>
</GlassPanel>

<style>
  .hero-card { display: flex; flex-direction: column; }
  .hero-card__head {
    display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
    font-family: var(--talos-font-display); font-size: 0.62rem;
    text-transform: uppercase; letter-spacing: var(--talos-tracking-hud);
    color: hsl(0 0% 100% / 0.45); margin-bottom: 1.5rem;
  }
  .hero-card__label { color: hsl(0 0% 100% / 0.6); }
  .hero-card__div { flex: 0 0 1.25rem; height: 1px; background: hsl(0 0% 100% / 0.18); }
  .hero-card__status { display: inline-flex; align-items: center; gap: 0.5rem; color: hsl(0 0% 100% / 0.8); }
  .hero-card__slug { margin-left: auto; font-variant-numeric: tabular-nums; color: hsl(0 0% 100% / 0.5); }

  .hero-card__hero { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; }
  .hero-card__eyebrow {
    font-family: var(--talos-font-display); font-size: 0.7rem; text-transform: uppercase;
    letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.5);
  }
  .hero-card__headline {
    font-family: var(--talos-font-display); font-weight: 300;
    font-size: clamp(2.25rem, 4.5vw, 4rem); line-height: 1.02; letter-spacing: 0.005em;
    text-transform: uppercase; color: hsl(0 0% 100%); margin: 0;
  }
  .hero-card__dot { color: hsl(0 0% 100% / 0.35); margin-left: 0.1em; }

  .hero-card__split { display: grid; grid-template-columns: 1fr; gap: 1.5rem; flex: 1; }
  @media (min-width: 768px) {
    .hero-card__split { grid-template-columns: 1.4fr 1fr; gap: 2.5rem; }
  }
  .hero-card__summary {
    font-size: 0.95rem; line-height: 1.65; color: hsl(0 0% 100% / 0.78);
    max-width: 38ch; margin: 0;
  }
  .hero-card__vitals {
    margin: 0; padding: 0 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.85rem;
    border-left: 1px solid hsl(0 0% 100% / 0.12);
  }
  @media (max-width: 767px) {
    .hero-card__vitals {
      border-left: 0; border-top: 1px solid hsl(0 0% 100% / 0.12);
      padding: 1.25rem 0 0;
    }
  }
  .hero-card__vital { display: grid; grid-template-columns: 5rem 1fr; gap: 0.5rem; align-items: baseline; }
  .hero-card__vital-key {
    font-family: var(--talos-font-display); font-size: 0.62rem; text-transform: uppercase;
    letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.45);
  }
  .hero-card__vital-val {
    margin: 0; font-family: var(--talos-font-display); font-size: 0.78rem;
    letter-spacing: var(--talos-tracking-hud-tight); text-transform: uppercase;
    color: hsl(0 0% 100% / 0.9); display: inline-flex; gap: 0.5rem;
  }
  .hero-card__vital-val .slash { color: hsl(0 0% 100% / 0.3); font-weight: 300; }

  .hero-card__foot {
    margin-top: 2rem; display: flex; justify-content: flex-end; align-items: center; gap: 0.5rem;
    font-family: var(--talos-font-display); font-size: 0.6rem;
    letter-spacing: var(--talos-tracking-hud); color: hsl(0 0% 100% / 0.3);
  }
  .hero-card__foot .caret { font-size: 0.55rem; color: hsl(0 0% 100% / 0.4); }
</style>
