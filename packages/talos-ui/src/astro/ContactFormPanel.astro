---
/**
 * ContactFormPanel — chamfered HUD contact form: header (eyebrow + title),
 * name / email / subject inputs, message textarea, and a submit button.
 * De-Tailwinded from shelfwood.co's ContactFormPanel.
 *
 * Requires the consumer to import BOTH:
 *   "@shelfwood/talos-ui/talos.css"        (tokens + .talos-button)
 *   "@shelfwood/talos-ui/talos-forms.css"  (.talos-field / .talos-input / …)
 * This component intentionally does NOT import the CSS itself.
 */
import GlassPanel from "./GlassPanel.astro";

interface Props {
  action?: string;
  method?: string;
  class?: string;
}
const {
  action = "#",
  method = "POST",
  class: className,
} = Astro.props;
---

<GlassPanel class={["contact-form", "talos-pad-lg", className].filter(Boolean).join(" ")}>
  <header class="contact-form__head">
    <p class="talos-eyebrow">// Contact</p>
    <h2 class="contact-form__title">Send a Message</h2>
    <p class="contact-form__lede">Fill out the form below and I'll get back to you within 24 hours.</p>
  </header>

  <form class="contact-form__form" action={action} method={method}>
    <div class="contact-form__row">
      <div class="talos-field">
        <label class="talos-label" for="name">Name</label>
        <input class="talos-input" type="text" id="name" name="name" required placeholder="Your full name" />
      </div>
      <div class="talos-field">
        <label class="talos-label" for="email">Email</label>
        <input class="talos-input" type="email" id="email" name="email" required placeholder="your.email@example.com" />
      </div>
    </div>

    <div class="talos-field">
      <label class="talos-label" for="subject">Subject</label>
      <input class="talos-input" type="text" id="subject" name="subject" required placeholder="What's this about?" />
    </div>

    <div class="talos-field">
      <label class="talos-label" for="message">Message</label>
      <textarea class="talos-textarea" id="message" name="message" rows="5" required placeholder="Tell me about your project, goals, timeline…"></textarea>
    </div>

    <button class="talos-button talos-button--lg contact-form__submit" type="submit">Send Message</button>
  </form>
</GlassPanel>

<style>
  .contact-form { display: flex; flex-direction: column; }
  .contact-form__head { margin-bottom: 1.5rem; }
  .contact-form__title {
    font-family: var(--talos-font-display);
    font-weight: 300;
    font-size: 1.25rem;
    color: hsl(0 0% 100% / 0.95);
    margin: 0.5rem 0 0.4rem;
  }
  .contact-form__lede {
    font-size: 0.85rem;
    line-height: 1.5;
    color: hsl(var(--talos-muted-foreground-hsl));
    margin: 0;
  }
  .contact-form__form { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-form__row { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 640px) {
    .contact-form__row { grid-template-columns: 1fr 1fr; }
  }
  .contact-form__submit { width: 100%; margin-top: 0.25rem; }
</style>
