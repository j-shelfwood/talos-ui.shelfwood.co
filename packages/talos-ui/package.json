{
  "name": "@shelfwood/talos-ui",
  "version": "0.0.1",
  "description": "Dark-monochrome HUD design system — chamfered panels, Oxanium type, ambient grid, and composable notched-panel web components. Framework-agnostic CSS + opt-in web components + Astro wrappers.",
  "license": "MIT",
  "author": "Joris Schelfhout <joris@shelfwood.co>",
  "homepage": "https://talos-ui.shelfwood.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shelfwood/talos-ui.shelfwood.co.git",
    "directory": "packages/talos-ui"
  },
  "keywords": [
    "design-system",
    "hud",
    "web-components",
    "astro",
    "css",
    "monochrome",
    "chamfer",
    "ui"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/all.css",
    "src/tokens.css",
    "src/talos.css",
    "src/talos-blog.css",
    "src/talos-forms.css",
    "src/talos-feedback.css",
    "src/talos-data.css",
    "src/talos-nav.css",
    "src/fonts",
    "src/astro",
    "DESIGN.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/wc/index.d.ts",
      "import": "./dist/wc/index.js"
    },
    "./all.css": "./src/all.css",
    "./tokens.css": "./src/tokens.css",
    "./talos.css": "./src/talos.css",
    "./talos-blog.css": "./src/talos-blog.css",
    "./talos-forms.css": "./src/talos-forms.css",
    "./talos-feedback.css": "./src/talos-feedback.css",
    "./talos-data.css": "./src/talos-data.css",
    "./talos-nav.css": "./src/talos-nav.css",
    "./wc": {
      "types": "./dist/wc/index.d.ts",
      "import": "./dist/wc/index.js"
    },
    "./astro/*": "./src/astro/*",
    "./fonts/*": "./src/fonts/*"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
